</div>


<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
            const temperatureUnitLabel = <%- JSON.stringify(typeof temperatureUnit !== "undefined" ? temperatureUnit : "°C") %>;
        const radarScoreFields = [
            { id: "richness", label: "Richness", outputId: "richnessValue" },
            { id: "sweetness", label: "Sweetness", outputId: "sweetnessValue" },
            { id: "aftertaste", label: "Aftertaste", outputId: "aftertasteValue" },
            { id: "aroma", label: "Aroma", outputId: "aromaValue" },
            { id: "acidity", label: "Acidity", outputId: "acidityValue" }
        ];

        const radarChartElement = document.getElementById("brewCharacteristicsRadarChart");

        const enableLocationDefaults = <%= typeof enableLocationDefaults !== "undefined" && enableLocationDefaults ? "true" : "false" %>;
        const equipmentLocationMessage = document.getElementById("equipmentLocationMessage");
        const grinderSelect = document.getElementById("grinderId");
        const brewerSelect = document.getElementById("brewerId");
        let userManuallyChangedEquipment = false;

        function escapeHtml(value) {
            return String(value || "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function formatDistanceLabel(distanceMeters) {
            if (typeof distanceMeters !== "number") {
                return "";
            }

            if (distanceMeters < 1000) {
                return Math.round(distanceMeters) + " m";
            }

            return (distanceMeters / 1000).toFixed(1) + " km";
        }

        function buildCandidateButtons(candidates, targetSelectId, label) {
            if (!candidates || candidates.length <= 1) {
                return "";
            }

            const buttons = candidates.slice(0, 4).map(function (candidate) {
                const locationText = candidate.locationName ? " · " + candidate.locationName : "";
                return "<button type=\"button\" class=\"btn btn-sm btn-outline-primary me-1 mb-1\" data-location-equipment-target=\"" + targetSelectId + "\" data-location-equipment-id=\"" + candidate.id + "\">" +
                    escapeHtml(candidate.name + locationText + " · " + formatDistanceLabel(candidate.distanceMeters)) +
                    "</button>";
            }).join("");

            return "<div class=\"mt-2\"><div class=\"small fw-semibold mb-1\">Other nearby " + label + " options</div>" + buttons + "</div>";
        }

        function showEquipmentLocationMessage(type, message, htmlSuffix) {
            if (!equipmentLocationMessage) {
                return;
            }

            equipmentLocationMessage.innerHTML = "<div class=\"alert alert-" + type + " py-2 small\">" + message + (htmlSuffix || "") + "</div>";
        }

        function clearEquipmentLocationMessage() {
            if (equipmentLocationMessage) {
                equipmentLocationMessage.innerHTML = "";
            }
        }

        function applySuggestedEquipment(data) {
            const applied = [];

            if (!userManuallyChangedEquipment && data.grinder && grinderSelect) {
                grinderSelect.value = String(data.grinder.id);
                applied.push("grinder " + data.grinder.name + " (" + data.grinder.matchStrength + ", " + formatDistanceLabel(data.grinder.distanceMeters) + ")");
            }

            if (!userManuallyChangedEquipment && data.brewer && brewerSelect) {
                brewerSelect.value = String(data.brewer.id);
                applied.push("brewer " + data.brewer.name + " (" + data.brewer.matchStrength + ", " + formatDistanceLabel(data.brewer.distanceMeters) + ")");
            }

            if (applied.length === 0) {
                return;
            }

            showEquipmentLocationMessage(
                "info",
                escapeHtml("Suggested nearby equipment: " + applied.join(" and ") + ". You can manually override this."),
                buildCandidateButtons(data.grinderCandidates, "grinderId", "grinder") + buildCandidateButtons(data.brewerCandidates, "brewerId", "brewer")
            );
        }

        async function requestLocationEquipmentDefaults() {
            if (!enableLocationDefaults || !navigator.geolocation) {
                return;
            }

            navigator.geolocation.getCurrentPosition(async function (position) {
                if (position.coords && position.coords.accuracy && position.coords.accuracy > 500) {
                    clearEquipmentLocationMessage();
                    return;
                }

                const body = new URLSearchParams();
                body.set("latitude", String(position.coords.latitude));
                body.set("longitude", String(position.coords.longitude));

                try {
                    const response = await fetch("/brew-sessions/equipment-location-suggestions", {
                        method: "POST",
                        headers: {
                            "Accept": "application/json",
                            "Content-Type": "application/x-www-form-urlencoded",
                            "X-Requested-With": "fetch"
                        },
                        body: body.toString(),
                        credentials: "same-origin"
                    });

                    const data = await response.json();

                    if (!response.ok || !data || !data.ok) {
                        return;
                    }

                    applySuggestedEquipment(data);
                } catch {
                    clearEquipmentLocationMessage();
                }
            }, function () {
                clearEquipmentLocationMessage();
            }, {
                enableHighAccuracy: true,
                timeout: 8000,
                maximumAge: 60000
            });
        }

        [grinderSelect, brewerSelect].forEach(function (select) {
            if (!select) {
                return;
            }

            select.addEventListener("change", function () {
                userManuallyChangedEquipment = true;
            });
        });

        if (equipmentLocationMessage) {
            equipmentLocationMessage.addEventListener("click", function (event) {
                const target = event.target;

                if (!target || !target.matches("[data-location-equipment-target]")) {
                    return;
                }

                const selectId = target.getAttribute("data-location-equipment-target");
                const equipmentId = target.getAttribute("data-location-equipment-id");
                const select = document.getElementById(selectId);

                if (select && equipmentId) {
                    select.value = equipmentId;
                    userManuallyChangedEquipment = true;
                }
            });
        }

        requestLocationEquipmentDefaults();

        let brewCharacteristicsRadarChart = null;
        let isDraggingRadarScore = false;

        function clampRadarScore(value) {
            const parsed = Number(value);

            if (Number.isNaN(parsed)) {
                return 3;
            }

            return Math.min(5, Math.max(1, Math.round(parsed)));
        }

        function getRadarScoreValue(fieldId) {
            const input = document.getElementById(fieldId);

            if (!input) {
                return 3;
            }

            return clampRadarScore(input.value);
        }

        function getRadarScoreValues() {
            return radarScoreFields.map(function (field) {
                return getRadarScoreValue(field.id);
            });
        }

        function updateRadarScoreOutputs() {
            radarScoreFields.forEach(function (field) {
                const output = document.getElementById(field.outputId);

                if (output) {
                    output.textContent = String(getRadarScoreValue(field.id));
                }
            });
        }

        function updateRadarScoreEditor() {
            updateRadarScoreOutputs();

            if (brewCharacteristicsRadarChart) {
                brewCharacteristicsRadarChart.data.datasets[0].data = getRadarScoreValues();
                brewCharacteristicsRadarChart.update("none");
            }
        }

        function setRadarScoreValue(fieldId, value) {
            const input = document.getElementById(fieldId);
            const score = clampRadarScore(value);

            if (input) {
                input.value = String(score);
            }

            updateRadarScoreEditor();
        }

        function getRadarAxisAngle(index) {
            return (-90 + index * 72) * Math.PI / 180;
        }

        function getNearestRadarFieldIndex(point, radialScale) {
            const dx = point.x - radialScale.xCenter;
            const dy = point.y - radialScale.yCenter;
            let bestIndex = 0;
            let bestDot = -Infinity;

            radarScoreFields.forEach(function (field, index) {
                const angle = getRadarAxisAngle(index);
                const dot = dx * Math.cos(angle) + dy * Math.sin(angle);

                if (dot > bestDot) {
                    bestDot = dot;
                    bestIndex = index;
                }
            });

            return bestIndex;
        }

        function isPointInsidePolygon(point, polygonPoints) {
            let isInside = false;
            let j = polygonPoints.length - 1;

            for (let i = 0; i < polygonPoints.length; i += 1) {
                const xi = polygonPoints[i].x;
                const yi = polygonPoints[i].y;
                const xj = polygonPoints[j].x;
                const yj = polygonPoints[j].y;
                const intersects = ((yi > point.y) !== (yj > point.y)) &&
                    (point.x < (xj - xi) * (point.y - yi) / (yj - yi) + xi);

                if (intersects) {
                    isInside = !isInside;
                }

                j = i;
            }

            return isInside;
        }

        function getRadarMaxPolygonPoints(radialScale) {
            if (!radialScale || typeof radialScale.getPointPositionForValue !== "function") {
                return [];
            }

            return radarScoreFields.map(function (field, index) {
                return radialScale.getPointPositionForValue(index, 5);
            });
        }

        function getExpandedRadarPolygonPoints(radialScale, edgeTolerancePixels) {
            const polygonPoints = getRadarMaxPolygonPoints(radialScale);

            if (polygonPoints.length < 3) {
                return [];
            }

            return polygonPoints.map(function (polygonPoint) {
                const dx = polygonPoint.x - radialScale.xCenter;
                const dy = polygonPoint.y - radialScale.yCenter;
                const distance = Math.sqrt(dx * dx + dy * dy);

                if (distance <= 0) {
                    return polygonPoint;
                }

                const scale = (distance + edgeTolerancePixels) / distance;

                return {
                    x: radialScale.xCenter + dx * scale,
                    y: radialScale.yCenter + dy * scale
                };
            });
        }

        function isPointInsideRadarPentagon(point, radialScale, event) {
            const edgeTolerancePixels = event && event.pointerType === "touch" ? 24 : 16;
            const polygonPoints = getExpandedRadarPolygonPoints(radialScale, edgeTolerancePixels);

            if (polygonPoints.length < 3) {
                return false;
            }

            return isPointInsidePolygon(point, polygonPoints);
        }

        function getRadarPointerPoint(event) {
            if (!window.Chart || !window.Chart.helpers || !brewCharacteristicsRadarChart) {
                return null;
            }

            return window.Chart.helpers.getRelativePosition(event, brewCharacteristicsRadarChart);
        }

        function updateRadarScoreFromPointer(event) {
            if (!brewCharacteristicsRadarChart) {
                return false;
            }

            const radialScale = brewCharacteristicsRadarChart.scales.r;
            const point = getRadarPointerPoint(event);

            if (!radialScale || !point || !isPointInsideRadarPentagon(point, radialScale, event)) {
                return false;
            }

            const fieldIndex = getNearestRadarFieldIndex(point, radialScale);
            const angle = getRadarAxisAngle(fieldIndex);
            const dx = point.x - radialScale.xCenter;
            const dy = point.y - radialScale.yCenter;
            const projectedDistance = dx * Math.cos(angle) + dy * Math.sin(angle);
            const score = projectedDistance / radialScale.drawingArea * 5;

            setRadarScoreValue(radarScoreFields[fieldIndex].id, score);
            return true;
        }

        if (window.Chart && radarChartElement) {
            brewCharacteristicsRadarChart = new Chart(radarChartElement, {
                type: "radar",
                data: {
                    labels: radarScoreFields.map(function (field) {
                        return field.label;
                    }),
                    datasets: [
                        {
                            label: "This Brew",
                            data: getRadarScoreValues()
                        }
                    ]
                },
                options: {
                    responsive: true,
                    scales: {
                        r: {
                            beginAtZero: true,
                            min: 0,
                            max: 5,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    }
                }
            });

            function beginRadarScoreDrag(event) {
                const didUpdate = updateRadarScoreFromPointer(event);

                if (!didUpdate) {
                    return false;
                }

                isDraggingRadarScore = true;

                const radarEditor = radarChartElement.closest(".radar-score-editor");

                if (radarEditor) {
                    radarEditor.classList.add("is-radar-dragging");
                }

                if (radarChartElement.setPointerCapture) {
                    radarChartElement.setPointerCapture(event.pointerId);
                }

                event.preventDefault();
                return true;
            }

            function endRadarScoreDrag(event) {
                isDraggingRadarScore = false;

                const radarEditor = radarChartElement.closest(".radar-score-editor");

                if (radarEditor) {
                    radarEditor.classList.remove("is-radar-dragging");
                }

                if (event && radarChartElement.hasPointerCapture && radarChartElement.hasPointerCapture(event.pointerId)) {
                    radarChartElement.releasePointerCapture(event.pointerId);
                }
            }

            radarChartElement.addEventListener("pointerdown", function (event) {
                beginRadarScoreDrag(event);
            });

            radarChartElement.addEventListener("pointermove", function (event) {
                if (isDraggingRadarScore) {
                    updateRadarScoreFromPointer(event);
                    event.preventDefault();
                }
            });

            radarChartElement.addEventListener("pointerup", function (event) {
                endRadarScoreDrag(event);
            });

            radarChartElement.addEventListener("pointercancel", function (event) {
                endRadarScoreDrag(event);
            });

            radarChartElement.addEventListener("touchmove", function (event) {
                if (isDraggingRadarScore) {
                    event.preventDefault();
                }
            }, { passive: false });

            radarChartElement.addEventListener("touchend", function () {
                endRadarScoreDrag(null);
            });

            radarChartElement.addEventListener("touchcancel", function () {
                endRadarScoreDrag(null);
            });
        }

        updateRadarScoreEditor();

        const overallRatingInput = document.getElementById("overallRating");
        const overallRatingDisplay = document.getElementById("overallRatingDisplay");
        const overallRatingButtons = document.querySelectorAll(".star-rating-button");
        const clearOverallRatingButton = document.getElementById("clearOverallRatingButton");

        function normalizeRatingValue(value) {
            if (value === null || typeof value === "undefined" || value === "") {
                return "";
            }

            const parsed = Number(value);

            if (Number.isNaN(parsed) || parsed <= 0) {
                return "";
            }

            const clamped = Math.min(5, Math.max(0.5, parsed));
            const roundedToHalf = Math.round(clamped * 2) / 2;

            if (Number.isInteger(roundedToHalf)) {
                return String(roundedToHalf);
            }

            return roundedToHalf.toFixed(1);
        }

        function getDisplayRatingText(value) {
            const normalized = normalizeRatingValue(value);

            if (!normalized) {
                return "No rating";
            }

            return normalized + " / 5";
        }

        function setStarVisual(value) {
            const normalized = normalizeRatingValue(value);
            const rating = normalized ? Number(normalized) : 0;

            overallRatingButtons.forEach(function (button) {
                const starNumber = Number(button.getAttribute("data-star-number") || "0");
                let fillWidth = 0;

                if (rating >= starNumber) {
                    fillWidth = 100;
                } else if (rating >= starNumber - 0.5) {
                    fillWidth = 50;
                }

                button.style.setProperty("--star-fill-width", fillWidth + "%");
            });
        }

        function setOverallRating(value) {
            const normalized = normalizeRatingValue(value);

            if (overallRatingInput) {
                overallRatingInput.value = normalized;
            }

            if (overallRatingDisplay) {
                overallRatingDisplay.textContent = getDisplayRatingText(normalized);
            }

            setStarVisual(normalized);
        }

        function getRatingFromPointerEvent(button, event) {
            const starNumber = Number(button.getAttribute("data-star-number") || "0");
            const buttonRect = button.getBoundingClientRect();
            const offsetX = event.clientX - buttonRect.left;
            const isLeftHalf = offsetX <= buttonRect.width / 2;

            if (isLeftHalf) {
                return starNumber - 0.5;
            }

            return starNumber;
        }

        overallRatingButtons.forEach(function (button) {
            button.addEventListener("mousemove", function (event) {
                const previewRating = getRatingFromPointerEvent(button, event);

                setStarVisual(previewRating);

                if (overallRatingDisplay) {
                    overallRatingDisplay.textContent = getDisplayRatingText(previewRating);
                }
            });

            button.addEventListener("mouseleave", function () {
                const currentValue = overallRatingInput ? overallRatingInput.value : "";

                setStarVisual(currentValue);

                if (overallRatingDisplay) {
                    overallRatingDisplay.textContent = getDisplayRatingText(currentValue);
                }
            });

            button.addEventListener("click", function (event) {
                const selectedRating = getRatingFromPointerEvent(button, event);

                setOverallRating(selectedRating);
            });
        });

        if (clearOverallRatingButton) {
            clearOverallRatingButton.addEventListener("click", function () {
                setOverallRating("");
            });
        }

        if (overallRatingInput) {
            setOverallRating(overallRatingInput.value);
        }

        const suggestRecipeButton = document.getElementById("suggestRecipeButton");
        const applyRecipeButton = document.getElementById("applyRecipeButton");
        const brewAssistantMessage = document.getElementById("brewAssistantMessage");
        const recipeResultMessage = document.getElementById("recipeResultMessage");
        const recipeResultModalElement = document.getElementById("recipeResultModal");

        let recipeResultModal = null;

        if (window.bootstrap && recipeResultModalElement) {
            recipeResultModal = new window.bootstrap.Modal(recipeResultModalElement);
        }

        function getElementValue(id) {
            const element = document.getElementById(id);

            if (!element) {
                return "";
            }

            return element.value || "";
        }

        function setElementValue(id, value) {
            const element = document.getElementById(id);

            if (element) {
                element.value = value || "";
            }
        }

        function setText(id, value) {
            const element = document.getElementById(id);

            if (element) {
                element.textContent = value || "-";
            }
        }

        function escapeHtml(value) {
            return String(value || "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function showMessage(container, type, message) {
            if (!container) {
                return;
            }

            container.innerHTML =
                '<div class="alert alert-' + type + '">' +
                escapeHtml(message) +
                '</div>';
        }

        function clearMessage(container) {
            if (container) {
                container.innerHTML = "";
            }
        }

        function setSuggestButtonLoading(isLoading) {
            if (!suggestRecipeButton) {
                return;
            }

            if (isLoading) {
                suggestRecipeButton.disabled = true;
                suggestRecipeButton.innerHTML =
                    '<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>' +
                    'Suggesting...';
            } else {
                suggestRecipeButton.disabled = false;
                suggestRecipeButton.innerHTML =
                    '<i class="bi bi-magic me-1"></i>' +
                    'Suggest Brewing Recipe';
            }
        }

        function appendListItems(listId, items) {
            const list = document.getElementById(listId);

            if (!list) {
                return;
            }

            list.innerHTML = "";

            if (!items || items.length === 0) {
                const item = document.createElement("li");
                item.textContent = "No details returned.";
                list.appendChild(item);
                return;
            }

            items.forEach(function (text) {
                const item = document.createElement("li");
                item.textContent = text;
                list.appendChild(item);
            });
        }

        function formatSecondsForDisplay(totalSeconds) {
            if (totalSeconds === null || typeof totalSeconds === "undefined") {
                return "-";
            }

            const parsed = Number(totalSeconds);

            if (Number.isNaN(parsed)) {
                return "-";
            }

            const minutes = Math.floor(parsed / 60);
            const seconds = parsed % 60;

            return minutes + ":" + String(seconds).padStart(2, "0");
        }

        function buildPourStructureText(recipe) {
            if (!recipe.pourStructure || recipe.pourStructure.length === 0) {
                return "";
            }

            return recipe.pourStructure.join("\n");
        }

        function buildRecipeStepsText(recipe) {
            const sections = [];

            if (recipe.recipeName) {
                sections.push(recipe.recipeName);
            }

            if (recipe.recipeSteps && recipe.recipeSteps.length > 0) {
                sections.push(recipe.recipeSteps.join("\n"));
            }

            return sections.join("\n\n");
        }

        function buildAdjustmentNotesText(recipe) {
            if (!recipe.adjustmentTips || recipe.adjustmentTips.length === 0) {
                return "";
            }

            return recipe.adjustmentTips.join("\n");
        }

        function populateRecipe(recipe) {
            setText("recipeName", recipe.recipeName || "Suggested Brewing Recipe");
            setText("recipeGrindSize", recipe.grindSize);
            setText("recipeWaterTemp", recipe.waterTemperature ? recipe.waterTemperature + " " + temperatureUnitLabel : "-");
            setText("recipeDose", recipe.coffeeDoseGrams ? recipe.coffeeDoseGrams + " g" : "-");
            setText("recipeYield", recipe.totalYieldGrams ? recipe.totalYieldGrams + " g" : "-");
            setText("recipeRatio", recipe.brewRatio);
            setText("recipeTime", formatSecondsForDisplay(recipe.totalBrewTimeSeconds));
            setText("recipeBloomWater", recipe.bloomWaterGrams ? recipe.bloomWaterGrams + " g" : "-");
            setText("recipeBloomTime", recipe.bloomSeconds ? recipe.bloomSeconds + " sec" : "-");

            appendListItems("recipePourStructure", recipe.pourStructure || []);
            appendListItems("recipeStepList", recipe.recipeSteps || []);
            appendListItems("recipeAdjustmentTips", recipe.adjustmentTips || []);
            appendListItems("recipeReasoningNotes", recipe.reasoningNotes || []);

            setElementValue("suggestedGrindSize", recipe.grindSize || "");
            setElementValue("suggestedWaterTemperatureC", recipe.waterTemperature || "");
            setElementValue("suggestedCoffeeDoseGrams", recipe.coffeeDoseGrams || "");
            setElementValue("suggestedTotalYieldGrams", recipe.totalYieldGrams || "");
            setElementValue("suggestedPourStructure", buildPourStructureText(recipe));
            setElementValue("suggestedRecipeSteps", buildRecipeStepsText(recipe));
            setElementValue("suggestedAdjustmentNotes", buildAdjustmentNotesText(recipe));
        }

        function validateAssistantInputs() {
            if (!getElementValue("coffeeBeanId")) {
                return "Please select a coffee bean.";
            }

            if (!getElementValue("grinderId")) {
                return "Please select a grinder.";
            }

            if (!getElementValue("brewerId")) {
                return "Please select a brewer.";
            }

            const dose = getElementValue("coffeeDoseGrams");

            if (!dose || Number.isNaN(Number(dose)) || Number(dose) <= 0) {
                return "Please enter bean weight / coffee dose.";
            }

            return "";
        }

        async function suggestRecipe() {
            clearMessage(brewAssistantMessage);
            clearMessage(recipeResultMessage);

            const validationMessage = validateAssistantInputs();

            if (validationMessage) {
                showMessage(brewAssistantMessage, "warning", validationMessage);
                return;
            }

            setSuggestButtonLoading(true);

            const controller = new AbortController();
            const timeoutId = window.setTimeout(function () {
                controller.abort();
            }, 90000);

            const body = new URLSearchParams();
            body.set("coffeeBeanId", getElementValue("coffeeBeanId"));
            body.set("grinderId", getElementValue("grinderId"));
            body.set("brewerId", getElementValue("brewerId"));
            body.set("coffeeDoseGrams", getElementValue("coffeeDoseGrams"));

            try {
                const response = await fetch("/brew-sessions/suggest-recipe", {
                    method: "POST",
                    headers: {
                        "Accept": "application/json",
                        "Content-Type": "application/x-www-form-urlencoded",
                        "X-Requested-With": "fetch"
                    },
                    body: body.toString(),
                    credentials: "same-origin",
                    signal: controller.signal
                });

                let data = null;

                try {
                    data = await response.json();
                } catch {
                    data = null;
                }

                if (!response.ok || !data || !data.ok) {
                    const errorMessage = data && data.errorMessage
                        ? data.errorMessage
                        : "Could not generate brewing recipe.";

                    showMessage(brewAssistantMessage, "danger", errorMessage);
                    return;
                }

                populateRecipe(data.recipe);

                if (typeof data.recentMatchingBrewCount === "number" && data.recentMatchingBrewCount > 0) {
                    showMessage(
                        recipeResultMessage,
                        "info",
                        "AI used " + data.recentMatchingBrewCount + " recent matching brew" + (data.recentMatchingBrewCount === 1 ? "" : "s") + " with the same bean, grinder, brewer, and dose."
                    );
                } else {
                    showMessage(
                        recipeResultMessage,
                        "secondary",
                        "No recent matching brews found for the same bean, grinder, brewer, and dose. AI used the selected setup and bean information only."
                    );
                }

                if (recipeResultModal) {
                    recipeResultModal.show();
                } else {
                    showMessage(brewAssistantMessage, "danger", "Bootstrap modal is not available. Please refresh the page and try again.");
                }
            } catch (error) {
                if (error && error.name === "AbortError") {
                    showMessage(brewAssistantMessage, "danger", "Generating the recipe took too long. Please try again.");
                } else {
                    showMessage(brewAssistantMessage, "danger", "Could not generate brewing recipe.");
                }
            } finally {
                window.clearTimeout(timeoutId);
                setSuggestButtonLoading(false);
            }
        }

        function applyRecipeToForm() {
            const grindSize = getElementValue("suggestedGrindSize");
            const waterTemperatureC = getElementValue("suggestedWaterTemperatureC");
            const coffeeDoseGrams = getElementValue("suggestedCoffeeDoseGrams");
            const totalYieldGrams = getElementValue("suggestedTotalYieldGrams");
            const suggestedPourStructure = getElementValue("suggestedPourStructure");
            const suggestedRecipeSteps = getElementValue("suggestedRecipeSteps");
            const suggestedAdjustmentNotes = getElementValue("suggestedAdjustmentNotes");

            if (grindSize) {
                setElementValue("grindSize", grindSize);
            }

            if (waterTemperatureC) {
                setElementValue("waterTemperatureC", waterTemperatureC);
            }

            if (coffeeDoseGrams) {
                setElementValue("coffeeDoseGrams", coffeeDoseGrams);
            }

            if (totalYieldGrams) {
                setElementValue("totalYieldGrams", totalYieldGrams);
            }


            if (suggestedPourStructure) {
                setElementValue("pourStructure", suggestedPourStructure);
            }

            if (suggestedRecipeSteps) {
                setElementValue("recipeSteps", suggestedRecipeSteps);
            }

            if (suggestedAdjustmentNotes) {
                setElementValue("adjustmentNotes", suggestedAdjustmentNotes);
            }

            if (recipeResultModal) {
                recipeResultModal.hide();
            }
        }

        if (suggestRecipeButton) {
            suggestRecipeButton.addEventListener("click", suggestRecipe);
        }

        if (applyRecipeButton) {
            applyRecipeButton.addEventListener("click", applyRecipeToForm);
        }
    });
</script>
