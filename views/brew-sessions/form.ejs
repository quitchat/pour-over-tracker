                    </div>

                    <div class="row g-3">
                        <div class="col-lg-6">
                            <div class="card h-100">
                                <div class="card-header">Pour Structure</div>
                                <div class="card-body">
                                    <ol class="mb-0" id="recipePourStructure"></ol>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="card h-100">
                                <div class="card-header">Recipe Steps</div>
                                <div class="card-body">
                                    <ol class="mb-0" id="recipeStepList"></ol>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="card h-100">
                                <div class="card-header">Adjustment Tips</div>
                                <div class="card-body">
                                    <ul class="mb-0" id="recipeAdjustmentTips"></ul>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="card h-100">
                                <div class="card-header">Reasoning</div>
                                <div class="card-body">
                                    <ul class="mb-0" id="recipeReasoningNotes"></ul>
                                </div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="suggestedGrindSize">
                    <input type="hidden" id="suggestedWaterTemperatureC">
                    <input type="hidden" id="suggestedCoffeeDoseGrams">
                    <input type="hidden" id="suggestedTotalYieldGrams">
                    <input type="hidden" id="suggestedPourStructure">
                    <input type="hidden" id="suggestedRecipeSteps">
                    <input type="hidden" id="suggestedAdjustmentNotes">
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-success" id="applyRecipeButton">
                    <i class="bi bi-check-circle me-1"></i>
                    Apply to Form
