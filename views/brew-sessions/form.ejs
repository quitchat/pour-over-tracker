<%
    const errorsValue = typeof errors !== "undefined" ? errors : [];
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row brew-entry-header">
    <div>
        <h1 class="h3 mb-1"><%= pageHeading %></h1>
        <p class="text-muted mb-0">Track brew variables and bean characteristics.</p>
    </div>

    <a href="/brew-sessions" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>
        Back to List
    </a>
</div>

<% if (errorsValue && errorsValue.length > 0) { %>
    <div class="alert alert-danger">
        <strong>Please fix the following:</strong>
        <ul class="mb-0">
            <% errorsValue.forEach(function (error) { %>
                <li><%= error %></li>
            <% }); %>
        </ul>
    </div>
<% } %>

<div id="brewAssistantMessage"></div>

<style>
    .star-rating-control {
        display: inline-flex;
        align-items: center;
        gap: 0.15rem;
    }

    .star-rating-button {
        position: relative;
        width: 2.1rem;
        height: 2.1rem;
        border: 0;
        background: transparent;
        padding: 0;
        line-height: 1;
        cursor: pointer;
    }

    .star-rating-button:focus-visible {
        outline: 2px solid var(--bs-primary);
        outline-offset: 2px;
        border-radius: 0.35rem;
    }

    .star-rating-empty,
    .star-rating-filled {
        position: absolute;
        left: 0;
        top: 0;
        font-size: 2rem;
    }

    .star-rating-empty {
        color: #dee2e6;
    }

    .star-rating-filled {
        color: #ffc107;
        width: var(--star-fill-width, 0%);
        overflow: hidden;
        white-space: nowrap;
    }

    .star-rating-button:hover .star-rating-empty {
        color: #ced4da;
    }

    .brew-session-mobile-form .form-control,
    .brew-session-mobile-form .form-select,
    .brew-session-mobile-form .btn {
        min-height: 2.75rem;
    }

    .brew-quick-field .form-label {
        font-weight: 600;
    }

    .radar-score-editor {
        max-width: 460px;
        margin: 0 auto;
        touch-action: none;
        user-select: none;
    }

    .radar-score-editor svg {
        width: 100%;
        height: auto;
        display: block;
        cursor: crosshair;
    }

    .radar-score-editor:focus-within svg,
    .radar-score-editor svg:focus-visible {
        outline: 2px solid var(--bs-primary);
        outline-offset: 0.35rem;
        border-radius: 0.75rem;
    }

    .radar-score-grid-line {
        fill: none;
        stroke: #dee2e6;
        stroke-width: 1;
    }

    .radar-score-axis-line {
        stroke: #adb5bd;
        stroke-width: 1;
    }

    .radar-score-area {
        fill: rgba(13, 110, 253, 0.22);
        stroke: var(--bs-primary);
        stroke-width: 3;
    }

    .radar-score-handle {
        fill: var(--bs-primary);
        stroke: #fff;
        stroke-width: 3;
        cursor: grab;
    }

    .radar-score-handle:active {
        cursor: grabbing;
    }

    .radar-score-label {
        font-size: 13px;
        font-weight: 600;
        fill: #212529;
    }

    .radar-score-number {
        font-size: 12px;
        fill: #6c757d;
    }

    .radar-score-value-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 0.5rem;
    }

    .radar-score-value-pill {
        border: 1px solid var(--bs-border-color);
        border-radius: 999px;
        padding: 0.4rem 0.7rem;
        background: var(--bs-body-bg);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        font-size: 0.9rem;
    }

    .radar-score-value-pill strong {
        white-space: nowrap;
        flex-shrink: 0;
    }


    .brew-form-actions {
        background: var(--bs-body-bg);
        border-top: 1px solid transparent;
    }

    @media (max-width: 767.98px) {
        .brew-entry-header .btn {
            width: 100%;
        }

        .brew-session-mobile-form .card {
            border-radius: 0.85rem;
        }

        .brew-session-mobile-form .card-body {
            padding: 1rem;
        }

        .brew-session-mobile-form .form-control,
        .brew-session-mobile-form .form-select,
        .brew-session-mobile-form .btn {
            font-size: 1rem;
            min-height: 3rem;
        }

        .brew-form-actions {
            position: sticky;
            bottom: 0;
            z-index: 1020;
            margin-left: -0.75rem;
            margin-right: -0.75rem;
            padding: 0.75rem;
            border-top-color: var(--bs-border-color);
            box-shadow: 0 -0.25rem 1rem rgba(0, 0, 0, 0.08);
        }

        .brew-form-actions .btn {
            flex: 1 1 0;
        }

        .star-rating-button {
            width: 2.4rem;
            height: 2.4rem;
        }

        .star-rating-empty,
        .star-rating-filled {
            font-size: 2.3rem;
        }
    }
</style>

<form method="post" action="<%= formAction %>" id="brewSessionForm" class="brew-session-mobile-form">
    <div class="card mb-3">
        <div class="card-header">
            <i class="bi bi-stars me-1"></i>
            Brew Setup / AI Recipe
        </div>

        <div class="card-body">

            <div class="row g-3 brew-mobile-main-grid">
                <div class="brew-quick-field col-md-6">
                    <label for="coffeeBeanId" class="form-label">Coffee Bean</label>
                    <select class="form-select" id="coffeeBeanId" name="coffeeBeanId">
                        <option value="">Select coffee bean</option>
                        <% coffeeBeans.forEach(function (bean) { %>
                            <option value="<%= bean.id %>" <%= String(formData.coffeeBeanId || "") === String(bean.id) ? "selected" : "" %>>
                                <%= bean.label %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="brew-quick-field col-md-6">
                    <label for="brewDate" class="form-label">Brew Date</label>
                    <input
                        type="date"
                        class="form-control"
                        id="brewDate"
                        name="brewDate"
                        value="<%= formData.brewDate || "" %>">
                </div>

                <div class="brew-quick-field col-md-4">
                    <label for="grinderId" class="form-label">Grinder</label>
                    <select class="form-select" id="grinderId" name="grinderId">
                        <option value="">No grinder selected</option>
                        <% grinders.forEach(function (grinder) { %>
                            <option value="<%= grinder.id %>" <%= String(formData.grinderId || "") === String(grinder.id) ? "selected" : "" %>>
                                <%= grinder.name %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="brew-quick-field col-md-4">
                    <label for="brewerId" class="form-label">Brewer / Brew Method</label>
                    <select class="form-select" id="brewerId" name="brewerId">
                        <option value="">No brewer selected</option>
                        <% brewers.forEach(function (brewer) { %>
                            <option value="<%= brewer.id %>" <%= String(formData.brewerId || "") === String(brewer.id) ? "selected" : "" %>>
                                <%= brewer.name %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="brew-quick-field col-md-4">
                    <label for="coffeeDoseGrams" class="form-label">Bean Weight / Coffee Dose</label>
                    <input
                        type="number"
                        step="0.01"
                        min="0"
                        class="form-control"
                        id="coffeeDoseGrams"
                        name="coffeeDoseGrams"
                        value="<%= formData.coffeeDoseGrams || "" %>">
                </div>


                <div class="col-md-4 d-flex align-items-end">
                    <button type="button" class="btn btn-success w-100" id="suggestRecipeButton">
                        <i class="bi bi-magic me-1"></i>
                        Suggest Brewing Recipe
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            <i class="bi bi-cup-hot me-1"></i>
            Brew Recipe Values
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="brew-quick-field col-md-4">
                    <label for="grindSize" class="form-label">Grind Size</label>
                    <input
                        type="text"
                        class="form-control"
                        id="grindSize"
                        name="grindSize"
                        value="<%= formData.grindSize || "" %>">
                </div>

                <div class="brew-quick-field col-md-4">
                    <label for="waterTemperatureC" class="form-label">Water Temp °C</label>
                    <input
                        type="number"
                        step="0.1"
                        min="0"
                        class="form-control"
                        id="waterTemperatureC"
                        name="waterTemperatureC"
                        value="<%= formData.waterTemperatureC || "" %>">
                </div>

                <div class="brew-quick-field col-md-4">
                    <label for="totalYieldGrams" class="form-label">Total Yield</label>
                    <input
                        type="number"
                        step="0.01"
                        min="0"
                        class="form-control"
                        id="totalYieldGrams"
                        name="totalYieldGrams"
                        value="<%= formData.totalYieldGrams || "" %>">
                    <div class="form-text">Ratio is calculated from dose and yield.</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Total Brew Time</label>
                    <div class="input-group">
                        <input
                            type="number"
                            min="0"
                            step="1"
                            class="form-control"
                            id="totalBrewTimeMinutes"
                            name="totalBrewTimeMinutes"
                            placeholder="min"
                            value="<%= formData.totalBrewTimeMinutes || "" %>">
                        <span class="input-group-text">min</span>
                        <input
                            type="number"
                            min="0"
                            max="59"
                            step="1"
                            class="form-control"
                            id="totalBrewTimeSeconds"
                            name="totalBrewTimeSeconds"
                            placeholder="sec"
                            value="<%= formData.totalBrewTimeSeconds || "" %>">
                        <span class="input-group-text">sec</span>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label d-flex justify-content-between align-items-center" for="overallRating">
                        <span>Overall Rating</span>
                        <span class="text-muted small" id="overallRatingDisplay">No rating</span>
                    </label>

                    <input
                        type="hidden"
                        id="overallRating"
                        name="overallRating"
                        value="<%= formData.overallRating || "" %>">

                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="star-rating-control" id="overallRatingStars" role="radiogroup" aria-label="Overall rating">
                            <% [1, 2, 3, 4, 5].forEach(function (starNumber) { %>
                                <button
                                    type="button"
                                    class="star-rating-button"
                                    data-star-number="<%= starNumber %>"
                                    aria-label="Rate <%= starNumber %> star">
                                    <i class="bi bi-star-fill star-rating-empty"></i>
                                    <i class="bi bi-star-fill star-rating-filled"></i>
                                </button>
                            <% }); %>
                        </div>

                        <button type="button" class="btn btn-sm btn-outline-secondary" id="clearOverallRatingButton">
                            Clear
                        </button>
                    </div>

                    <div class="form-text">
                        Click the left half of a star for a half-star rating, or the right half for a full star.
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input
                            class="form-check-input"
                            type="checkbox"
                            id="wouldRepeat"
                            name="wouldRepeat"
                            <%= formData.wouldRepeat ? "checked" : "" %>>
                        <label class="form-check-label" for="wouldRepeat">
                            Would repeat this brew
                        </label>
                    </div>
                </div>

                <div class="col-12">
                    <label for="notes" class="form-label">Notes</label>
                    <textarea
                        class="form-control"
                        id="notes"
                        name="notes"
                        rows="4"><%= formData.notes || "" %></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center gap-2">
            <span>
                <i class="bi bi-activity me-1"></i>
                Brew Characteristics
            </span>

            <button
                type="button"
                class="btn btn-sm btn-outline-secondary d-md-none"
                data-bs-toggle="collapse"
                data-bs-target="#brewCharacteristicsCollapse"
                aria-expanded="true"
                aria-controls="brewCharacteristicsCollapse">
                Show / Hide
            </button>
        </div>

        <div class="collapse show d-md-block" id="brewCharacteristicsCollapse">
            <div class="card-body">
                <p class="text-muted">
                    Score this specific brew from 1 to 5 by clicking or dragging directly on the pentagon radar chart.
                </p>

                <input type="hidden" class="tasting-score-input" id="richness" name="richness" value="<%= formData.richness || '3' %>">
                <input type="hidden" class="tasting-score-input" id="sweetness" name="sweetness" value="<%= formData.sweetness || '3' %>">
                <input type="hidden" class="tasting-score-input" id="aftertaste" name="aftertaste" value="<%= formData.aftertaste || '3' %>">
                <input type="hidden" class="tasting-score-input" id="aroma" name="aroma" value="<%= formData.aroma || '3' %>">
                <input type="hidden" class="tasting-score-input" id="acidity" name="acidity" value="<%= formData.acidity || '3' %>">

                <div class="row g-4 align-items-center">
                    <div class="col-lg-7">
                        <div class="border rounded p-2 p-sm-3 bg-light">
                            <div class="radar-score-editor" id="brewCharacteristicsRadarEditor">
                                <svg
                                    id="brewCharacteristicsRadarSvg"
                                    viewBox="0 0 360 360"
                                    role="img"
                                    tabindex="0"
                                    aria-label="Interactive brew characteristics pentagon radar score editor">
                                    <g id="radarScoreGrid"></g>
                                    <polygon id="radarScoreArea" class="radar-score-area" points=""></polygon>
                                    <g id="radarScoreHandles"></g>
                                    <g id="radarScoreLabels"></g>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="radar-score-value-grid">
                            <div class="radar-score-value-pill">
                                <span>Richness</span>
                                <strong><span id="richnessValue"><%= formData.richness || '3' %></span> / 5</strong>
                            </div>

                            <div class="radar-score-value-pill">
                                <span>Sweetness</span>
                                <strong><span id="sweetnessValue"><%= formData.sweetness || '3' %></span> / 5</strong>
                            </div>

                            <div class="radar-score-value-pill">
                                <span>Aftertaste</span>
                                <strong><span id="aftertasteValue"><%= formData.aftertaste || '3' %></span> / 5</strong>
                            </div>

                            <div class="radar-score-value-pill">
                                <span>Aroma</span>
                                <strong><span id="aromaValue"><%= formData.aroma || '3' %></span> / 5</strong>
                            </div>

                            <div class="radar-score-value-pill">
                                <span>Acidity</span>
                                <strong><span id="acidityValue"><%= formData.acidity || '3' %></span> / 5</strong>
                            </div>
                        </div>

                        <div class="form-text mt-3">
                            Tip: tap near an axis to set that score. Drag a blue point to fine-tune it.
                        </div>
                    </div>
                </div>
        </div>
    </div>

    </div>

    <div class="d-flex gap-2 brew-form-actions">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save me-1"></i>
            <%= submitButtonText %>
        </button>

        <a href="/brew-sessions" class="btn btn-outline-secondary">
            Cancel
        </a>
    </div>
</form>

