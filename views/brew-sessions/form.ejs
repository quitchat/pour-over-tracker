        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="recipeResultModalLabel">
                    <i class="bi bi-stars me-1"></i>
                    Suggested Brewing Recipe
                </h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div id="recipeResultMessage"></div>

                <div id="recipeResultSection">
                    <div class="card mb-3">
                        <div class="card-header">
                            <i class="bi bi-cup-hot me-1"></i>
                            Recipe
                        </div>

                        <div class="card-body">
                            <h5 id="recipeName">Suggested Brewing Recipe</h5>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="text-muted small">Grind Size</div>
                                    <div class="fw-semibold" id="recipeGrindSize">-</div>
                                </div>

                                <div class="col-md-4">
