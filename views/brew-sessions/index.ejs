<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-journal-text me-2"></i>
            Brew Sessions
        </h1>
        <p class="text-muted mb-0">
            Track pour-over recipes, brew variables, ratings, and notes.
        </p>
    </div>

    <a href="/brew-sessions/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Add Brew Session
    </a>
</div>

<div class="card mb-3">
    <div class="card-header">
        <i class="bi bi-funnel me-1"></i>
        Filters
    </div>

    <div class="card-body">
        <form method="get" action="/brew-sessions">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="coffeeBeanId" class="form-label">Coffee Bean</label>
                    <select class="form-select" id="coffeeBeanId" name="coffeeBeanId">
                        <option value="">All beans</option>
                        <% coffeeBeans.forEach(function (bean) { %>
                            <option value="<%= bean.id %>" <%= String(filters.coffeeBeanId || "") === String(bean.id) ? "selected" : "" %>>
                                <%= bean.beanName %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="grinderId" class="form-label">Grinder</label>
                    <select class="form-select" id="grinderId" name="grinderId">
                        <option value="">All grinders</option>
                        <% grinders.forEach(function (grinder) { %>
                            <option value="<%= grinder.id %>" <%= String(filters.grinderId || "") === String(grinder.id) ? "selected" : "" %>>
                                <%= grinder.name %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="brewerId" class="form-label">Brewer</label>
                    <select class="form-select" id="brewerId" name="brewerId">
                        <option value="">All brewers</option>
                        <% brewers.forEach(function (brewer) { %>
                            <option value="<%= brewer.id %>" <%= String(filters.brewerId || "") === String(brewer.id) ? "selected" : "" %>>
                                <%= brewer.name %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="minRating" class="form-label">Minimum Rating</label>
                    <select class="form-select" id="minRating" name="minRating">
                        <option value="">Any rating</option>
                        <option value="3" <%= filters.minRating === "3" ? "selected" : "" %>>3+</option>
                        <option value="3.5" <%= filters.minRating === "3.5" ? "selected" : "" %>>3.5+</option>
                        <option value="4" <%= filters.minRating === "4" ? "selected" : "" %>>4+</option>
                        <option value="4.5" <%= filters.minRating === "4.5" ? "selected" : "" %>>4.5+</option>
                        <option value="5" <%= filters.minRating === "5" ? "selected" : "" %>>5</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="wouldRepeat" class="form-label">Would Repeat</label>
                    <select class="form-select" id="wouldRepeat" name="wouldRepeat">
                        <option value="">All</option>
                        <option value="yes" <%= filters.wouldRepeat === "yes" ? "selected" : "" %>>Yes</option>
                        <option value="no" <%= filters.wouldRepeat === "no" ? "selected" : "" %>>No</option>
                    </select>
                </div>

                <div class="col-md-9">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>
                            Apply Filters
                        </button>

                        <a href="/brew-sessions" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>
                            Clear
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-list-ul me-1"></i>
            Brew Session List
        </span>
        <span class="text-muted small"><%= brewSessions.length %> result(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Brew Date</th>
                    <th>Bean</th>
                    <th>Grinder</th>
                    <th>Brewer</th>
                    <th>Grind</th>
                    <th>Dose</th>
                    <th>Total Yield</th>
                    <th>Ratio</th>
                    <th>Temp</th>
                    <th>Time</th>
                    <th>Rating</th>
                    <th>Repeat?</th>
                    <th style="width: 320px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (brewSessions.length === 0) { %>
                    <tr>
                        <td colspan="13" class="text-muted text-center py-4">
                            No brew sessions found.
                        </td>
                    </tr>
                <% } %>

                <% brewSessions.forEach(function (session) { %>
                    <tr>
                        <td><%= session.brewDate %></td>
                        <td><%= session.beanName %></td>
                        <td><%= session.grinderName %></td>
                        <td><%= session.brewerName %></td>
                        <td><%= session.grindSize %></td>
                        <td><%= session.coffeeDoseGrams %></td>
                        <td><%= session.totalYieldGrams %></td>
                        <td>1:<%= session.brewRatio %></td>
                        <td><%= session.waterTemperatureC %></td>
                        <td><%= session.totalBrewTime %></td>
                        <td><%= session.overallRating || "-" %></td>
                        <td>
                            <% if (session.wouldRepeat) { %>
                                <i class="bi bi-check-circle me-1"></i>
                                Yes
                            <% } else { %>
                                <i class="bi bi-x-circle me-1"></i>
                                No
                            <% } %>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/brew-sessions/<%= session.id %>" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>
                                    View
                                </a>

                                <a href="/brew-sessions/<%= session.id %>/edit" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square me-1"></i>
                                    Edit
                                </a>

                                <a href="/brew-sessions/<%= session.id %>/duplicate" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-copy me-1"></i>
                                    Duplicate
                                </a>

                                <form
                                    method="post"
                                    action="/brew-sessions/<%= session.id %>/delete"
                                    onsubmit="return confirm('Delete this brew session?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash me-1"></i>
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>