<%
    const sessions = typeof brewSessions !== "undefined" ? brewSessions : [];
    const coffeeBeanOptions = typeof coffeeBeans !== "undefined" ? coffeeBeans : [];
    const grinderOptions = typeof grinders !== "undefined" ? grinders : [];
    const brewerOptions = typeof brewers !== "undefined" ? brewers : [];
    const filterValues = typeof filters !== "undefined" ? filters : {};
    const pageInfo = typeof pagination !== "undefined" ? pagination : { currentPage: 1, totalPages: 1, totalItems: sessions.length, hasPreviousPage: false, hasNextPage: false, previousPageHref: "#", nextPageHref: "#", pageLinks: [] };

    function getSessionBeanName(session) {
        return session.coffeeBeanName || session.beanName || "";
    }

    function getRatioText(session) {
        const dose = session.coffeeDoseGrams || "";
        const totalYield = session.totalYieldGrams || "";

        if (!dose && !totalYield) {
            return "-";
        }

        return `${dose || "-"} → ${totalYield || "-"}`;
    }
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-journal-text me-2"></i>
            Brew Sessions
        </h1>
        <p class="text-muted mb-0">
            Track pour-over recipes, brew variables, ratings, and notes.
        </p>
    </div>

    <a href="/brew-sessions/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Add Brew Session
    </a>
</div>

<style>
    .brew-session-table td {
        vertical-align: middle;
    }

    .brew-session-bean {
        font-weight: 600;
    }

    .brew-session-muted {
        color: var(--bs-secondary-color);
        font-size: 0.875rem;
    }

    .brew-ratio {
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }

    .brew-actions-cell {
        width: 320px;
        white-space: nowrap;
    }

    .brew-session-clickable-row {
        cursor: pointer;
    }

    .brew-session-clickable-row:focus {
        outline: 2px solid var(--bs-primary);
        outline-offset: -2px;
    }

    .brew-mobile-label {
        display: none;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.15rem;
    }

    @media (max-width: 991.98px) {
        .brew-session-table thead {
            display: none;
        }

        .brew-session-table,
        .brew-session-table tbody,
        .brew-session-table tr,
        .brew-session-table td {
            display: block;
            width: 100%;
        }

        .brew-session-table tr {
            border-bottom: 1px solid var(--bs-border-color);
            padding: 0.75rem 0;
        }

        .brew-session-table td {
            border: 0;
            padding: 0.35rem 1rem;
        }

        .brew-mobile-label {
            display: block;
        }

        .brew-actions-cell {
            width: 100%;
            white-space: normal;
        }
    }
</style>

<div class="card mb-3">
    <div class="card-header">
        <i class="bi bi-funnel me-1"></i>
        Filters
    </div>

    <div class="card-body">
        <form method="get" action="/brew-sessions">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="coffeeBeanId" class="form-label">Coffee Bean</label>
                    <select class="form-select" id="coffeeBeanId" name="coffeeBeanId">
                        <option value="">All beans</option>

                        <% coffeeBeanOptions.forEach(function (bean) { %>
                            <option value="<%= bean.id %>" <%= String(filterValues.coffeeBeanId || "") === String(bean.id) ? "selected" : "" %>>
                                <%= bean.beanName %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="grinderId" class="form-label">Grinder</label>
                    <select class="form-select" id="grinderId" name="grinderId">
                        <option value="">All grinders</option>

                        <% grinderOptions.forEach(function (grinder) { %>
                            <option value="<%= grinder.id %>" <%= String(filterValues.grinderId || "") === String(grinder.id) ? "selected" : "" %>>
                                <%= grinder.name %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="brewerId" class="form-label">Brewer</label>
                    <select class="form-select" id="brewerId" name="brewerId">
                        <option value="">All brewers</option>

                        <% brewerOptions.forEach(function (brewer) { %>
                            <option value="<%= brewer.id %>" <%= String(filterValues.brewerId || "") === String(brewer.id) ? "selected" : "" %>>
                                <%= brewer.name %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="minRating" class="form-label">Minimum Rating</label>
                    <select class="form-select" id="minRating" name="minRating">
                        <option value="">Any rating</option>
                        <option value="3" <%= filterValues.minRating === "3" ? "selected" : "" %>>3+</option>
                        <option value="3.5" <%= filterValues.minRating === "3.5" ? "selected" : "" %>>3.5+</option>
                        <option value="4" <%= filterValues.minRating === "4" ? "selected" : "" %>>4+</option>
                        <option value="4.5" <%= filterValues.minRating === "4.5" ? "selected" : "" %>>4.5+</option>
                        <option value="5" <%= filterValues.minRating === "5" ? "selected" : "" %>>5</option>
                    </select>
                </div>

                <div class="col-12">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>
                            Apply Filters
                        </button>

                        <a href="/brew-sessions" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>
                            Clear
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-list-ul me-1"></i>
            Brew Session List
        </span>

        <span class="text-muted small"><%= pageInfo.totalItems %> result(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle brew-session-table">
            <thead>
                <tr>
                    <th>Brew Date</th>
                    <th>Bean</th>
                    <th>Grinder</th>
                    <th>Brewer</th>
                    <th>Grind</th>
                    <th>Ratio</th>
                    <th>Temp</th>
                    <th>Time</th>
                    <th>Rating</th>
                    <th class="brew-actions-cell">Actions</th>
                </tr>
            </thead>

            <tbody>
                <% if (sessions.length === 0) { %>
                    <tr>
                        <td colspan="10" class="text-muted text-center py-4">
                            No brew sessions found.
                        </td>
                    </tr>
                <% } %>

                <% sessions.forEach(function (session) { %>
                    <tr
                        class="brew-session-clickable-row"
                        data-href="/brew-sessions/<%= session.id %>"
                        tabindex="0"
                        role="link"
                        aria-label="View brew session details for <%= getSessionBeanName(session) %> on <%= session.brewDate %>">
                        <td>
                            <div class="brew-mobile-label">Brew Date</div>
                            <%= session.brewDate %>
                        </td>

                        <td>
                            <div class="brew-mobile-label">Bean</div>
                            <div class="brew-session-bean">
                                <%= getSessionBeanName(session) %>
                            </div>
                        </td>

                        <td>
                            <div class="brew-mobile-label">Grinder</div>
                            <%= session.grinderName || "-" %>
                        </td>

                        <td>
                            <div class="brew-mobile-label">Brewer</div>
                            <%= session.brewerName || "-" %>
                        </td>

                        <td>
                            <div class="brew-mobile-label">Grind</div>
                            <%= session.grindSize || "-" %>
                        </td>

                        <td>
                            <div class="brew-mobile-label">Ratio</div>
                            <span class="brew-ratio"><%= getRatioText(session) %></span>
                        </td>

                        <td>
                            <div class="brew-mobile-label">Temp</div>
                            <%= session.waterTemperatureC || "-" %>
                        </td>

                        <td>
                            <div class="brew-mobile-label">Time</div>
                            <%= session.totalBrewTime || "-" %>
                        </td>

                        <td>
                            <div class="brew-mobile-label">Rating</div>

                            <% if (session.overallRating) { %>
                                <span class="badge text-bg-warning">
                                    <%= session.overallRating %> / 5
                                </span>
                            <% } else { %>
                                <span class="text-muted">-</span>
                            <% } %>
                        </td>

                        <td class="brew-actions-cell">
                            <div class="brew-mobile-label">Actions</div>

                            <div class="d-flex gap-2 flex-wrap">
                                <a href="/brew-sessions/<%= session.id %>/edit" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square me-1"></i>
                                    Edit
                                </a>

                                <a href="/brew-sessions/<%= session.id %>/duplicate" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-copy me-1"></i>
                                    Duplicate
                                </a>

                                <form
                                    method="post"
                                    action="/brew-sessions/<%= session.id %>/delete"
                                    onsubmit="return confirm('Delete this brew session?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash me-1"></i>
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<% if (pageInfo.totalPages > 1) { %>
    <nav class="mt-3" aria-label="Brew session pagination">
        <ul class="pagination justify-content-center mb-0 flex-wrap">
            <li class="page-item <%= pageInfo.hasPreviousPage ? "" : "disabled" %>">
                <a class="page-link" href="<%= pageInfo.previousPageHref %>">Previous</a>
            </li>

            <% pageInfo.pageLinks.forEach(function (pageLink) { %>
                <li class="page-item <%= pageLink.pageNumber === pageInfo.currentPage ? "active" : "" %>">
                    <a class="page-link" href="<%= pageLink.href %>"><%= pageLink.pageNumber %></a>
                </li>
            <% }); %>

            <li class="page-item <%= pageInfo.hasNextPage ? "" : "disabled" %>">
                <a class="page-link" href="<%= pageInfo.nextPageHref %>">Next</a>
            </li>
        </ul>
    </nav>
<% } %>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".brew-session-clickable-row[data-href]").forEach(function (row) {
            row.addEventListener("click", function (event) {
                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                window.location.href = row.getAttribute("data-href");
            });

            row.addEventListener("keydown", function (event) {
                if (event.key !== "Enter" && event.key !== " ") {
                    return;
                }

                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                event.preventDefault();
                window.location.href = row.getAttribute("data-href");
            });
        });
    });
</script>
