<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-journal-text me-2"></i>
            Brew Session Detail
        </h1>
        <p class="text-muted mb-0">
            <%= brewSession.coffeeBeanName %> brewed on <%= brewSession.brewDate %>
        </p>
    </div>

    <div class="d-flex gap-2">
        <a href="/brew-sessions/<%= brewSession.id %>/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil-square me-1"></i>
            Edit
        </a>

        <form method="post" action="/brew-sessions/<%= brewSession.id %>/duplicate">
            <button type="submit" class="btn btn-outline-success">
                <i class="bi bi-copy me-1"></i>
                Duplicate
            </button>
        </form>

        <form method="post" action="/brew-sessions/<%= brewSession.id %>/delete">
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>
                Delete
            </button>
        </form>

        <a href="/brew-sessions" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Back to List
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-cup-hot me-1"></i>
                Brew Information
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Coffee Bean</dt>
                    <dd class="col-sm-8">
                        <a href="/coffee-beans/<%= brewSession.coffeeBeanId %>">
                            <%= brewSession.coffeeBeanName %>
                        </a>
                    </dd>

                    <dt class="col-sm-4">Brew Date</dt>
                    <dd class="col-sm-8"><%= brewSession.brewDate %></dd>

                    <dt class="col-sm-4">Grinder</dt>
                    <dd class="col-sm-8"><%= brewSession.grinderName || "-" %></dd>

                    <dt class="col-sm-4">Brewer</dt>
                    <dd class="col-sm-8"><%= brewSession.brewerName || "-" %></dd>

                    <dt class="col-sm-4">Grind Size</dt>
                    <dd class="col-sm-8"><%= brewSession.grindSize || "-" %></dd>

                    <dt class="col-sm-4">Coffee Dose</dt>
                    <dd class="col-sm-8"><%= brewSession.coffeeDoseGrams %></dd>

                    <dt class="col-sm-4">Total Yield</dt>
                    <dd class="col-sm-8"><%= brewSession.totalYieldGrams || "-" %></dd>

                    <dt class="col-sm-4">Ratio</dt>
                    <dd class="col-sm-8">
                        <% if (brewSession.brewRatio) { %>
                            1:<%= brewSession.brewRatio %>
                        <% } else { %>
                            -
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Water Temp °C</dt>
                    <dd class="col-sm-8"><%= brewSession.waterTemperatureC || "-" %></dd>

                    <dt class="col-sm-4">Total Brew Time</dt>
                    <dd class="col-sm-8"><%= brewSession.totalBrewTime || "-" %></dd>

                    <dt class="col-sm-4">Overall Rating</dt>
                    <dd class="col-sm-8">
                        <% if (brewSession.overallRating) { %>
                            <%= brewSession.overallRating %> / 5
                        <% } else { %>
                            -
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Would Repeat</dt>
                    <dd class="col-sm-8">
                        <% if (brewSession.wouldRepeat) { %>
                            <i class="bi bi-check-circle me-1"></i>
                            Yes
                        <% } else { %>
                            <i class="bi bi-x-circle me-1"></i>
                            No
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8">
                        <% if (brewSession.notes) { %>
                            <%= brewSession.notes %>
                        <% } else { %>
                            <span class="text-muted">No notes entered.</span>
                        <% } %>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-radar me-1"></i>
                Bean Characteristics
            </div>

            <div class="card-body">
                <canvas id="tastingScoreChart" height="280"></canvas>

                <div class="table-responsive mt-3">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <th>Richness</th>
                                <td class="text-end"><%= brewSession.tastingScore.richness %> / 5</td>
                            </tr>
                            <tr>
                                <th>Sweetness</th>
                                <td class="text-end"><%= brewSession.tastingScore.sweetness %> / 5</td>
                            </tr>
                            <tr>
                                <th>Aftertaste</th>
                                <td class="text-end"><%= brewSession.tastingScore.aftertaste %> / 5</td>
                            </tr>
                            <tr>
                                <th>Aroma</th>
                                <td class="text-end"><%= brewSession.tastingScore.aroma %> / 5</td>
                            </tr>
                            <tr>
                                <th>Acidity</th>
                                <td class="text-end"><%= brewSession.tastingScore.acidity %> / 5</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const chartElement = document.getElementById("tastingScoreChart");

        if (!chartElement) {
            return;
        }

        const chartData = {
            labels: [
                "Richness",
                "Sweetness",
                "Aftertaste",
                "Aroma",
                "Acidity"
            ],
            datasets: [
                {
                    label: "Bean Characteristics",
                    data: [
                        <%= brewSession.tastingScore.richness %>,
                        <%= brewSession.tastingScore.sweetness %>,
                        <%= brewSession.tastingScore.aftertaste %>,
                        <%= brewSession.tastingScore.aroma %>,
                        <%= brewSession.tastingScore.acidity %>
                    ],
                    fill: true
                }
            ]
        };

        new Chart(chartElement, {
            type: "radar",
            data: chartData,
            options: {
                responsive: true,
                scales: {
                    r: {
                        min: 0,
                        max: 5,
                        ticks: {
                            stepSize: 1
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    });
</script>