<%
    const session = typeof brewSession !== "undefined" ? brewSession : null;
    const tastingScore = session && session.tastingScore ? session.tastingScore : {
        richness: 3,
        sweetness: 3,
        aftertaste: 3,
        aroma: 3,
        acidity: 3
    };
    const previousBrew = typeof previousBrewSession !== "undefined" ? previousBrewSession : null;
    const nextBrew = typeof nextBrewSession !== "undefined" ? nextBrewSession : null;

    function formatDisplayValue(value) {
        if (value === null || typeof value === "undefined" || value === "") {
            return "-";
        }

        return value;
    }



    function getBrewSummaryText(session) {
        const dose = session.coffeeDoseGrams ? `${session.coffeeDoseGrams}g` : "-";
        const totalYield = session.totalYieldGrams ? `${session.totalYieldGrams}g` : "-";
        const waterTemperature = session.waterTemperatureC ? ` @ ${session.waterTemperatureC}${session.waterTemperatureUnit || "°C"}` : "";
        const totalBrewTime = session.totalBrewTime ? ` over ${session.totalBrewTime}` : "";

        if (dose === "-" && totalYield === "-" && !waterTemperature && !totalBrewTime) {
            return "-";
        }

        return `${dose} → ${totalYield}${waterTemperature}${totalBrewTime}`;
    }

    function getBrewSummarySubtext(session) {
        if (!session.brewRatio) {
            return "";
        }

        return `Ratio 1:${session.brewRatio}`;
    }

    function buildRatingStars(value) {
        if (value === null || typeof value === "undefined" || value === "") {
            return "<span class=\"text-muted\">Not rated</span>";
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return "<span class=\"text-muted\">Not rated</span>";
        }

        const clampedValue = Math.max(0, Math.min(5, numericValue));
        const displayValue = Number.isInteger(clampedValue) ? clampedValue.toFixed(0) : clampedValue.toFixed(1);
        let html = "<span class=\"readonly-rating-display\" style=\"white-space: nowrap;\"><span class=\"readonly-rating-stars\" style=\"white-space: nowrap;\" aria-label=\"" + displayValue + " out of 5 stars\">";

        for (let index = 1; index <= 5; index++) {
            if (clampedValue >= index) {
                html += "<i class=\"bi bi-star-fill\" style=\"color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;\"></i>";
            } else if (clampedValue >= index - 0.5) {
                html += "<i class=\"bi bi-star-half\" style=\"color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;\"></i>";
            } else {
                html += "<i class=\"bi bi-star\" style=\"color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;\"></i>";
            }
        }

        html += "</span></span>";
        return html;
    }
%>

<% if (!session) { %>
    <div class="alert alert-danger">
        Brew session was not found.
    </div>
<% } else { %>
    <div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-journal-check me-2"></i>
                Brew Session Detail
            </h1>
            <p class="text-muted mb-0">
                <%= session.coffeeBeanName %> · <%= session.brewDate %>
            </p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <% if (previousBrew) { %>
                <a href="/brew-sessions/<%= previousBrew.id %>" class="btn btn-outline-secondary" title="<%= previousBrew.coffeeBeanName %> · <%= previousBrew.brewDate %>">
                    <i class="bi bi-arrow-left me-1"></i>
                    Previous Brew
                </a>
            <% } else { %>
                <button type="button" class="btn btn-outline-secondary" disabled>
                    <i class="bi bi-arrow-left me-1"></i>
                    Previous Brew
                </button>
            <% } %>

            <% if (nextBrew) { %>
                <a href="/brew-sessions/<%= nextBrew.id %>" class="btn btn-outline-secondary" title="<%= nextBrew.coffeeBeanName %> · <%= nextBrew.brewDate %>">
                    Next Brew
                    <i class="bi bi-arrow-right ms-1"></i>
                </a>
            <% } else { %>
                <button type="button" class="btn btn-outline-secondary" disabled>
                    Next Brew
                    <i class="bi bi-arrow-right ms-1"></i>
                </button>
            <% } %>

            <% if (!session.hasRating) { %>
                <a href="/brew-sessions/<%= session.id %>/rate" class="btn btn-success">
                    <i class="bi bi-star me-1"></i>
                    Rate Brew
                </a>
            <% } %>

            <a href="/brew-sessions/<%= session.id %>/edit" class="btn btn-outline-primary">
                <i class="bi bi-pencil-square me-1"></i>
                Edit
            </a>

            <a href="/brew-sessions/<%= session.id %>/duplicate" class="btn btn-outline-success">
                <i class="bi bi-files me-1"></i>
                Duplicate
            </a>

            <a href="/brew-sessions" class="btn btn-outline-secondary">
                <i class="bi bi-list-ul me-1"></i>
                Back to Brews
            </a>
        </div>
    </div>

    <div class="d-md-none alert alert-light border small py-2 mb-3">
        <span class="me-1" aria-hidden="true">👆</span> Swipe left or right to move between brew sessions.
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-card-checklist me-1"></i>
                    Brew Details
                </div>

                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Coffee Bean</dt>
                        <dd class="col-sm-8">
                            <a href="/coffee-beans/<%= session.coffeeBeanId %>">
                                <%= session.coffeeBeanName %>
                            </a>
                        </dd>

                        <dt class="col-sm-4">Brew Date</dt>
                        <dd class="col-sm-8"><%= formatDisplayValue(session.brewDate) %></dd>

                        <dt class="col-sm-4">Grinder</dt>
                        <dd class="col-sm-8"><%= formatDisplayValue(session.grinderName) %></dd>

                        <dt class="col-sm-4">Grind Size</dt>
                        <dd class="col-sm-8"><%= formatDisplayValue(session.grindSize) %></dd>

                        <dt class="col-sm-4">Brewer</dt>
                        <dd class="col-sm-8"><%= formatDisplayValue(session.brewerName) %></dd>

                        <dt class="col-sm-4">Brew</dt>
                        <dd class="col-sm-8">
                            <div class="fw-semibold"><%= getBrewSummaryText(session) %></div>
                            <% if (getBrewSummarySubtext(session)) { %>
                                <div class="text-muted small"><%= getBrewSummarySubtext(session) %></div>
                            <% } %>
                        </dd>

                        <dt class="col-sm-4">Overall Rating</dt>
                        <dd class="col-sm-8"><%- buildRatingStars(session.overallRating) %></dd>

                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-activity me-1"></i>
                    Brew Characteristics Radar
                </div>

                <div class="card-body">
                    <canvas id="brewCharacteristicsRadarChart" height="260"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-12">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-journal-text me-1"></i>
                    Brew Notes
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <h3 class="h6">Pour Structure</h3>
                        <% if (session.pourStructure) { %>
                            <div style="white-space: pre-wrap;"><%= session.pourStructure %></div>
                        <% } else { %>
                            <span class="text-muted">No pour structure entered.</span>
                        <% } %>
                    </div>

                    <div class="mb-3">
                        <h3 class="h6">Recipe Steps</h3>
                        <% if (session.recipeSteps) { %>
                            <div style="white-space: pre-wrap;"><%= session.recipeSteps %></div>
                        <% } else { %>
                            <span class="text-muted">No recipe steps entered.</span>
                        <% } %>
                    </div>

                    <div class="mb-3">
                        <h3 class="h6">Adjustment Notes</h3>
                        <% if (session.adjustmentNotes) { %>
                            <div style="white-space: pre-wrap;"><%= session.adjustmentNotes %></div>
                        <% } else { %>
                            <span class="text-muted">No adjustment notes entered.</span>
                        <% } %>
                    </div>

                    <div>
                        <h3 class="h6">Brew Comments</h3>
                        <% if (session.brewComments) { %>
                            <div style="white-space: pre-wrap;"><%= session.brewComments %></div>
                        <% } else { %>
                            <span class="text-muted">No brew comments entered.</span>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <form method="post" action="/brew-sessions/<%= session.id %>/delete" class="m-0" onsubmit="return confirm('Delete this brew session?');">
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>
                Delete Brew Session
            </button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const previousBrewUrl = <%- JSON.stringify(previousBrew ? "/brew-sessions/" + previousBrew.id : "") %>;
            const nextBrewUrl = <%- JSON.stringify(nextBrew ? "/brew-sessions/" + nextBrew.id : "") %>;
            let touchStartX = 0;
            let touchStartY = 0;
            let touchStartTarget = null;

            function isInteractiveSwipeTarget(target) {
                if (!target || !target.closest) {
                    return false;
                }

                return Boolean(target.closest("a, button, input, textarea, select, canvas, [data-no-swipe]"));
            }

            document.addEventListener("touchstart", function (event) {
                if (!event.touches || event.touches.length !== 1) {
                    return;
                }

                touchStartTarget = event.target;
                touchStartX = event.touches[0].clientX;
                touchStartY = event.touches[0].clientY;
            }, { passive: true });

            document.addEventListener("touchend", function (event) {
                if (!event.changedTouches || event.changedTouches.length !== 1) {
                    return;
                }

                if (isInteractiveSwipeTarget(touchStartTarget)) {
                    return;
                }

                const deltaX = event.changedTouches[0].clientX - touchStartX;
                const deltaY = event.changedTouches[0].clientY - touchStartY;
                const horizontalSwipeThreshold = 80;
                const verticalTolerance = 60;

                if (Math.abs(deltaX) < horizontalSwipeThreshold || Math.abs(deltaY) > verticalTolerance) {
                    return;
                }

                if (deltaX < 0 && nextBrewUrl) {
                    window.location.href = nextBrewUrl;
                    return;
                }

                if (deltaX > 0 && previousBrewUrl) {
                    window.location.href = previousBrewUrl;
                }
            }, { passive: true });

            const radarChartElement = document.getElementById("brewCharacteristicsRadarChart");

            if (!window.Chart || !radarChartElement) {
                return;
            }

            new Chart(radarChartElement, {
                type: "radar",
                data: {
                    labels: ["Richness", "Sweetness", "Aftertaste", "Aroma", "Acidity"],
                    datasets: [
                        {
                            label: "This Brew",
                            data: [
                                <%= tastingScore.richness %>,
                                <%= tastingScore.sweetness %>,
                                <%= tastingScore.aftertaste %>,
                                <%= tastingScore.aroma %>,
                                <%= tastingScore.acidity %>
                            ]
                        }
                    ]
                },
                options: {
                    responsive: true,
                    scales: {
                        r: {
                            beginAtZero: true,
                            min: 0,
                            max: 5,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    }
                }
            });
        });
    </script>
<% } %>
