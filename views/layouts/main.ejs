<%
    const pageTitle = typeof title !== "undefined" && title ? title : "Track Ya Brew";
    const currentPathValue = typeof currentPath !== "undefined" && currentPath ? currentPath : "";
    const currentUserValue = typeof currentUser !== "undefined" ? currentUser : null;
    const isSignedIn = !!currentUserValue;
    const isAdmin = !!currentUserValue && currentUserValue.role === "Admin";
    const displayName = currentUserValue && currentUserValue.displayName ? currentUserValue.displayName : "";
    const email = currentUserValue && currentUserValue.email ? currentUserValue.email : "";
    const userLabel = displayName || email || "Account";

    function isActivePath(path) {
        if (!currentPathValue) {
            return "";
        }

        if (path === "/") {
            return currentPathValue === "/" ? "active" : "";
        }

        return currentPathValue === path || currentPathValue.startsWith(path + "/") ? "active" : "";
    }

    function isAdminActive() {
        return currentPathValue.startsWith("/admin") ? "active" : "";
    }

    function isEquipmentActive() {
        return currentPathValue.startsWith("/grinders") || currentPathValue.startsWith("/brewers") ? "active" : "";
    }
%>

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title><%= pageTitle %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <link href="/css/styles.css" rel="stylesheet">

    <style>
        body {
            min-height: 100vh;
            background-color: #f8f9fa;
        }

        .app-navbar {
            border-bottom: 1px solid rgba(255, 255, 255, 0.15);
        }

        .app-navbar .nav-link {
            border-radius: 0.5rem;
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        .app-navbar .nav-link.active {
            background-color: rgba(255, 255, 255, 0.16);
            color: #ffffff;
            font-weight: 600;
        }

        .app-navbar .dropdown-item.active,
        .app-navbar .dropdown-item:active {
            background-color: #6f4e37;
            color: #ffffff;
        }

        .app-brand-icon {
            width: 2rem;
            height: 2rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background-color: rgba(255, 255, 255, 0.18);
        }

        .app-main {
            padding-top: 1.5rem;
            padding-bottom: 3rem;
        }

        .app-footer {
            color: #6c757d;
            font-size: 0.875rem;
            padding: 1.25rem 0;
            border-top: 1px solid #e9ecef;
            background-color: #ffffff;
        }

        .dropdown-menu {
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08);
        }

        @media (max-width: 991.98px) {
            .app-navbar .nav-link {
                margin-top: 0.15rem;
                margin-bottom: 0.15rem;
            }
        }
    </style>

    <% if (typeof head !== "undefined") { %>
        <%- head %>
    <% } %>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar" style="background-color: #6f4e37;">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <span class="app-brand-icon">
                    <i class="bi bi-cup-hot"></i>
                </span>
                <span>Track Ya Brew</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div id="mainNavbar" class="collapse navbar-collapse">
                <% if (isSignedIn) { %>
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link <%= isActivePath("/") %>" href="/">
                                <i class="bi bi-speedometer2 me-1"></i>
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link <%= isActivePath("/coffee-beans") %>" href="/coffee-beans">
                                <i class="bi bi-cup-hot me-1"></i>
                                Beans
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link <%= isActivePath("/brew-sessions") %>" href="/brew-sessions">
                                <i class="bi bi-journal-check me-1"></i>
                                Brews
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle <%= isEquipmentActive() %>" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-tools me-1"></i>
                                Equipment
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item <%= isActivePath("/grinders") %>" href="/grinders">
                                        <i class="bi bi-gear me-2"></i>
                                        Grinders
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item <%= isActivePath("/brewers") %>" href="/brewers">
                                        <i class="bi bi-filter-circle me-2"></i>
                                        Brewers
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link <%= isActivePath("/analytics") %>" href="/analytics">
                                <i class="bi bi-graph-up-arrow me-1"></i>
                                Analytics
                            </a>
                        </li>

                        <% if (isAdmin) { %>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle <%= isAdminActive() %>" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock me-1"></i>
                                    Admin
                                </a>

                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item <%= isActivePath("/admin/users") %>" href="/admin/users">
                                            <i class="bi bi-people me-2"></i>
                                            User Management
                                        </a>
                                    </li>

                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>

                                    <li>
                                        <a class="dropdown-item <%= isActivePath("/admin/ai") || isActivePath("/admin/ai-call-logs") || isActivePath("/admin/bean-detail-ai-prompt") || isActivePath("/admin/brew-suggestion-ai-prompt") %>" href="/admin/ai">
                                            <i class="bi bi-robot me-2"></i>
                                            AI Administration
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        <% } %>
                    </ul>

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle <%= isActivePath("/profile") %>" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>
                                <%= userLabel %>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="/profile">
                                        <i class="bi bi-person-gear me-2"></i>
                                        Profile
                                    </a>
                                </li>

                                <li>
                                    <hr class="dropdown-divider">
                                </li>

                                <li>
                                    <form method="post" action="/auth/sign-out" class="m-0">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>
                                            Sign Out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                <% } else { %>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link <%= isActivePath("/auth/sign-in") %>" href="/auth/sign-in">
                                <i class="bi bi-box-arrow-in-right me-1"></i>
                                Sign In
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link <%= isActivePath("/auth/register") %>" href="/auth/register">
                                <i class="bi bi-person-plus me-1"></i>
                                Register
                            </a>
                        </li>
                    </ul>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="app-main">
        <div class="container">
            <% if (typeof successMessage !== "undefined" && successMessage) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-1"></i>
                    <%= successMessage %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <%= errorMessage %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <%- body %>
        </div>
    </main>

    <footer class="app-footer">
        <div class="container d-flex justify-content-between align-items-center gap-2 flex-column flex-md-row">
            <div>
                Track Ya Brew
            </div>

            <div>
                <span class="me-2">
                    <i class="bi bi-cup-hot me-1"></i>
                    Track. Brew. Improve.
                </span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/disable-autocomplete.js"></script>

    <% if (typeof scripts !== "undefined") { %>
        <%- scripts %>
    <% } %>
</body>
</html>
