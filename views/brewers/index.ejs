<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Brewers</h1>
        <p class="text-muted mb-0">
            Track drippers and brewers such as V60, Kalita, Origami, April, Chemex, and Clever.
        </p>
    </div>

    <a href="/brewers/new" class="btn btn-primary">Add Brewer</a>
</div>

<div class="card">
    <div class="card-header">
        Brewer List
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Brand</th>
                    <th>Type</th>
                    <th>Location</th>
                    <th>Notes</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (brewers.length === 0) { %>
                    <tr>
                        <td colspan="6" class="text-muted text-center py-4">
                            No brewers yet. Click Add Brewer to create one.
                        </td>
                    </tr>
                <% } %>

                <% brewers.forEach(function (brewer) { %>
                    <tr>
                        <td><%= brewer.name %></td>
                        <td><%= brewer.brand %></td>
                        <td><%= brewer.brewerType %></td>
                        <td>
                            <% if (brewer.locationName || (brewer.latitude !== null && brewer.longitude !== null)) { %>
                                <div><%= brewer.locationName || "Saved location" %></div>
                                <% if (brewer.latitude !== null && brewer.longitude !== null) { %>
                                    <% const brewerMapUrl = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(brewer.latitude) + "," + String(brewer.longitude)); %>
                                    <div class="small text-muted">
                                        <a href="<%= brewerMapUrl %>" target="_blank" rel="noopener noreferrer">
                                            <i class="bi bi-geo-alt me-1"></i>
                                            <%= Number(brewer.latitude).toFixed(5) %>, <%= Number(brewer.longitude).toFixed(5) %>
                                        </a>
                                    </div>
                                <% } %>
                            <% } %>
                        </td>
                        <td><%= brewer.notes %></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/brewers/<%= brewer.id %>/edit" class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <form
                                    method="post"
                                    action="/brewers/<%= brewer.id %>/delete"
                                    onsubmit="return confirm('Delete this brewer?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>