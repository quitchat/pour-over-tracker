<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Brewers</h1>
        <p class="text-muted mb-0">
            Track drippers and brewers such as V60, Kalita, Origami, April, Chemex, and Clever.
        </p>
    </div>

    <a href="/brewers/new" class="btn btn-primary align-self-start align-self-sm-center">
        <i class="bi bi-plus-lg me-1"></i>
        Add Brewer
    </a>
</div>

<div class="card equipment-list-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Brewer List</span>
        <span class="badge text-bg-light"><%= brewers.length %></span>
    </div>

    <div class="table-responsive equipment-responsive-table-wrap">
        <table class="table table-striped table-hover mb-0 align-middle equipment-table equipment-responsive-table">
            <thead>
                <tr>
                    <th class="equipment-primary-col">Name</th>
                    <th>Brand</th>
                    <th class="d-none d-md-table-cell">Type</th>
                    <th class="text-end">Brews</th>
                    <th class="text-end">Total Bean Weight</th>
                    <th class="d-none d-lg-table-cell">Notes</th>
                    <th class="equipment-action-col">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (brewers.length === 0) { %>
                    <tr>
                        <td colspan="7" class="text-muted text-center py-4">
                            No brewers yet. Click Add Brewer to create one.
                        </td>
                    </tr>
                <% } %>

                <% brewers.forEach(function (brewer) { %>
                    <tr>
                        <td class="fw-semibold equipment-primary-col" data-label="Name">
                            <div>
                                <%= brewer.name %>
                                <% if (brewer.locationName || (brewer.latitude !== null && brewer.longitude !== null)) { %>
                                    <% const brewerMapUrl = brewer.latitude !== null && brewer.longitude !== null ? "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(brewer.latitude) + "," + String(brewer.longitude)) : ""; %>
                                    <span class="fw-normal equipment-location-inline">(<% if (brewerMapUrl) { %><a href="<%= brewerMapUrl %>" target="_blank" rel="noopener noreferrer"><i class="bi bi-geo-alt-fill me-1" aria-hidden="true"></i><%= brewer.locationName || "Open map" %></a><% } else { %><%= brewer.locationName %><% } %>)</span>
                                <% } %>
                            </div>
                            <% if (brewer.brewerType) { %>
                                <div class="small text-muted d-md-none"><%= brewer.brewerType %></div>
                            <% } %>
                        </td>
                        <td data-label="Brand"><%= brewer.brand || "" %></td>
                        <td class="d-none d-md-table-cell" data-label="Type"><%= brewer.brewerType || "" %></td>
                        <td class="text-end" data-label="Brews">
                            <span class="badge text-bg-secondary"><%= brewer.brewCount || 0 %></span>
                        </td>
                        <td class="text-end text-nowrap" data-label="Total Bean Weight">
                            <%= brewer.totalBeanGrams || "0.0" %> g
                        </td>
                        <td class="d-none d-lg-table-cell" data-label="Notes"><%= brewer.notes || "" %></td>
                        <td class="equipment-action-col" data-label="Actions">
                            <div class="equipment-action-buttons">
                                <a href="/brewers/<%= brewer.id %>/edit" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square d-inline d-sm-none"></i>
                                    <span class="d-none d-sm-inline">Edit</span>
                                </a>

                                <form
                                    method="post"
                                    action="/brewers/<%= brewer.id %>/delete"
                                    onsubmit="return confirm('Delete this brewer?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash d-inline d-sm-none"></i>
                                        <span class="d-none d-sm-inline">Delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
