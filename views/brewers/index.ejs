<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Brewers</h1>
        <p class="text-muted mb-0">
            Track drippers and brewers such as V60, Kalita, Origami, April, Chemex, and Clever.
        </p>
    </div>

    <a href="/brewers/new" class="btn btn-primary align-self-start align-self-sm-center">
        <i class="bi bi-plus-lg me-1"></i>
        Add Brewer
    </a>
</div>

<div class="card equipment-list-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Brewer List</span>
        <span class="badge text-bg-light"><%= brewers.length %></span>
    </div>

    <div class="table-responsive d-none d-lg-block">
        <table class="table table-striped table-hover mb-0 align-middle equipment-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Brand</th>
                    <th>Type</th>
                    <th class="text-end">Brews</th>
                    <th class="text-end">Total Bean Weight</th>
                    <th>Location</th>
                    <th>Notes</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (brewers.length === 0) { %>
                    <tr>
                        <td colspan="8" class="text-muted text-center py-4">
                            No brewers yet. Click Add Brewer to create one.
                        </td>
                    </tr>
                <% } %>

                <% brewers.forEach(function (brewer) { %>
                    <tr>
                        <td class="fw-semibold"><%= brewer.name %></td>
                        <td><%= brewer.brand || "" %></td>
                        <td><%= brewer.brewerType || "" %></td>
                        <td class="text-end">
                            <span class="badge text-bg-secondary"><%= brewer.brewCount || 0 %></span>
                        </td>
                        <td class="text-end">
                            <%= brewer.totalBeanGrams || "0.0" %> g
                        </td>
                        <td>
                            <% if (brewer.locationName || (brewer.latitude !== null && brewer.longitude !== null)) { %>
                                <div><%= brewer.locationName || "Saved location" %></div>
                                <% if (brewer.latitude !== null && brewer.longitude !== null) { %>
                                    <% const brewerMapUrl = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(brewer.latitude) + "," + String(brewer.longitude)); %>
                                    <div class="small text-muted">
                                        <a href="<%= brewerMapUrl %>" target="_blank" rel="noopener noreferrer">
                                            <i class="bi bi-geo-alt me-1"></i>
                                            <%= Number(brewer.latitude).toFixed(5) %>, <%= Number(brewer.longitude).toFixed(5) %>
                                        </a>
                                    </div>
                                <% } %>
                            <% } %>
                        </td>
                        <td><%= brewer.notes || "" %></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/brewers/<%= brewer.id %>/edit" class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <form
                                    method="post"
                                    action="/brewers/<%= brewer.id %>/delete"
                                    onsubmit="return confirm('Delete this brewer?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <div class="equipment-mobile-list d-lg-none">
        <% if (brewers.length === 0) { %>
            <div class="text-muted text-center py-4 px-3">
                No brewers yet. Click Add Brewer to create one.
            </div>
        <% } %>

        <% brewers.forEach(function (brewer) { %>
            <article class="equipment-mobile-card">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div class="min-w-0">
                        <h2 class="h6 mb-1 text-truncate"><%= brewer.name %></h2>
                        <div class="small text-muted">
                            <% const brewerSummary = [brewer.brand, brewer.brewerType].filter(Boolean).join(" · "); %>
                            <%= brewerSummary || "No brewer details" %>
                        </div>
                    </div>
                    <span class="badge text-bg-secondary flex-shrink-0"><%= brewer.brewCount || 0 %> brews</span>
                </div>

                <div class="equipment-mobile-metrics mt-3">
                    <div>
                        <div class="equipment-mobile-label">Total Bean Weight</div>
                        <div class="fw-semibold"><%= brewer.totalBeanGrams || "0.0" %> g</div>
                    </div>
                    <div>
                        <div class="equipment-mobile-label">Type</div>
                        <div class="fw-semibold"><%= brewer.brewerType || "—" %></div>
                    </div>
                </div>

                <% if (brewer.locationName || (brewer.latitude !== null && brewer.longitude !== null)) { %>
                    <div class="equipment-mobile-detail mt-3">
                        <div class="equipment-mobile-label">Location</div>
                        <div><%= brewer.locationName || "Saved location" %></div>
                        <% if (brewer.latitude !== null && brewer.longitude !== null) { %>
                            <% const brewerMobileMapUrl = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(brewer.latitude) + "," + String(brewer.longitude)); %>
                            <a class="small" href="<%= brewerMobileMapUrl %>" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-geo-alt me-1"></i>
                                <%= Number(brewer.latitude).toFixed(5) %>, <%= Number(brewer.longitude).toFixed(5) %>
                            </a>
                        <% } %>
                    </div>
                <% } %>

                <% if (brewer.notes) { %>
                    <div class="equipment-mobile-detail mt-3">
                        <div class="equipment-mobile-label">Notes</div>
                        <div><%= brewer.notes %></div>
                    </div>
                <% } %>

                <div class="equipment-mobile-actions mt-3">
                    <a href="/brewers/<%= brewer.id %>/edit" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil-square me-1"></i>
                        Edit
                    </a>

                    <form
                        method="post"
                        action="/brewers/<%= brewer.id %>/delete"
                        onsubmit="return confirm('Delete this brewer?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash me-1"></i>
                            Delete
                        </button>
                    </form>
                </div>
            </article>
        <% }); %>
    </div>
</div>
