<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1"><%= pageHeading %></h1>
        <p class="text-muted mb-0">Enter information about your brewer or dripper.</p>
    </div>

    <a href="/brewers" class="btn btn-outline-secondary">Back to List</a>
</div>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <strong>Please fix the following:</strong>
        <ul class="mb-0">
            <% errors.forEach(function (error) { %>
                <li><%= error %></li>
            <% }); %>
        </ul>
    </div>
<% } %>

<form method="post" action="<%= formAction %>">
    <div class="card mb-3">
        <div class="card-header">
            <span class="brewer-icon me-1" aria-hidden="true"></span>Brewer Information
        </div>

        <div class="card-body">
            <div class="mb-3">
                <label for="name" class="form-label">Brewer Name</label>
                <input
                    type="text"
                    class="form-control"
                    id="name"
                    name="name"
                    placeholder="Example: V60, Kalita Wave, Origami"
                    value="<%= formData.name || "" %>">
            </div>

            <div class="mb-3">
                <label for="brand" class="form-label">Brand</label>
                <input
                    type="text"
                    class="form-control"
                    id="brand"
                    placeholder="Example: Hario, Kalita, Origami"
                    name="brand"
                    value="<%= formData.brand || "" %>">
            </div>

            <div class="mb-3">
                <label for="brewerType" class="form-label">Brewer Type</label>
                <select class="form-select" id="brewerType" name="brewerType">
                    <option value="">Select type</option>
                    <option value="Cone" <%= formData.brewerType === "Cone" ? "selected" : "" %>>Cone</option>
                    <option value="Flat Bottom" <%= formData.brewerType === "Flat Bottom" ? "selected" : "" %>>Flat Bottom</option>
                    <option value="Hybrid" <%= formData.brewerType === "Hybrid" ? "selected" : "" %>>Hybrid</option>
                    <option value="Immersion" <%= formData.brewerType === "Immersion" ? "selected" : "" %>>Immersion</option>
                    <option value="Chemex Style" <%= formData.brewerType === "Chemex Style" ? "selected" : "" %>>Chemex Style</option>
                    <option value="Other" <%= formData.brewerType === "Other" ? "selected" : "" %>>Other</option>
                </select>
            </div>


            <div class="card bg-light border-0 mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-2 flex-column flex-md-row mb-3">
                        <div>
                            <h2 class="h6 mb-1">Equipment Location</h2>
                            <p class="text-muted small mb-0">Optional. Used to suggest this grinder when adding a brew near this location.</p>
                        </div>

                        <button type="button" class="btn btn-sm btn-outline-primary" data-fill-current-location>
                            <i class="bi bi-geo-alt me-1"></i>
                            Use Current Location
                        </button>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="locationName" class="form-label">Location Name</label>
                            <input
                                type="text"
                                class="form-control"
                                id="locationName"
                                name="locationName"
                                placeholder="Example: Home, Office, Travel Kit"
                                value="<%= formData.locationName || "" %>">
                        </div>

                        <div class="col-md-4">
                            <label for="latitude" class="form-label">Latitude</label>
                            <input
                                type="number"
                                step="any"
                                class="form-control"
                                id="latitude"
                                name="latitude"
                                value="<%= formData.latitude || "" %>">
                        </div>

                        <div class="col-md-4">
                            <label for="longitude" class="form-label">Longitude</label>
                            <input
                                type="number"
                                step="any"
                                class="form-control"
                                id="longitude"
                                name="longitude"
                                value="<%= formData.longitude || "" %>">
                        </div>
                    </div>

                    <div class="small text-muted mt-2" data-location-fill-message></div>

                    <% if (formData.latitude && formData.longitude) { %>
                        <% const equipmentMapUrl = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(formData.latitude) + "," + String(formData.longitude)); %>
                        <div class="small mt-2">
                            <a href="<%= equipmentMapUrl %>" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-geo-alt me-1"></i>
                                Open saved location in Google Maps
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="mb-3">
                <label for="notes" class="form-label">Notes</label>
                <textarea
                    class="form-control"
                    id="notes"
                    name="notes"
                    rows="4"
                    placeholder="Example: Works best with Cafec Abaca filter, medium-fine grind, slower drawdown."><%= formData.notes || "" %></textarea>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><%= submitButtonText %></button>
        <a href="/brewers" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

<script>
    (function () {
        const locationButton = document.querySelector("[data-fill-current-location]");
        const messageElement = document.querySelector("[data-location-fill-message]");

        if (!locationButton) {
            return;
        }

        locationButton.addEventListener("click", function () {
            if (!navigator.geolocation) {
                if (messageElement) {
                    messageElement.textContent = "Geolocation is not available in this browser.";
                }
                return;
            }

            locationButton.disabled = true;
            if (messageElement) {
                messageElement.textContent = "Getting current location...";
            }

            navigator.geolocation.getCurrentPosition(function (position) {
                const latitudeInput = document.getElementById("latitude");
                const longitudeInput = document.getElementById("longitude");

                if (latitudeInput) {
                    latitudeInput.value = position.coords.latitude.toFixed(6);
                }

                if (longitudeInput) {
                    longitudeInput.value = position.coords.longitude.toFixed(6);
                }

                if (messageElement) {
                    messageElement.textContent = "Location saved into the form. Add a location name like Home or Office if useful.";
                }

                locationButton.disabled = false;
            }, function () {
                if (messageElement) {
                    messageElement.textContent = "Could not read current location. You can enter latitude and longitude manually.";
                }

                locationButton.disabled = false;
            }, {
                enableHighAccuracy: true,
                timeout: 8000,
                maximumAge: 60000
            });
        });
    })();
</script>
