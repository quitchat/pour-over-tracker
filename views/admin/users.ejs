<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-people me-2"></i>
            User Management
        </h1>
        <p class="text-muted mb-0">
            Deactivate users without deleting their historical coffee logs.
        </p>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a href="/" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Dashboard
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <i class="bi bi-people me-1"></i>
        Users
    </div>

    <div class="table-responsive mobile-card-table-wrap">
        <table class="table table-striped table-hover mb-0 align-middle mobile-card-table user-management-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>AI</th>
                    <th>Coffee Beans</th>
                    <th>Grinders</th>
                    <th>Brewers</th>
                    <th>Brew Sessions</th>
                    <th>Created</th>
                    <th>Deactivated</th>
                    <th style="width: 260px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                <% if (users.length === 0) { %>
                    <tr>
                        <td colspan="11" class="text-center text-muted py-4">
                            No users found.
                        </td>
                    </tr>
                <% } %>

                <% users.forEach(function (user) { %>
                    <tr>
                        <td data-label="User">
                            <div class="fw-semibold"><%= user.displayName || "(No display name)" %></div>
                            <div class="text-muted small"><%= user.email %></div>

                            <% if (user.id === currentUserId) { %>
                                <span class="badge text-bg-info mt-1">You</span>
                            <% } %>
                        </td>

                        <td data-label="Role">
                            <% if (user.role === "Admin") { %>
                                <span class="badge text-bg-primary">Admin</span>
                            <% } else { %>
                                <span class="badge text-bg-secondary">User</span>
                            <% } %>
                        </td>

                        <td data-label="Status">
                            <% if (user.isActive) { %>
                                <span class="badge text-bg-success">Active</span>
                            <% } else { %>
                                <span class="badge text-bg-danger">Inactive</span>
                            <% } %>
                        </td>

                        <td data-label="AI">
                            <% if (user.allowAi) { %>
                                <span class="badge text-bg-success">Allowed</span>
                            <% } else { %>
                                <span class="badge text-bg-secondary">Off</span>
                            <% } %>
                        </td>

                        <td data-label="Coffee Beans"><%= user.coffeeBeanCount %></td>
                        <td data-label="Grinders"><%= user.grinderCount %></td>
                        <td data-label="Brewers"><%= user.brewerCount %></td>
                        <td data-label="Brew Sessions"><%= user.brewSessionCount %></td>
                        <td data-label="Created"><%= user.createdAt %></td>
                        <td data-label="Deactivated"><%= user.deactivatedAt || "-" %></td>

                        <td data-label="Actions">
                            <div class="d-flex gap-2 flex-wrap">
                                <% if (user.allowAi) { %>
                                    <form method="post" action="/admin/users/<%= user.id %>/disable-ai">
                                        <button type="submit" class="btn btn-sm btn-outline-warning">
                                            Disable AI
                                        </button>
                                    </form>
                                <% } else { %>
                                    <form method="post" action="/admin/users/<%= user.id %>/enable-ai">
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            Enable AI
                                        </button>
                                    </form>
                                <% } %>

                                <% if (user.role !== "Admin") { %>
                                    <form method="post" action="/admin/users/<%= user.id %>/make-admin">
                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            Make Admin
                                        </button>
                                    </form>
                                <% } %>

                                <% if (user.role === "Admin" && user.id !== currentUserId) { %>
                                    <form method="post" action="/admin/users/<%= user.id %>/make-user">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                                            Make User
                                        </button>
                                    </form>
                                <% } %>

                                <% if (user.isActive && user.id !== currentUserId) { %>
                                    <form method="post" action="/admin/users/<%= user.id %>/deactivate">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Deactivate
                                        </button>
                                    </form>
                                <% } %>

                                <% if (!user.isActive) { %>
                                    <form method="post" action="/admin/users/<%= user.id %>/activate">
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            Reactivate
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>