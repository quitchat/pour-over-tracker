<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-speedometer2 me-2"></i>
            AI Monthly Caps
        </h1>
        <p class="text-muted mb-0">
            Manage monthly AI call limits. Use Default Cap follows the admin default; No Cap is truly unlimited.
        </p>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a href="/admin/ai" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            AI Administration
        </a>
    </div>
</div>

<% if (message) { %>
    <div class="alert alert-success"><%= message %></div>
<% } %>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card mb-3">
    <div class="card-header">
        <i class="bi bi-sliders me-1"></i>
        Default Monthly AI Call Cap
    </div>
    <div class="card-body">
        <form method="post" action="/admin/ai-monthly-caps/default" class="ai-default-cap-form">
            <label for="defaultMonthlyCallCap" class="form-label">Default monthly call cap</label>
            <div class="d-flex flex-column flex-sm-row gap-2 align-items-stretch align-items-sm-center">
                <input type="number" class="form-control ai-default-cap-input" id="defaultMonthlyCallCap" name="defaultMonthlyCallCap" min="0" step="1" value="<%= defaultMonthlyCallCap %>" required>
                <button type="submit" class="btn btn-primary flex-shrink-0">
                    <i class="bi bi-save me-1"></i>
                    Save Default Cap
                </button>
            </div>
            <div class="form-text">Users set to Use Default Cap fall back to this value.</div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex flex-column flex-md-row justify-content-between gap-1">
        <span>
            <i class="bi bi-people me-1"></i>
            Per-User AI Access and Monthly Caps
        </span>
        <span class="small text-muted">Usage resets each calendar month. Current month from <%= currentMonthStart %>.</span>
    </div>

    <div class="table-responsive mobile-card-table-wrap">
        <table class="table table-striped table-hover mb-0 align-middle mobile-card-table admin-ai-cap-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>AI</th>
                    <th>Usage This Month</th>
                    <th style="min-width: 360px;">Monthly Cap</th>
                </tr>
            </thead>
            <tbody>
                <% if (users.length === 0) { %>
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No users found.</td>
                    </tr>
                <% } %>

                <% users.forEach(function (user) { %>
                    <tr>
                        <td data-label="User">
                            <div class="fw-semibold d-flex align-items-center gap-2 flex-wrap">
                                <span><%= user.displayName || "(No display name)" %></span>
                                <% if (!user.isActive) { %>
                                    <span class="badge text-bg-danger">Inactive</span>
                                <% } %>
                            </div>
                            <div class="text-muted small"><%= user.email %></div>
                        </td>
                        <td data-label="AI">
                            <div class="d-flex flex-column gap-2 align-items-start">
                                <% if (user.allowAi) { %>
                                    <span class="badge text-bg-success">AI enabled</span>
                                    <form method="post" action="/admin/users/<%= user.id %>/disable-ai">
                                        <input type="hidden" name="returnTo" value="/admin/ai-monthly-caps">
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Disable AI</button>
                                    </form>
                                <% } else { %>
                                    <span class="badge text-bg-secondary">AI off</span>
                                    <form method="post" action="/admin/users/<%= user.id %>/enable-ai">
                                        <input type="hidden" name="returnTo" value="/admin/ai-monthly-caps">
                                        <button type="submit" class="btn btn-sm btn-outline-success">Enable AI</button>
                                    </form>
                                <% } %>
                            </div>
                        </td>
                        <td data-label="Usage This Month">
                            <div class="fw-semibold <%= user.isAtOrOverCap ? 'text-danger' : '' %>"><%= user.usageLabel %></div>
                        </td>
                        <td data-label="Monthly Cap">
                            <form method="post" action="/admin/ai-monthly-caps/users/<%= user.id %>" class="ai-cap-form">
                                <div class="row g-2 align-items-end">
                                    <div class="col-12 col-md-5">
                                        <label class="form-label small mb-1" for="capMode-<%= user.id %>">Cap mode</label>
                                        <select class="form-select form-select-sm" id="capMode-<%= user.id %>" name="capMode">
                                            <option value="USE_DEFAULT" <%= user.capMode === 'USE_DEFAULT' ? 'selected' : '' %>>Use Default Cap</option>
                                            <option value="CUSTOM" <%= user.capMode === 'CUSTOM' ? 'selected' : '' %>>Custom Cap</option>
                                            <option value="NO_CAP" <%= user.capMode === 'NO_CAP' ? 'selected' : '' %>>No Cap</option>
                                        </select>
                                    </div>
                                    <div class="col-7 col-md-4 ai-custom-cap-wrap <%= user.capMode === 'CUSTOM' ? '' : 'd-none' %>">
                                        <label class="form-label small mb-1" for="customMonthlyCallCap-<%= user.id %>">AI Call Cap / Month</label>
                                        <input type="number" class="form-control form-control-sm ai-custom-cap-input" id="customMonthlyCallCap-<%= user.id %>" name="customMonthlyCallCap" min="0" step="1" value="<%= user.customMonthlyCallCap %>" placeholder="Default <%= defaultMonthlyCallCap %>" <%= user.capMode === 'CUSTOM' ? '' : 'disabled' %>>
                                    </div>
                                    <div class="col-5 col-md-3">
                                        <button type="submit" class="btn btn-sm btn-primary w-100">Save</button>
                                    </div>
                                </div>
                                <div class="form-text">
                                    Current: <%= user.capModeLabel %><% if (user.capMode === 'USE_DEFAULT') { %> (<%= user.capLabel %>)<% } %>
                                </div>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<style>
    .admin-ai-cap-table .btn,
    .admin-ai-cap-table .form-select,
    .admin-ai-cap-table .form-control {
        vertical-align: middle;
    }

    .ai-default-cap-input {
        max-width: 14rem;
    }

    @media (max-width: 575.98px) {
        .ai-default-cap-input {
            max-width: none;
        }
    }

    .ai-default-cap-input {
        max-width: 14rem;
    }

    @media (max-width: 575.98px) {
        .ai-default-cap-input {
            max-width: none;
        }
    }

    @media (max-width: 767.98px) {
        .ai-cap-form .row > [class*="col-"] {
            margin-bottom: 0.25rem;
        }
    }
</style>

<script>
    (function () {
        function updateCustomCapField(form) {
            const modeSelect = form.querySelector('select[name="capMode"]');
            const customCapWrap = form.querySelector('.ai-custom-cap-wrap');
            const customCapInput = form.querySelector('.ai-custom-cap-input');

            if (!modeSelect || !customCapWrap || !customCapInput) {
                return;
            }

            const isCustom = modeSelect.value === 'CUSTOM';
            customCapWrap.classList.toggle('d-none', !isCustom);
            customCapInput.disabled = !isCustom;

            if (!isCustom) {
                customCapInput.value = '';
            }
        }

        document.querySelectorAll('.ai-cap-form').forEach(function (form) {
            updateCustomCapField(form);

            const modeSelect = form.querySelector('select[name="capMode"]');
            if (modeSelect) {
                modeSelect.addEventListener('change', function () {
                    updateCustomCapField(form);
                });
            }
        });
    })();
</script>

