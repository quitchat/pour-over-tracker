<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="h3 mb-1">AI Cost Settings</h1>
        <p class="text-muted mb-0">
            Override estimated base costs used by AI call logging. Changes affect future log entries only.
        </p>
    </div>

    <a href="/admin/ai" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>
        AI Administration
    </a>
</div>

<% if (message) { %>
    <div class="alert alert-success"><%= message %></div>
<% } %>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="card mb-3">
    <div class="card-header">
        <i class="bi bi-currency-dollar me-1"></i>
        API Tool Base Costs
    </div>
    <div class="card-body">
        <form method="post" action="/admin/ai-cost-settings">
            <div class="row g-3 align-items-end">
                <div class="col-lg-6">
                    <label for="webSearchCostPer1KCalls" class="form-label">Web search tool cost</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input
                            type="number"
                            step="0.000001"
                            min="0"
                            class="form-control"
                            id="webSearchCostPer1KCalls"
                            name="webSearchCostPer1KCalls"
                            value="<%= webSearchCostPer1KCalls %>"
                            required>
                        <span class="input-group-text">per 1,000 calls</span>
                    </div>
                    <div class="form-text">
                        Used when calculating <strong>Tool $</strong> for AI calls logged as Web search.
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="border rounded p-3 bg-light">
                        <div class="text-muted small">Current unit</div>
                        <div class="fw-semibold"><%= webSearchUnit %></div>

                        <% if (webSearchUpdatedByEmail || webSearchUpdatedAt) { %>
                            <div class="text-muted small mt-2">Last updated</div>
                            <div class="small">
                                <%= webSearchUpdatedAt || "" %>
                                <% if (webSearchUpdatedByEmail) { %>
                                    by <%= webSearchUpdatedByEmail %>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i>
                    Save Cost Settings
                </button>

                <a href="/admin/ai" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<div class="alert alert-info small">
    <strong>Note:</strong>
    This is an estimate for your own tracking. It does not change what OpenAI charges. Existing AI call logs keep the cost calculated at the time the log was created.
</div>
