<div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-trash3 me-2"></i>
            Orphaned Replenishments
        </h1>
        <p class="text-muted mb-0">
            Temporary cleanup screen for replenish records that no longer have any linked inventory bags.
        </p>
    </div>
</div>

<% if (message) { %>
    <div class="alert alert-success" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        <%= message %>
    </div>
<% } %>

<% if (error) { %>
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>
        <%= error %>
    </div>
<% } %>

<div class="alert alert-warning" role="alert">
    <div class="fw-semibold mb-1">
        Backup first.
    </div>
    <div>
        This deletes only <code>BeanPurchase</code> rows where no <code>BeanInventory</code> bag links back to that purchase.
        It does not delete coffee beans, inventory bags, brew sessions, or adjustments.
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="fw-semibold">
                    <i class="bi bi-list-check me-1"></i>
                    Orphaned Replenish Records
                </span>
                <span class="badge text-bg-light border"><%= orphanedPurchases.length %></span>
            </div>

            <div class="table-responsive mobile-card-table-wrap">
                <table class="table table-hover mb-0 align-middle mobile-card-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Bean</th>
                            <th>Purchase Date</th>
                            <th>Quantity</th>
                            <th>Total Paid</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (orphanedPurchases.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    No orphaned replenish records found.
                                </td>
                            </tr>
                        <% } %>

                        <% orphanedPurchases.forEach(function (purchase) { %>
                            <tr>
                                <td data-label="ID"><%= purchase.id %></td>
                                <td data-label="Bean">
                                    <a href="/coffee-beans/<%= purchase.beanId %>/inventory" class="fw-semibold text-decoration-none">
                                        <%= purchase.beanName %>
                                    </a>
                                    <% if (purchase.roasterName) { %>
                                        <div class="small text-muted"><%= purchase.roasterName %></div>
                                    <% } %>
                                </td>
                                <td data-label="Purchase Date"><%= purchase.purchaseDate || "-" %></td>
                                <td data-label="Quantity"><%= purchase.quantity %></td>
                                <td data-label="Total Paid">
                                    <% if (purchase.totalPaid) { %>
                                        <%= purchase.currencyCode %> <%= purchase.totalPaid %>
                                    <% } else { %>
                                        <span class="text-muted">-</span>
                                    <% } %>
                                </td>
                                <td data-label="Created"><%= purchase.createdAt || "-" %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">
                <i class="bi bi-shield-exclamation me-1"></i>
                Delete Orphans
            </div>
            <div class="card-body">
                <% if (orphanedPurchases.length === 0) { %>
                    <p class="text-muted mb-0">
                        Nothing to delete.
                    </p>
                <% } else { %>
                    <p class="text-muted">
                        This will delete <strong><%= orphanedPurchases.length %></strong> orphaned replenish record<%= orphanedPurchases.length === 1 ? "" : "s" %>.
                    </p>

                    <form method="post" action="/admin/orphan-purchases/delete" onsubmit="return confirm('Delete orphaned replenish records? Make sure you created a backup first.');">
                        <label for="confirmDelete" class="form-label">Type DELETE to confirm</label>
                        <input type="text" class="form-control mb-3" id="confirmDelete" name="confirmDelete" autocomplete="off">

                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash3 me-1"></i>
                            Delete Orphaned Replenishments
                        </button>
                    </form>
                <% } %>
            </div>
        </div>
    </div>
</div>
