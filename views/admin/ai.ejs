<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">AI Administration</h1>
        <p class="text-muted mb-0">
            Manage AI prompts and review AI usage logs in one place.
        </p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center" style="width: 3rem; height: 3rem;">
                        <i class="bi bi-activity fs-4"></i>
                    </div>

                    <div>
                        <div class="text-muted small">Total AI Calls</div>
                        <div class="fs-4 fw-semibold"><%= totalAiCallCount %></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center" style="width: 3rem; height: 3rem;">
                        <i class="bi bi-exclamation-triangle fs-4"></i>
                    </div>

                    <div>
                        <div class="text-muted small">Failed AI Calls</div>
                        <div class="fs-4 fw-semibold"><%= failedAiCallCount %></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success-subtle text-success d-inline-flex align-items-center justify-content-center" style="width: 3rem; height: 3rem;">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>

                    <div>
                        <div class="text-muted small">Latest AI Call</div>
                        <div class="fs-6 fw-semibold"><%= latestAiCallStartedAt || "None yet" %></div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-info-subtle text-info d-inline-flex align-items-center justify-content-center" style="width: 3rem; height: 3rem;">
                        <i class="bi bi-currency-dollar fs-4"></i>
                    </div>

                    <div>
                        <div class="text-muted small">Estimated Cost This Month</div>
                        <div class="fs-5 fw-semibold"><%= currentMonthEstimatedCost || "$0.000000" %></div>
                        <div class="text-muted small">All time: <%= totalEstimatedCost || "$0.000000" %></div>
                        <div class="text-muted small">Input: $<%= inputCostPer1MTokens %> / 1M</div>
                        <div class="text-muted small">Output: $<%= outputCostPer1MTokens %> / 1M</div>
                        <div class="text-muted small">Web search: $<%= webSearchCostPer1KCalls %> / 1K</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <a href="/admin/ai-call-logs" class="text-decoration-none text-reset">
            <div class="card h-100 shadow-sm admin-ai-card">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle bg-secondary-subtle text-secondary d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                            <i class="bi bi-list-check fs-4"></i>
                        </div>

                        <div>
                            <h2 class="h5 mb-1">AI Call Logs</h2>
                            <p class="text-muted mb-0">
                                See who started each AI call, when it ran, what type of call it was, whether it succeeded, token usage, and estimated cost.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-lg-4">
        <a href="/admin/ai-monthly-caps" class="text-decoration-none text-reset">
            <div class="card h-100 shadow-sm admin-ai-card">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                            <i class="bi bi-speedometer2 fs-4"></i>
                        </div>

                        <div>
                            <h2 class="h5 mb-1">AI Monthly Caps</h2>
                            <p class="text-muted mb-0">
                                Manage per-user AI monthly call caps, Use Default Cap, and No Cap.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-lg-4">
        <a href="/admin/ai-cost-settings" class="text-decoration-none text-reset">
            <div class="card h-100 shadow-sm admin-ai-card">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle bg-success-subtle text-success d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                            <i class="bi bi-currency-dollar fs-4"></i>
                        </div>

                        <div>
                            <h2 class="h5 mb-1">AI Cost Settings</h2>
                            <p class="text-muted mb-0">
                                Override estimated input token, output token, and web search base costs.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-lg-4">
        <a href="/admin/bean-detail-ai-prompt" class="text-decoration-none text-reset">
            <div class="card h-100 shadow-sm admin-ai-card">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle bg-warning-subtle text-warning d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                            <i class="bi bi-magic fs-4"></i>
                        </div>

                        <div>
                            <h2 class="h5 mb-1">Bean Detail Prompt</h2>
                            <p class="text-muted mb-0">
                                Manage the prompt used by Get Coffee Information for bean origin, process, roast level, and notes.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-lg-4">
        <a href="/admin/coffee-bag-image-identity-ai-prompt" class="text-decoration-none text-reset">
            <div class="card h-100 shadow-sm admin-ai-card">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle bg-success-subtle text-success d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                            <i class="bi bi-camera fs-4"></i>
                        </div>

                        <div>
                            <h2 class="h5 mb-1">Bean Bag Image OCR Prompt</h2>
                            <p class="text-muted mb-0">
                                Manage the prompt used to read a bag photo and extract only roaster and coffee name. Bean details are handled by the separate Bean Detail Prompt.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-lg-4">
        <a href="/admin/brew-suggestion-ai-prompt" class="text-decoration-none text-reset">
            <div class="card h-100 shadow-sm admin-ai-card">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle bg-info-subtle text-info d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                            <i class="bi bi-stars fs-4"></i>
                        </div>

                        <div>
                            <h2 class="h5 mb-1">Brew Suggestion Prompt</h2>
                            <p class="text-muted mb-0">
                                Manage the prompt used by AI Recipe Setup for brew recommendations.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
    .admin-ai-card {
        transition: transform 0.12s ease, box-shadow 0.12s ease;
    }

    .admin-ai-card:hover,
    .admin-ai-card:focus-within {
        transform: translateY(-2px);
        box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.12) !important;
    }
</style>
