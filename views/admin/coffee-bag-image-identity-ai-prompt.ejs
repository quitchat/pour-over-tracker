<%
    const messageText = typeof message !== "undefined" ? message : "";
    const errorText = typeof error !== "undefined" ? error : "";
    const promptTextValue = promptRecord && promptRecord.promptText ? promptRecord.promptText : "";
    const defaultPromptValue = typeof defaultPromptText !== "undefined" ? defaultPromptText : "";
    const updatedByText = promptRecord && promptRecord.updatedByEmail ? promptRecord.updatedByEmail : "";
    const updatedAtText = promptRecord && promptRecord.updatedAt && typeof formatDateTimeUs !== "undefined" ? formatDateTimeUs(promptRecord.updatedAt) : "";
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-camera me-2"></i>
            Bean Bag Image Identity AI Prompt
        </h1>
        <p class="text-muted mb-0">
            Manage the prompt used by Upload + Read Label to extract Roaster and Coffee Name from a bean bag photo.
        </p>
    </div>

    <a href="/admin/ai" class="btn btn-outline-secondary">
        <i class="bi bi-robot me-1"></i>
        AI Administration
    </a>
</div>

<% if (messageText) { %>
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-1"></i>
        <%= messageText %>
    </div>
<% } %>

<% if (errorText) { %>
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-1"></i>
        <%= errorText %>
    </div>
<% } %>

<div class="card mb-3">
    <div class="card-header">
        <i class="bi bi-pencil-square me-1"></i>
        Prompt Editor
    </div>

    <div class="card-body">
        <form method="post" action="/admin/coffee-bag-image-identity-ai-prompt">
            <div class="mb-3">
                <label for="promptText" class="form-label">Prompt Text</label>
                <textarea id="promptText" name="promptText" class="form-control font-monospace" rows="18" required><%= promptTextValue %></textarea>

                <div class="form-text">
                    This prompt is used with the uploaded bean bag image. It should extract only Roaster and Coffee Name. Do not ask it to fill origin, process, roast level, tasting notes, or price.
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center gap-2 flex-column flex-md-row">
                <div class="text-muted small">
                    <% if (updatedAtText) { %>
                        Last updated: <%= updatedAtText %>
                    <% } else { %>
                        Last updated: not available
                    <% } %>

                    <% if (updatedByText) { %>
                        by <%= updatedByText %>
                    <% } %>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" name="action" value="reset" class="btn btn-outline-danger" onclick="return confirm('Reset this prompt to the default version?');">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>
                        Reset Default
                    </button>

                    <button type="submit" name="action" value="save" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>
                        Save Prompt
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <i class="bi bi-file-text me-1"></i>
        Default Prompt Reference
    </div>

    <div class="card-body">
        <textarea class="form-control font-monospace" rows="12" readonly><%= defaultPromptValue %></textarea>
    </div>
</div>