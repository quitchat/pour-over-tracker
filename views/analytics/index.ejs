<%
    const summaryValue = typeof summary !== "undefined" ? summary : {
        totalBeans: 0,
        activeBeans: 0,
        inactiveBeans: 0,
        totalBrews: 0,
        averageRating: 0
    };

    const topBeanList = typeof topBeans !== "undefined" ? topBeans : [];
    const topGrinderList = typeof topGrinders !== "undefined" ? topGrinders : [];
    const topBrewerList = typeof topBrewers !== "undefined" ? topBrewers : [];
    const recentBrewList = typeof recentBrews !== "undefined" ? recentBrews : [];



    const inventoryAnalyticsValue = typeof inventoryAnalytics !== "undefined" ? inventoryAnalytics : {
        lowStockThresholdGrams: 50,
        summary: {
            totalCoffeeOnHandGrams: 0,
            beanCountWithInventory: 0,
            lowBeanCount: 0,
            outOfStockBeanCount: 0,
            oldestInventory: null,
            inventoryValueEstimate: { isKnown: false, isMultipleCurrency: false, currencyCode: "", total: null, values: [], knownRecordCount: 0, totalRecordCount: 0 },
            coffeeConsumedThisMonthGrams: 0,
            mostRecentlyReplenished: null
        },
        beansRunningLow: [],
        currentInventory: [],
        recentlyReplenished: [],
        inventoryValueByBean: []
    };

    const costAnalyticsValue = typeof costAnalytics !== "undefined" ? costAnalytics : {
        selectedRange: "last90",
        selectedRangeLabel: "Last 90 days",
        rangeOptions: [],
        summary: {
            coffeeCost: { isKnown: false, isMultipleCurrency: false, currencyCode: "", total: null, values: [] },
            coffeePurchased: { isKnown: false, isMultipleCurrency: false, currencyCode: "", total: null, values: [] },
            averageCostPerBrew: { isKnown: false, isMultipleCurrency: false, currencyCode: "", total: null, values: [] },
            knownCostBrewCount: 0,
            totalBrewCount: 0
        },
        costByBean: [],
        costByRoaster: [],
        bestValueBeans: [],
        mostExpensiveBrews: []
    };

    const analyticsChartData = typeof chartData !== "undefined" ? chartData : {
        monthlyLabels: [],
        monthlyBrewCounts: [],
        monthlyAverageRatings: [],
        tastingLabels: [],
        tastingAverages: []
    };



    function formatNumber(value, decimals = 1) {
        if (value === null || value === undefined || value === "") {
            return "—";
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return "—";
        }

        return numericValue.toLocaleString(undefined, {
            minimumFractionDigits: 0,
            maximumFractionDigits: decimals
        });
    }

    function formatCurrencyValue(value, currencyCode, decimals = 2) {
        if (value === null || value === undefined || value === "") {
            return "—";
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return "—";
        }

        return `${currencyCode} ${numericValue.toLocaleString(undefined, {
            minimumFractionDigits: decimals,
            maximumFractionDigits: decimals
        })}`;
    }

    function renderCostDisplay(display, decimals = 2) {
        if (!display || !display.isKnown || !display.values || display.values.length === 0) {
            return `<span class="text-muted">—</span>`;
        }

        if (display.values.length === 1) {
            return formatCurrencyValue(display.values[0].total, display.values[0].currencyCode, decimals);
        }

        let html = `<div class="small text-muted mb-1">Multiple currencies</div>`;
        html += `<div class="cost-currency-subtotals">`;
        display.values.forEach(function (item) {
            html += `<div>${formatCurrencyValue(item.total, item.currencyCode, decimals)}</div>`;
        });
        html += `</div>`;

        return html;
    }

    function renderCostCoverage(knownCount, totalCount) {
        if (!totalCount || Number(totalCount) === 0) {
            return `<span class="text-muted small">No brews in range</span>`;
        }

        if (Number(knownCount) === Number(totalCount)) {
            return `<span class="text-muted small">Cost known for all ${totalCount} brews</span>`;
        }

        return `<span class="text-muted small">Cost based on ${knownCount} of ${totalCount} brews</span>`;
    }


    function renderInventoryValueCoverage(display) {
        if (!display || !display.totalRecordCount || Number(display.totalRecordCount) === 0) {
            return `<span class="text-muted small">No current inventory</span>`;
        }

        if (Number(display.knownRecordCount) === Number(display.totalRecordCount)) {
            return `<span class="text-muted small">Value known for all ${display.totalRecordCount} inventory records</span>`;
        }

        return `<span class="text-muted small">Based on ${display.knownRecordCount} of ${display.totalRecordCount} inventory records</span>`;
    }

    function formatMaybeDate(value) {
        if (!value) {
            return "—";
        }

        return value;
    }

    function formatAge(value) {
        if (value === null || value === undefined || value === "") {
            return "—";
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return "—";
        }

        return `${numericValue} days`;
    }

    function renderRatingStars(value, emptyText = "Not rated") {
        if (value === null || value === undefined || value === "") {
            return `<span class="text-muted">${emptyText}</span>`;
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return `<span class="text-muted">${emptyText}</span>`;
        }

        const clampedValue = Math.max(0, Math.min(5, numericValue));
        const displayValue = Number.isInteger(clampedValue) ? clampedValue.toFixed(0) : clampedValue.toFixed(1);
        let html = `<span class="readonly-rating-display" style="white-space: nowrap;"><span class="readonly-rating-stars" style="white-space: nowrap;" aria-label="${displayValue} out of 5 stars">`;

        for (let index = 1; index <= 5; index++) {
            if (clampedValue >= index) {
                html += `<i class="bi bi-star-fill" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            } else if (clampedValue >= index - 0.5) {
                html += `<i class="bi bi-star-half" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            } else {
                html += `<i class="bi bi-star" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            }
        }

        html += `</span>`;
        html += `</span>`;
        return html;
    }
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-graph-up-arrow me-2"></i>
            Analytics
        </h1>
        <p class="text-muted mb-0">
            Review brew activity, ratings, and tasting trends.
        </p>
    </div>

</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <a href="/brew-sessions" class="card h-100 text-decoration-none text-reset analytics-summary-card">
            <div class="card-body">
                <div class="text-muted small">Total Brews</div>
                <div class="display-6 fw-semibold"><%= summaryValue.totalBrews %></div>
                <div class="small text-primary">View brew sessions</div>
            </div>
        </a>
    </div>

    <div class="col-12 col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Average Rating</div>
                <div class="display-6 fw-semibold"><%= summaryValue.averageRating %></div>
                <div class="text-muted small">out of 5</div>
            </div>
        </div>
    </div>


    <div class="col-12 col-md-4">
        <a href="/coffee-beans" class="card h-100 text-decoration-none text-reset analytics-summary-card">
            <div class="card-body">
                <div class="text-muted small">Beans</div>
                <div class="display-6 fw-semibold"><%= summaryValue.totalBeans %></div>
                <div class="text-muted small">
                    <%= summaryValue.activeBeans %> active / <%= summaryValue.inactiveBeans %> inactive
                </div>
                <div class="small text-primary">View beans</div>
            </div>
        </a>
    </div>
</div>


<div class="analytics-section-tabs mb-4">
    <ul class="nav nav-pills nav-fill flex-column flex-sm-row gap-2 mb-3" id="analyticsDetailTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="inventory-summary-tab" data-bs-toggle="tab" data-bs-target="#inventory-summary-pane" type="button" role="tab" aria-controls="inventory-summary-pane" aria-selected="true">
                <i class="bi bi-box-seam me-1"></i>
                Inventory Summary
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="cost-analytics-tab" data-bs-toggle="tab" data-bs-target="#cost-analytics-pane" type="button" role="tab" aria-controls="cost-analytics-pane" aria-selected="false">
                <i class="bi bi-cash-coin me-1"></i>
                Cost Analytics
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="brew-summary-tab" data-bs-toggle="tab" data-bs-target="#brew-summary-pane" type="button" role="tab" aria-controls="brew-summary-pane" aria-selected="false">
                <i class="bi bi-cup-hot me-1"></i>
                Brew Summary
            </button>
        </li>
    </ul>

    <div class="tab-content" id="analyticsDetailTabContent">
        <div class="tab-pane fade show active" id="inventory-summary-pane" role="tabpanel" aria-labelledby="inventory-summary-tab" tabindex="0">
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Total Coffee On Hand</div>
                        <div class="h4 fw-semibold mb-1"><%= formatNumber(inventoryAnalyticsValue.summary.totalCoffeeOnHandGrams, 1) %>g</div>
                        <div class="small text-muted">Across <%= inventoryAnalyticsValue.summary.beanCountWithInventory %> beans</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Beans Running Low</div>
                        <div class="h4 fw-semibold mb-1"><%= inventoryAnalyticsValue.summary.lowBeanCount %> beans low</div>
                        <div class="small text-muted">
                            ≤ <%= inventoryAnalyticsValue.lowStockThresholdGrams %>g, plus <%= inventoryAnalyticsValue.summary.outOfStockBeanCount %> out of stock
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Oldest Inventory</div>
                        <% if (inventoryAnalyticsValue.summary.oldestInventory) { %>
                            <div class="fw-semibold mb-1">
                                <a href="/coffee-beans/<%= inventoryAnalyticsValue.summary.oldestInventory.beanId %>/inventory" class="text-decoration-none">
                                    <%= inventoryAnalyticsValue.summary.oldestInventory.beanName %>
                                </a>
                            </div>
                            <div class="small text-muted">
                                <% if (inventoryAnalyticsValue.summary.oldestInventory.roasterName) { %><%= inventoryAnalyticsValue.summary.oldestInventory.roasterName %> · <% } %>
                                <%= formatAge(inventoryAnalyticsValue.summary.oldestInventory.ageDays) %> · <%= formatNumber(inventoryAnalyticsValue.summary.oldestInventory.remainingGrams, 1) %>g left
                            </div>
                        <% } else { %>
                            <div class="h4 fw-semibold mb-1 text-muted">—</div>
                            <div class="small text-muted">No current inventory</div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Inventory Value Estimate</div>
                        <div class="h4 fw-semibold mb-1"><%- renderCostDisplay(inventoryAnalyticsValue.summary.inventoryValueEstimate, 2) %></div>
                        <%- renderInventoryValueCoverage(inventoryAnalyticsValue.summary.inventoryValueEstimate) %>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Coffee Consumed This Month</div>
                        <div class="h4 fw-semibold mb-1"><%= formatNumber(inventoryAnalyticsValue.summary.coffeeConsumedThisMonthGrams, 1) %>g</div>
                        <div class="small text-muted">All brews this month</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Most Recently Replenished</div>
                        <% if (inventoryAnalyticsValue.summary.mostRecentlyReplenished) { %>
                            <div class="fw-semibold mb-1">
                                <a href="/coffee-beans/<%= inventoryAnalyticsValue.summary.mostRecentlyReplenished.beanId %>/inventory" class="text-decoration-none">
                                    <%= inventoryAnalyticsValue.summary.mostRecentlyReplenished.beanName %>
                                </a>
                            </div>
                            <div class="small text-muted">
                                <% if (inventoryAnalyticsValue.summary.mostRecentlyReplenished.roasterName) { %><%= inventoryAnalyticsValue.summary.mostRecentlyReplenished.roasterName %> · <% } %>
                                added <%= inventoryAnalyticsValue.summary.mostRecentlyReplenished.replenishedDate %>
                            </div>
                        <% } else { %>
                            <div class="h4 fw-semibold mb-1 text-muted">—</div>
                            <div class="small text-muted">No replenishments yet</div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

<% if (inventoryAnalyticsValue.beansRunningLow.length > 0) { %>
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Beans Running Low
                    </div>
                    <div class="table-responsive mobile-card-table-wrap">
                        <table class="table table-hover mb-0 align-middle mobile-card-table">
                            <thead>
                                <tr>
                                    <th>Bean</th>
                                    <th>Remaining</th>
                                    <th>Last Brewed</th>
                                    <th>Last Replenished</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (inventoryAnalyticsValue.beansRunningLow.length === 0) { %>
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">No beans are currently low.</td>
                                    </tr>
                                <% } %>
                                <% inventoryAnalyticsValue.beansRunningLow.forEach(function (bean) { %>
                                    <tr class="analytics-inventory-clickable-row" data-href="/coffee-beans/<%= bean.beanId %>/inventory" tabindex="0" role="link" aria-label="View inventory for <%= bean.beanName %>">
                                        <td data-label="Bean">
                                            <div class="fw-semibold"><%= bean.beanName %></div>
                                            <% if (bean.roasterName) { %>
                                                <div class="text-muted small"><%= bean.roasterName %></div>
                                            <% } %>
                                        </td>
                                        <td data-label="Remaining"><%= formatNumber(bean.remainingGrams, 1) %>g</td>
                                        <td data-label="Last Brewed"><%= formatMaybeDate(bean.lastBrewedDate) %></td>
                                        <td data-label="Last Replenished"><%= formatMaybeDate(bean.lastReplenishedDate) %></td>
                                        <td data-label="Actions">
                                            <div class="d-flex flex-wrap gap-1" aria-label="Inventory actions">
                                                <a href="/coffee-beans/<%= bean.beanId %>" class="btn btn-sm btn-outline-secondary">View</a>
                                                <a href="/coffee-beans/<%= bean.beanId %>/replenishments/new" class="btn btn-sm btn-outline-secondary">Replenish</a>
                                                <a href="/coffee-beans/<%= bean.beanId %>/opening-balance/new" class="btn btn-sm btn-outline-secondary">Set</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

<% } %>

        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-boxes me-1"></i>
                        Current Inventory
                    </div>
                    <div class="table-responsive mobile-card-table-wrap">
                        <table class="table table-hover mb-0 align-middle mobile-card-table">
                            <thead>
                                <tr>
                                    <th>Bean</th>
                                    <th>Remaining</th>
                                    <th>Bag Size</th>
                                    <th>Roast Date</th>
                                    <th>Purchase Date</th>
                                    <th>Age</th>
                                    <th>Estimated Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (inventoryAnalyticsValue.currentInventory.length === 0) { %>
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">No current inventory on hand.</td>
                                    </tr>
                                <% } %>
                                <% inventoryAnalyticsValue.currentInventory.forEach(function (inventory) { %>
                                    <tr class="analytics-inventory-clickable-row" data-href="/coffee-beans/<%= inventory.beanId %>/inventory" tabindex="0" role="link" aria-label="View inventory for <%= inventory.beanName %>">
                                        <td data-label="Bean">
                                            <div class="fw-semibold"><%= inventory.beanName %></div>
                                            <% if (inventory.roasterName) { %>
                                                <div class="text-muted small"><%= inventory.roasterName %></div>
                                            <% } %>
                                        </td>
                                        <td data-label="Remaining"><%= formatNumber(inventory.remainingGrams, 1) %>g</td>
                                        <td data-label="Bag Size"><%= inventory.bagSizeLabel %></td>
                                        <td data-label="Roast Date"><%= formatMaybeDate(inventory.roastDate) %></td>
                                        <td data-label="Purchase Date"><%= formatMaybeDate(inventory.purchaseDate) %></td>
                                        <td data-label="Age"><%= formatAge(inventory.ageDays) %></td>
                                        <td data-label="Estimated Value"><%= inventory.estimatedValue === null ? "—" : formatCurrencyValue(inventory.estimatedValue, inventory.currencyCode, 2) %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-calendar-plus me-1"></i>
                        Recently Replenished
                    </div>
                    <div class="table-responsive mobile-card-table-wrap">
                        <table class="table table-hover mb-0 align-middle mobile-card-table">
                            <thead>
                                <tr>
                                    <th>Purchase Date</th>
                                    <th>Bean</th>
                                    <th>Quantity</th>
                                    <th>Total Grams</th>
                                    <th>Remaining</th>
                                    <th>Cost</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (inventoryAnalyticsValue.recentlyReplenished.length === 0) { %>
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">No replenishments yet.</td>
                                    </tr>
                                <% } %>
                                <% inventoryAnalyticsValue.recentlyReplenished.forEach(function (purchase) { %>
                                    <tr class="analytics-inventory-clickable-row" data-href="/coffee-beans/<%= purchase.beanId %>/inventory" tabindex="0" role="link" aria-label="View inventory for <%= purchase.beanName %>">
                                        <td data-label="Purchase Date"><%= formatMaybeDate(purchase.purchaseDate) %></td>
                                        <td data-label="Bean">
                                            <div class="fw-semibold"><%= purchase.beanName %></div>
                                            <% if (purchase.roasterName) { %>
                                                <div class="text-muted small"><%= purchase.roasterName %></div>
                                            <% } %>
                                        </td>
                                        <td data-label="Quantity"><%= purchase.quantity %><% if (purchase.bagSizeGrams) { %> × <%= formatNumber(purchase.bagSizeGrams, 1) %>g<% } %></td>
                                        <td data-label="Total Grams"><%= formatNumber(purchase.totalGrams, 1) %>g</td>
                                        <td data-label="Remaining"><%= formatNumber(purchase.remainingGrams, 1) %>g</td>
                                        <td data-label="Cost"><%= purchase.cost === null ? "—" : formatCurrencyValue(purchase.cost, purchase.currencyCode, 2) %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-wallet2 me-1"></i>
                        Inventory Value by Bean
                    </div>
                    <div class="table-responsive mobile-card-table-wrap">
                        <table class="table table-hover mb-0 align-middle mobile-card-table">
                            <thead>
                                <tr>
                                    <th>Bean</th>
                                    <th>Remaining</th>
                                    <th>Known Cost Coverage</th>
                                    <th>Estimated Value</th>
                                    <th>Cost / Gram</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (inventoryAnalyticsValue.inventoryValueByBean.length === 0) { %>
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">No current inventory value data.</td>
                                    </tr>
                                <% } %>
                                <% inventoryAnalyticsValue.inventoryValueByBean.forEach(function (bean) { %>
                                    <tr class="analytics-inventory-clickable-row" data-href="/coffee-beans/<%= bean.beanId %>/inventory" tabindex="0" role="link" aria-label="View inventory for <%= bean.beanName %>">
                                        <td data-label="Bean">
                                            <div class="fw-semibold"><%= bean.beanName %></div>
                                            <% if (bean.roasterName) { %>
                                                <div class="text-muted small"><%= bean.roasterName %></div>
                                            <% } %>
                                        </td>
                                        <td data-label="Remaining"><%= formatNumber(bean.remainingGrams, 1) %>g</td>
                                        <td data-label="Known Cost Coverage"><%- renderInventoryValueCoverage(bean.valueDisplay) %></td>
                                        <td data-label="Estimated Value"><%- renderCostDisplay(bean.valueDisplay, 2) %></td>
                                        <td data-label="Cost / Gram"><%- renderCostDisplay(bean.averageCostPerGram, 4) %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        </div>

        <div class="tab-pane fade" id="cost-analytics-pane" role="tabpanel" aria-labelledby="cost-analytics-tab" tabindex="0">
        <div class="d-flex justify-content-end mb-3">
            <form method="get" action="/analytics" class="d-flex align-items-center gap-2 flex-wrap">
                <label for="costRange" class="form-label small text-muted mb-0">Date range</label>
                <select id="costRange" name="costRange" class="form-select form-select-sm cost-range-select" onchange="this.form.submit()">
                    <% costAnalyticsValue.rangeOptions.forEach(function (option) { %>
                        <option value="<%= option.value %>" <%= option.value === costAnalyticsValue.selectedRange ? "selected" : "" %>><%= option.label %></option>
                    <% }); %>
                </select>
                <noscript>
                    <button type="submit" class="btn btn-sm btn-outline-primary">Apply</button>
                </noscript>
            </form>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Coffee Cost</div>
                        <div class="h4 fw-semibold mb-1"><%- renderCostDisplay(costAnalyticsValue.summary.coffeeCost, 2) %></div>
                        <div class="small text-muted">Consumed coffee cost</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Coffee Purchased</div>
                        <div class="h4 fw-semibold mb-1"><%- renderCostDisplay(costAnalyticsValue.summary.coffeePurchased, 2) %></div>
                        <div class="small text-muted">Purchase/order cost</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
