<%
    const summaryValue = typeof summary !== "undefined" ? summary : {
        totalBeans: 0,
        activeBeans: 0,
        inactiveBeans: 0,
        totalBrews: 0,
        averageRating: 0
    };

    const topBeanList = typeof topBeans !== "undefined" ? topBeans : [];
    const topGrinderList = typeof topGrinders !== "undefined" ? topGrinders : [];
    const topBrewerList = typeof topBrewers !== "undefined" ? topBrewers : [];
    const recentBrewList = typeof recentBrews !== "undefined" ? recentBrews : [];

    const costAnalyticsValue = typeof costAnalytics !== "undefined" ? costAnalytics : {
        selectedRange: "last90",
        selectedRangeLabel: "Last 90 days",
        rangeOptions: [],
        summary: {
            coffeeCost: { isKnown: false, isMultipleCurrency: false, currencyCode: "", total: null, values: [] },
            coffeePurchased: { isKnown: false, isMultipleCurrency: false, currencyCode: "", total: null, values: [] },
            averageCostPerBrew: { isKnown: false, isMultipleCurrency: false, currencyCode: "", total: null, values: [] },
            averageCostPerGram: { isKnown: false, isMultipleCurrency: false, currencyCode: "", total: null, values: [] },
            knownCostBrewCount: 0,
            totalBrewCount: 0
        },
        costByBean: [],
        costByRoaster: [],
        bestValueBeans: [],
        mostExpensiveBrews: []
    };

    const analyticsChartData = typeof chartData !== "undefined" ? chartData : {
        monthlyLabels: [],
        monthlyBrewCounts: [],
        monthlyAverageRatings: [],
        tastingLabels: [],
        tastingAverages: []
    };



    function formatNumber(value, decimals = 1) {
        if (value === null || value === undefined || value === "") {
            return "—";
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return "—";
        }

        return numericValue.toLocaleString(undefined, {
            minimumFractionDigits: 0,
            maximumFractionDigits: decimals
        });
    }

    function formatCurrencyValue(value, currencyCode, decimals = 2) {
        if (value === null || value === undefined || value === "") {
            return "—";
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return "—";
        }

        return `${currencyCode} ${numericValue.toLocaleString(undefined, {
            minimumFractionDigits: decimals,
            maximumFractionDigits: decimals
        })}`;
    }

    function renderCostDisplay(display, decimals = 2) {
        if (!display || !display.isKnown || !display.values || display.values.length === 0) {
            return `<span class="text-muted">—</span>`;
        }

        if (display.values.length === 1) {
            return formatCurrencyValue(display.values[0].total, display.values[0].currencyCode, decimals);
        }

        let html = `<div class="small text-muted mb-1">Multiple currencies</div>`;
        html += `<div class="cost-currency-subtotals">`;
        display.values.forEach(function (item) {
            html += `<div>${formatCurrencyValue(item.total, item.currencyCode, decimals)}</div>`;
        });
        html += `</div>`;

        return html;
    }

    function renderCostCoverage(knownCount, totalCount) {
        if (!totalCount || Number(totalCount) === 0) {
            return `<span class="text-muted small">No brews in range</span>`;
        }

        if (Number(knownCount) === Number(totalCount)) {
            return `<span class="text-muted small">Cost known for all ${totalCount} brews</span>`;
        }

        return `<span class="text-muted small">Cost based on ${knownCount} of ${totalCount} brews</span>`;
    }
    function renderRatingStars(value, emptyText = "Not rated") {
        if (value === null || value === undefined || value === "") {
            return `<span class="text-muted">${emptyText}</span>`;
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return `<span class="text-muted">${emptyText}</span>`;
        }

        const clampedValue = Math.max(0, Math.min(5, numericValue));
        const displayValue = Number.isInteger(clampedValue) ? clampedValue.toFixed(0) : clampedValue.toFixed(1);
        let html = `<span class="readonly-rating-display" style="white-space: nowrap;"><span class="readonly-rating-stars" style="white-space: nowrap;" aria-label="${displayValue} out of 5 stars">`;

        for (let index = 1; index <= 5; index++) {
            if (clampedValue >= index) {
                html += `<i class="bi bi-star-fill" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            } else if (clampedValue >= index - 0.5) {
                html += `<i class="bi bi-star-half" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            } else {
                html += `<i class="bi bi-star" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            }
        }

        html += `</span>`;
        html += `</span>`;
        return html;
    }
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-graph-up-arrow me-2"></i>
            Analytics
        </h1>
        <p class="text-muted mb-0">
            Review brew activity, ratings, and tasting trends.
        </p>
    </div>

</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <a href="/brew-sessions" class="card h-100 text-decoration-none text-reset analytics-summary-card">
            <div class="card-body">
                <div class="text-muted small">Total Brews</div>
                <div class="display-6 fw-semibold"><%= summaryValue.totalBrews %></div>
                <div class="small text-primary">View brew sessions</div>
            </div>
        </a>
    </div>

    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Average Rating</div>
                <div class="display-6 fw-semibold"><%= summaryValue.averageRating %></div>
                <div class="text-muted small">out of 5</div>
            </div>
        </div>
    </div>


    <div class="col-6 col-lg-3">
        <a href="/coffee-beans" class="card h-100 text-decoration-none text-reset analytics-summary-card">
            <div class="card-body">
                <div class="text-muted small">Beans</div>
                <div class="display-6 fw-semibold"><%= summaryValue.totalBeans %></div>
                <div class="text-muted small">
                    <%= summaryValue.activeBeans %> active / <%= summaryValue.inactiveBeans %> inactive
                </div>
                <div class="small text-primary">View beans</div>
            </div>
        </a>
    </div>
</div>


<div class="card mb-4" id="cost-analytics">
    <div class="card-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="fw-semibold">
                <i class="bi bi-cash-coin me-1"></i>
                Cost Analytics
            </div>
            <div class="small text-muted">
                Inventory-linked purchase cost reporting for <%= costAnalyticsValue.selectedRangeLabel %>.
            </div>
        </div>

        <form method="get" action="/analytics" class="d-flex align-items-center gap-2 flex-wrap">
            <label for="costRange" class="form-label small text-muted mb-0">Date range</label>
            <select id="costRange" name="costRange" class="form-select form-select-sm cost-range-select" onchange="this.form.submit()">
                <% costAnalyticsValue.rangeOptions.forEach(function (option) { %>
                    <option value="<%= option.value %>" <%= option.value === costAnalyticsValue.selectedRange ? "selected" : "" %>><%= option.label %></option>
                <% }); %>
            </select>
            <noscript>
                <button type="submit" class="btn btn-sm btn-outline-primary">Apply</button>
            </noscript>
        </form>
    </div>

    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Coffee Cost</div>
                        <div class="h4 fw-semibold mb-1"><%- renderCostDisplay(costAnalyticsValue.summary.coffeeCost, 2) %></div>
                        <div class="small text-muted">Consumed coffee cost</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Coffee Purchased</div>
                        <div class="h4 fw-semibold mb-1"><%- renderCostDisplay(costAnalyticsValue.summary.coffeePurchased, 2) %></div>
                        <div class="small text-muted">Purchase/order cost</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Average Cost per Brew</div>
                        <div class="h4 fw-semibold mb-1"><%- renderCostDisplay(costAnalyticsValue.summary.averageCostPerBrew, 2) %></div>
                        <%- renderCostCoverage(costAnalyticsValue.summary.knownCostBrewCount, costAnalyticsValue.summary.totalBrewCount) %>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100 bg-light border-0">
                    <div class="card-body">
                        <div class="text-muted small">Average Cost per Gram</div>
                        <div class="h4 fw-semibold mb-1"><%- renderCostDisplay(costAnalyticsValue.summary.averageCostPerGram, 4) %></div>
                        <div class="small text-muted">Known-cost brews only</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-cup-hot me-1"></i>
                        Cost by Bean
                    </div>
                    <div class="table-responsive mobile-card-table-wrap">
                        <table class="table table-hover mb-0 align-middle mobile-card-table">
                            <thead>
                                <tr>
                                    <th>Bean</th>
                                    <th>Brews</th>
                                    <th>Grams Brewed</th>
                                    <th>Total Cost</th>
                                    <th>Avg Cost/Brew</th>
                                    <th>Avg Cost/g</th>
                                    <th>Avg Rating</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (costAnalyticsValue.costByBean.length === 0) { %>
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">No bean cost data in this range.</td>
                                    </tr>
                                <% } %>
                                <% costAnalyticsValue.costByBean.forEach(function (item) { %>
                                    <tr>
                                        <td data-label="Bean">
                                            <a href="/coffee-beans/<%= item.beanId %>" class="fw-semibold text-decoration-none"><%= item.beanName %></a>
                                            <% if (item.roasterName) { %>
                                                <div class="text-muted small"><%= item.roasterName %></div>
                                            <% } %>
                                            <div><%- renderCostCoverage(item.knownCostBrewCount, item.brewCount) %></div>
                                        </td>
                                        <td data-label="Brews"><%= item.brewCount %></td>
                                        <td data-label="Grams Brewed"><%= formatNumber(item.gramsBrewed, 1) %>g</td>
                                        <td data-label="Total Cost"><%- renderCostDisplay(item.totalCost, 2) %></td>
                                        <td data-label="Avg Cost/Brew"><%- renderCostDisplay(item.averageCostPerBrew, 2) %></td>
                                        <td data-label="Avg Cost/g"><%- renderCostDisplay(item.averageCostPerGram, 4) %></td>
                                        <td data-label="Avg Rating"><%- renderRatingStars(item.averageRating) %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-shop me-1"></i>
                        Cost by Roaster
                    </div>
                    <div class="table-responsive mobile-card-table-wrap">
                        <table class="table table-hover mb-0 align-middle mobile-card-table">
                            <thead>
                                <tr>
                                    <th>Roaster</th>
                                    <th>Brews</th>
                                    <th>Beans</th>
                                    <th>Grams Brewed</th>
                                    <th>Total Cost</th>
                                    <th>Avg Cost/Brew</th>
                                    <th>Avg Cost/g</th>
                                    <th>Avg Rating</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (costAnalyticsValue.costByRoaster.length === 0) { %>
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">No roaster cost data in this range.</td>
                                    </tr>
                                <% } %>
                                <% costAnalyticsValue.costByRoaster.forEach(function (item) { %>
                                    <tr>
                                        <td data-label="Roaster">
                                            <div class="fw-semibold"><%= item.roasterName %></div>
                                            <div><%- renderCostCoverage(item.knownCostBrewCount, item.brewCount) %></div>
                                        </td>
                                        <td data-label="Brews"><%= item.brewCount %></td>
                                        <td data-label="Beans"><%= item.beanCount %></td>
                                        <td data-label="Grams Brewed"><%= formatNumber(item.gramsBrewed, 1) %>g</td>
                                        <td data-label="Total Cost"><%- renderCostDisplay(item.totalCost, 2) %></td>
                                        <td data-label="Avg Cost/Brew"><%- renderCostDisplay(item.averageCostPerBrew, 2) %></td>
                                        <td data-label="Avg Cost/g"><%- renderCostDisplay(item.averageCostPerGram, 4) %></td>
                                        <td data-label="Avg Rating"><%- renderRatingStars(item.averageRating) %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-xl-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-gem me-1"></i>
                        Best Value Beans
                    </div>
                    <div class="table-responsive mobile-card-table-wrap">
                        <table class="table table-hover mb-0 align-middle mobile-card-table">
                            <thead>
                                <tr>
                                    <th>Bean</th>
                                    <th>Avg Rating</th>
                                    <th>Avg Cost/Brew</th>
                                    <th>Avg Cost/g</th>
                                    <th>Brews</th>
                                    <th>Value Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (costAnalyticsValue.bestValueBeans.length === 0) { %>
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Need at least 2 brews with rating and known cost.</td>
                                    </tr>
                                <% } %>
                                <% costAnalyticsValue.bestValueBeans.forEach(function (item) { %>
                                    <tr>
                                        <td data-label="Bean">
                                            <a href="/coffee-beans/<%= item.beanId %>" class="fw-semibold text-decoration-none"><%= item.beanName %></a>
                                            <% if (item.roasterName) { %>
                                                <div class="text-muted small"><%= item.roasterName %></div>
                                            <% } %>
                                        </td>
                                        <td data-label="Avg Rating"><%- renderRatingStars(item.averageRating) %></td>
                                        <td data-label="Avg Cost/Brew"><%- renderCostDisplay(item.averageCostPerBrew, 2) %></td>
                                        <td data-label="Avg Cost/g"><%- renderCostDisplay(item.averageCostPerGram, 4) %></td>
                                        <td data-label="Brews"><%= item.brewCount %></td>
                                        <td data-label="Value Score"><%= item.valueScore %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-xl-6">
                <div class="card h-100">
                    <div class="card-header">
                        <i class="bi bi-arrow-up-circle me-1"></i>
                        Most Expensive Brews
                    </div>
                    <div class="table-responsive mobile-card-table-wrap">
                        <table class="table table-hover mb-0 align-middle mobile-card-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Bean</th>
                                    <th>Brew Summary</th>
                                    <th>Rating</th>
                                    <th>Coffee Grams</th>
                                    <th>Cost</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (costAnalyticsValue.mostExpensiveBrews.length === 0) { %>
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">No known-cost brews in this range.</td>
                                    </tr>
                                <% } %>
                                <% costAnalyticsValue.mostExpensiveBrews.forEach(function (brew) { %>
                                    <tr class="analytics-cost-clickable-row" data-href="/brew-sessions/<%= brew.id %>" tabindex="0" role="link" aria-label="View brew session details for <%= brew.beanName %> on <%= brew.brewDate %>">
                                        <td data-label="Date"><%= brew.brewDate %></td>
                                        <td data-label="Bean">
                                            <div class="fw-semibold"><%= brew.beanName %></div>
                                            <% if (brew.roasterName) { %>
                                                <div class="text-muted small"><%= brew.roasterName %></div>
                                            <% } %>
                                        </td>
                                        <td data-label="Brew Summary"><%= brew.brewSummary %></td>
                                        <td data-label="Rating"><%- renderRatingStars(brew.rating) %></td>
                                        <td data-label="Coffee Grams"><%= formatNumber(brew.coffeeGrams, 1) %>g</td>
                                        <td data-label="Cost"><%= formatCurrencyValue(brew.cost, brew.currencyCode, 2) %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-bar-chart-line me-1"></i>
                Brew Activity - Last 6 Months
            </div>

            <div class="card-body">
                <canvas id="monthlyBrewChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-activity me-1"></i>
                Average Tasting Profile
            </div>

            <div class="card-body">
                <canvas id="tastingRadarChart" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-cup-hot me-1"></i>
                Most Brewed Beans
            </div>

            <div class="list-group list-group-flush">
                <% if (topBeanList.length === 0) { %>
                    <div class="list-group-item text-muted">
                        No bean data yet.
                    </div>
                <% } %>

                <% topBeanList.forEach(function (bean) { %>
                    <a href="/coffee-beans/<%= bean.id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold"><%= bean.beanName %></div>

                            <% if (bean.roasterName) { %>
                                <div class="text-muted small"><%= bean.roasterName %></div>
                            <% } %>
                        </div>

                        <span class="badge text-bg-light border">
                            <%= bean.brewCount %>
                        </span>
                    </a>
                <% }); %>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-gear me-1"></i>
                Most Used Grinders
            </div>

            <div class="list-group list-group-flush">
                <% if (topGrinderList.length === 0) { %>
                    <div class="list-group-item text-muted">
                        No grinder data yet.
                    </div>
                <% } %>

                <% topGrinderList.forEach(function (grinder) { %>
                    <a href="/grinders/<%= grinder.id %>/edit" class="list-group-item list-group-item-action d-flex justify-content-between gap-3 analytics-equipment-list-item">
                        <div class="analytics-equipment-list-info">
                            <div class="fw-semibold"><%= grinder.name %></div>

                            <% if (grinder.brand) { %>
                                <div class="text-muted small"><%= grinder.brand %></div>
                            <% } %>
                        </div>

                        <span class="analytics-total-box">
                            <span class="analytics-total-primary"><%= grinder.totalGroundGrams %>g</span>
                            <span class="analytics-total-secondary"><%= grinder.brewCount %> brews</span>
                        </span>
                    </a>
                <% }); %>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-filter-circle me-1"></i>
                Most Used Brewers
            </div>

            <div class="list-group list-group-flush">
                <% if (topBrewerList.length === 0) { %>
                    <div class="list-group-item text-muted">
                        No brewer data yet.
                    </div>
                <% } %>

                <% topBrewerList.forEach(function (brewer) { %>
                    <a href="/brewers/<%= brewer.id %>/edit" class="list-group-item list-group-item-action d-flex justify-content-between gap-3 analytics-equipment-list-item">
                        <div class="analytics-equipment-list-info">
                            <div class="fw-semibold">
                                <%= brewer.name %><% if (brewer.locationName) { %> (<%= brewer.locationName %>)<% } %>
                            </div>

                            <% if (brewer.brand) { %>
                                <div class="text-muted small"><%= brewer.brand %></div>
                            <% } %>
                        </div>

                        <span class="analytics-total-box">
                            <span class="analytics-total-primary"><%= brewer.totalBeanGrams %>g beans</span>
                            <span class="analytics-total-secondary"><%= brewer.brewCount %> brews</span>
                        </span>
                    </a>
                <% }); %>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <i class="bi bi-clock-history me-1"></i>
        Recent Brews
    </div>

    <div class="table-responsive mobile-card-table-wrap">
        <table class="table table-hover mb-0 align-middle mobile-card-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Coffee</th>
                    <th>Setup</th>
                    <th>Rating</th>
                </tr>
            </thead>

            <tbody>
                <% if (recentBrewList.length === 0) { %>
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            No brew sessions yet.
                        </td>
                    </tr>
                <% } %>

                <% recentBrewList.forEach(function (brew) { %>
                    <tr
                        class="analytics-recent-brew-clickable-row"
                        data-href="/brew-sessions/<%= brew.id %>"
                        tabindex="0"
                        role="link"
                        aria-label="View brew session details for <%= brew.coffeeName %> on <%= brew.brewDate %>">
                        <td data-label="Date"><%= brew.brewDate %></td>

                        <td data-label="Coffee">
                            <div class="fw-semibold"><%= brew.coffeeName %></div>

                            <% if (brew.roasterName) { %>
                                <div class="text-muted small"><%= brew.roasterName %></div>
                            <% } %>
                        </td>

                        <td data-label="Setup">
                            <% if (brew.grinderName || brew.brewerName) { %>
                                <div><%= brew.brewerName || "No brewer" %></div>
                                <div class="text-muted small"><%= brew.grinderName || "No grinder" %></div>
                            <% } else { %>
                                <span class="text-muted">Not set</span>
                            <% } %>
                        </td>

                        <td data-label="Rating">
                            <%- renderRatingStars(brew.overallRating) %>
                        </td>

                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".analytics-recent-brew-clickable-row[data-href], .analytics-cost-clickable-row[data-href]").forEach(function (row) {
            row.addEventListener("click", function (event) {
                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                window.location.href = row.getAttribute("data-href");
            });

            row.addEventListener("keydown", function (event) {
                if (event.key !== "Enter" && event.key !== " ") {
                    return;
                }

                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                event.preventDefault();
                window.location.href = row.getAttribute("data-href");
            });
        });
    });

    const analyticsChartData = <%- JSON.stringify(analyticsChartData) %>;

    const monthlyBrewChartElement = document.getElementById("monthlyBrewChart");

    if (monthlyBrewChartElement) {
        new Chart(monthlyBrewChartElement, {
            type: "bar",
            data: {
                labels: analyticsChartData.monthlyLabels,
                datasets: [
                    {
                        label: "Brews",
                        data: analyticsChartData.monthlyBrewCounts
                    },
                    {
                        label: "Avg Rating",
                        data: analyticsChartData.monthlyAverageRatings,
                        type: "line",
                        yAxisID: "rating"
                    }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    },
                    rating: {
                        beginAtZero: true,
                        max: 5,
                        position: "right",
                        grid: {
                            drawOnChartArea: false
                        }
                    }
                }
            }
        });
    }

    const tastingRadarChartElement = document.getElementById("tastingRadarChart");

    if (tastingRadarChartElement) {
        new Chart(tastingRadarChartElement, {
            type: "radar",
            data: {
                labels: analyticsChartData.tastingLabels,
                datasets: [
                    {
                        label: "Average Score",
                        data: analyticsChartData.tastingAverages
                    }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    r: {
                        beginAtZero: true,
                        min: 0,
                        max: 5,
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });
    }
</script>
