</div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".analytics-recent-brew-clickable-row[data-href], .analytics-cost-clickable-row[data-href], .analytics-inventory-clickable-row[data-href]").forEach(function (row) {
            row.addEventListener("click", function (event) {
                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                window.location.href = row.getAttribute("data-href");
            });

            row.addEventListener("keydown", function (event) {
                if (event.key !== "Enter" && event.key !== " ") {
                    return;
                }

                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                event.preventDefault();
                window.location.href = row.getAttribute("data-href");
            });
        });
    });

    const analyticsChartData = <%- JSON.stringify(analyticsChartData) %>;
    let monthlyBrewChart = null;
    let tastingRadarChart = null;

    function initializeBrewSummaryCharts() {
        const monthlyBrewChartElement = document.getElementById("monthlyBrewChart");

        if (monthlyBrewChartElement && !monthlyBrewChart) {
            monthlyBrewChart = new Chart(monthlyBrewChartElement, {
                type: "bar",
                data: {
                    labels: analyticsChartData.monthlyLabels,
                    datasets: [
                        {
                            label: "Brews",
                            data: analyticsChartData.monthlyBrewCounts
                        },
                        {
                            label: "Avg Rating",
                            data: analyticsChartData.monthlyAverageRatings,
                            type: "line",
                            yAxisID: "rating"
                        }
                    ]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        },
                        rating: {
                            beginAtZero: true,
                            max: 5,
                            position: "right",
                            grid: {
                                drawOnChartArea: false
                            }
                        }
                    }
                }
            });
        }

        const tastingRadarChartElement = document.getElementById("tastingRadarChart");

        if (tastingRadarChartElement && !tastingRadarChart) {
            tastingRadarChart = new Chart(tastingRadarChartElement, {
                type: "radar",
                data: {
                    labels: analyticsChartData.tastingLabels,
                    datasets: [
                        {
                            label: "Average Score",
                            data: analyticsChartData.tastingAverages
                        }
                    ]
                },
                options: {
                    responsive: true,
                    scales: {
                        r: {
                            beginAtZero: true,
                            min: 0,
                            max: 5,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    }
                }
            });
        }
    }

    const brewSummaryPane = document.getElementById("brew-summary-pane");

    if (brewSummaryPane && brewSummaryPane.classList.contains("show")) {
        initializeBrewSummaryCharts();
    }

    const brewSummaryTab = document.getElementById("brew-summary-tab");

    if (brewSummaryTab) {
        brewSummaryTab.addEventListener("shown.bs.tab", function () {
            initializeBrewSummaryCharts();
        });
    }
</script>
