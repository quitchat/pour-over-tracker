<%
    const groups = typeof originMapGroups !== "undefined" ? originMapGroups : [];
    const unmatched = typeof unmatchedBeans !== "undefined" ? unmatchedBeans : [];
    const totalBeans = typeof totalBeanCount !== "undefined" ? totalBeanCount : 0;
    const focusedKey = typeof focusedOriginKey !== "undefined" ? focusedOriginKey : "";
    const focusedBean = typeof focusedBeanId !== "undefined" ? focusedBeanId : null;

    function flagUrl(countryCode) {
        if (!countryCode) {
            return "";
        }

        return `https://flagcdn.com/24x18/${countryCode}.png`;
    }
%>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-globe-americas me-2"></i>
            Origin Map
        </h1>
        <p class="text-muted mb-0">
            Coffee bean origins are geocoded by country plus region first, then fall back to country-level pins. Resolved locations are cached.
        </p>
        <% if (focusedBean && focusedKey) { %>
            <div class="small text-primary mt-1">
                <i class="bi bi-geo-alt-fill me-1"></i>
                Focused from bean detail.
            </div>
        <% } %>
    </div>

    <div class="d-flex gap-2">
        <a href="/analytics" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Analytics
        </a>
        <a href="/coffee-beans" class="btn btn-primary">
            <span class="coffee-bean-icon me-1" aria-hidden="true"></span>
            Beans
        </a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Mapped origin pins</div>
                <div class="display-6 fw-semibold"><%= groups.length %></div>
                <div class="small text-muted">Region pins plus country fallback pins</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Beans in tracker</div>
                <div class="display-6 fw-semibold"><%= totalBeans %></div>
                <div class="small text-muted">Active and inactive coffee beans</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Unmatched origins</div>
                <div class="display-6 fw-semibold"><%= unmatched.length %></div>
                <div class="small text-muted">Could not be geocoded from saved country/origin text</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body p-0">
        <% if (groups.length === 0) { %>
            <div class="p-4 text-center text-muted">
                Add country information to your coffee beans to see origin pins on the map.
            </div>
        <% } else { %>
            <div id="originMap" class="origin-map"></div>
        <% } %>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center gap-2">
                <span>
                    <i class="bi bi-pin-map me-1"></i>
                    Origin Matches
                </span>
                <span class="badge text-bg-light"><%= groups.length %></span>
            </div>
            <div class="list-group list-group-flush origin-match-list">
                <% if (groups.length === 0) { %>
                    <div class="list-group-item text-muted">No mapped origins yet.</div>
                <% } %>

                <% groups.forEach(function (group) { %>
                    <div class="list-group-item<%= focusedKey && group.key === focusedKey ? " border-start border-primary border-3" : "" %>">
                        <div class="d-flex justify-content-between align-items-start gap-3 flex-column flex-md-row">
                            <div>
                                <div class="fw-semibold">
                                    <% if (group.countryCode) { %>
                                        <img class="origin-country-flag" src="<%= flagUrl(group.countryCode) %>" width="24" height="18" alt="<%= group.country %> flag" loading="lazy">
                                    <% } %>
                                    <%= group.country %><% if (group.region) { %> · <%= group.region %><% } %>
                                </div>
                                <div class="small text-muted">
                                    <%= group.matchLevel === "REGION" ? "Region-level match" : "Country-level fallback" %>
                                    · <%= group.beanCount %> bean<%= group.beanCount === 1 ? "" : "s" %>
                                    · <%= group.activeBeanCount %> active
                                </div>
                            </div>

                            <button type="button" class="btn btn-sm btn-outline-primary origin-map-focus-button" data-origin-key="<%= group.key %>">
                                Show on map
                            </button>
                        </div>

                        <div class="mt-2 small origin-map-bean-links">
                            <% group.beans.slice(0, 5).forEach(function (bean, index) { %>
                                <% if (index > 0) { %><span class="text-muted"> · </span><% } %>
                                <span class="origin-map-bean-link-item">
                                    <a href="/coffee-beans/<%= bean.id %>" class="text-decoration-none"><%= bean.beanName %></a>
                                    <% if (group.matchLevel === "COUNTRY" && bean.origin) { %>
                                        <button
                                            type="button"
                                            class="btn btn-link btn-sm p-0 ms-1 align-baseline origin-map-refine-button"
                                            data-bean-id="<%= bean.id %>"
                                            data-bean-name="<%= bean.beanName %>"
                                            data-country="<%= group.country %>"
                                            data-origin="<%= bean.origin %>">
                                            Refine Map Pin
                                        </button>
                                    <% } %>
                                </span>
                            <% }); %>
                            <% if (group.beans.length > 5) { %>
                                <span class="text-muted"> · +<%= group.beans.length - 5 %> more</span>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center gap-2">
                <span>
                    <i class="bi bi-question-circle me-1"></i>
                    Unmatched
                </span>
                <span class="badge text-bg-light"><%= unmatched.length %></span>
            </div>
            <div class="list-group list-group-flush">
                <% if (unmatched.length === 0) { %>
                    <div class="list-group-item text-muted">All origins with country/region text were geocoded.</div>
                <% } %>

                <% unmatched.slice(0, 20).forEach(function (bean) { %>
                    <div class="list-group-item">
                        <div class="fw-semibold">
                            <a href="/coffee-beans/<%= bean.id %>" class="text-decoration-none"><%= bean.beanName %></a>
                        </div>
                        <div class="small text-muted">
                            <% if (bean.roasterName) { %><%= bean.roasterName %> · <% } %>
                            <%= bean.country || "No country" %><% if (bean.origin) { %> · <%= bean.origin %><% } %>
                        </div>
                    </div>
                <% }); %>

                <% if (unmatched.length > 20) { %>
                    <div class="list-group-item small text-muted">+<%= unmatched.length - 20 %> more unmatched beans</div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="refineMapPinModal" tabindex="-1" aria-labelledby="refineMapPinModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="refineMapPinModalLabel">Refine Map Pin</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="refineMapBeanId">
                <input type="hidden" id="refineMapCountry">

                <div class="mb-3">
                    <div class="small text-muted">Bean</div>
                    <div class="fw-semibold" id="refineMapBeanName"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="refineMapSearchText">Map Search / Region</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="refineMapSearchText" autocomplete="off">
                        <span class="input-group-text" id="refineMapCountryLabel"></span>
                    </div>
                    <div class="form-text">
                        This starts from the bean Origin / Region. Edit it to make the map search more specific. The bean record will not be changed.
                    </div>
                </div>

                <div id="refineMapMessage" class="small"></div>

                <div id="refineMapPreview" class="border rounded p-3 mt-3 d-none">
                    <div class="small text-muted mb-1">Preview match</div>
                    <div class="fw-semibold" id="refineMapPreviewTitle"></div>
                    <div class="small text-muted" id="refineMapPreviewMeta"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-outline-primary" id="refineMapPreviewButton">Preview Map Match</button>
                <button type="button" class="btn btn-primary" id="refineMapApplyButton" disabled>Apply</button>
            </div>
        </div>
    </div>
</div>

<style>
    .origin-map {
        border-radius: 0.5rem;
        min-height: 68vh;
        width: 100%;
    }

    .origin-map-popup-title {
        font-weight: 700;
        margin-bottom: 0.25rem;
    }

    .origin-map-popup-meta {
        color: #6c757d;
        font-size: 0.85rem;
        margin-bottom: 0.4rem;
    }

    .origin-map-popup-list {
        margin: 0;
        padding-left: 1rem;
    }

    .origin-map-popup-list li {
        margin-bottom: 0.15rem;
    }

    .origin-match-list {
        max-height: 68vh;
        overflow-y: auto;
    }

    .origin-map-refine-button {
        font-size: inherit;
        text-decoration: none;
    }

    .origin-map-refine-button:hover {
        text-decoration: underline;
    }

    @media (max-width: 767.98px) {
        .origin-map {
            min-height: 26rem;
        }
    }
</style>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script>
    window.originMapGroups = <%- JSON.stringify(groups) %>;
    window.focusedOriginKey = <%- JSON.stringify(focusedKey) %>;
</script>

<% scripts = (typeof scripts !== "undefined" ? scripts : "") + `
<script>
(function () {
    function escapeHtml(value) {
        return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    function setRefineMessage(message, isError) {
        const element = document.getElementById("refineMapMessage");

        if (!element) {
            return;
        }

        element.className = "small " + (isError ? "text-danger" : "text-muted");
        element.textContent = message || "";
    }

    function resetRefinePreview() {
        const preview = document.getElementById("refineMapPreview");
        const applyButton = document.getElementById("refineMapApplyButton");

        if (preview) {
            preview.classList.add("d-none");
        }

        if (applyButton) {
            applyButton.disabled = true;
        }
    }

    async function postJson(url, payload) {
        const response = await fetch(url, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
        });

        return response.json();
    }

    function buildPopupHtml(group) {
        const title = group.region ? group.country + " · " + group.region : group.country;
        const matchText = group.matchLevel === "REGION" ? "Region-level match" : "Country-level fallback";
        const beanItems = group.beans.slice(0, 8).map(function (bean) {
            const roaster = bean.roasterName ? ' <span class="text-muted">(' + escapeHtml(bean.roasterName) + ')</span>' : '';
            return '<li><a href="/coffee-beans/' + bean.id + '">' + escapeHtml(bean.beanName) + '</a>' + roaster + '</li>';
        }).join("");
        const extraCount = group.beans.length > 8 ? '<div class="small text-muted mt-1">+' + (group.beans.length - 8) + ' more</div>' : '';

        return '<div class="origin-map-popup">' +
            '<div class="origin-map-popup-title">' + escapeHtml(title) + '</div>' +
            '<div class="origin-map-popup-meta">' + matchText + ' · ' + group.beanCount + ' bean' + (group.beanCount === 1 ? '' : 's') + '</div>' +
            '<ul class="origin-map-popup-list">' + beanItems + '</ul>' +
            extraCount +
            '</div>';
    }

    document.addEventListener("DOMContentLoaded", function () {
        const mapElement = document.getElementById("originMap");
        const groups = window.originMapGroups || [];
        const modalElement = document.getElementById("refineMapPinModal");
        const modal = modalElement && window.bootstrap ? new bootstrap.Modal(modalElement) : null;
        const previewButton = document.getElementById("refineMapPreviewButton");
        const applyButton = document.getElementById("refineMapApplyButton");
        const searchInput = document.getElementById("refineMapSearchText");

        document.querySelectorAll(".origin-map-refine-button").forEach(function (button) {
            button.addEventListener("click", function () {
                const beanIdInput = document.getElementById("refineMapBeanId");
                const countryInput = document.getElementById("refineMapCountry");
                const beanNameElement = document.getElementById("refineMapBeanName");
                const countryLabel = document.getElementById("refineMapCountryLabel");

                if (beanIdInput) {
                    beanIdInput.value = button.getAttribute("data-bean-id") || "";
                }

                if (countryInput) {
                    countryInput.value = button.getAttribute("data-country") || "";
                }

                if (beanNameElement) {
                    beanNameElement.textContent = button.getAttribute("data-bean-name") || "";
                }

                if (countryLabel) {
                    countryLabel.textContent = button.getAttribute("data-country") || "";
                }

                if (searchInput) {
                    searchInput.value = button.getAttribute("data-origin") || "";
                }

                resetRefinePreview();
                setRefineMessage("", false);

                if (modal) {
                    modal.show();
                    setTimeout(function () {
                        if (searchInput) {
                            searchInput.focus();
                            searchInput.select();
                        }
                    }, 150);
                }
            });
        });

        if (searchInput) {
            searchInput.addEventListener("input", function () {
                resetRefinePreview();
                setRefineMessage("", false);
            });
        }

        if (previewButton) {
            previewButton.addEventListener("click", async function () {
                const beanId = document.getElementById("refineMapBeanId") ? document.getElementById("refineMapBeanId").value : "";
                const country = document.getElementById("refineMapCountry") ? document.getElementById("refineMapCountry").value : "";
                const searchText = searchInput ? searchInput.value : "";

                resetRefinePreview();
                previewButton.disabled = true;
                previewButton.textContent = "Previewing...";
                setRefineMessage("Checking map match...", false);

                try {
                    const result = await postJson("/analytics/origin-map/refine/preview", {
                        beanId: beanId,
                        country: country,
                        searchText: searchText
                    });

                    if (!result.ok) {
                        setRefineMessage(result.message || "No match found.", true);
                        return;
                    }

                    const preview = document.getElementById("refineMapPreview");
                    const title = document.getElementById("refineMapPreviewTitle");
                    const meta = document.getElementById("refineMapPreviewMeta");

                    if (title) {
                        title.textContent = result.preview.region ? result.preview.country + " · " + result.preview.region : result.preview.country;
                    }

                    if (meta) {
                        meta.textContent = result.preview.displayName + " (" + Number(result.preview.lat).toFixed(4) + ", " + Number(result.preview.lng).toFixed(4) + ")";
                    }

                    if (preview) {
                        preview.classList.remove("d-none");
                    }

                    if (applyButton) {
                        applyButton.disabled = false;
                    }

                    setRefineMessage("Preview found. Apply it to update your map pin cache.", false);
                } catch (error) {
                    setRefineMessage("Unable to preview the map match right now.", true);
                } finally {
                    previewButton.disabled = false;
                    previewButton.textContent = "Preview Map Match";
                }
            });
        }

        if (applyButton) {
            applyButton.addEventListener("click", async function () {
                const beanId = document.getElementById("refineMapBeanId") ? document.getElementById("refineMapBeanId").value : "";
                const country = document.getElementById("refineMapCountry") ? document.getElementById("refineMapCountry").value : "";
                const searchText = searchInput ? searchInput.value : "";

                applyButton.disabled = true;
                applyButton.textContent = "Applying...";
                setRefineMessage("Saving refined map pin...", false);

                try {
                    const result = await postJson("/analytics/origin-map/refine/apply", {
                        beanId: beanId,
                        country: country,
                        searchText: searchText
                    });

                    if (!result.ok) {
                        setRefineMessage(result.message || "Could not save the refined map pin.", true);
                        applyButton.disabled = false;
                        return;
                    }

                    window.location.href = "/analytics/origin-map?beanId=" + encodeURIComponent(beanId);
                } catch (error) {
                    setRefineMessage("Unable to save the refined map pin right now.", true);
                    applyButton.disabled = false;
                } finally {
                    applyButton.textContent = "Apply";
                }
            });
        }

        if (!mapElement || !window.L || groups.length === 0) {
            return;
        }

        const map = L.map(mapElement, {
            worldCopyJump: true
        }).setView([12, 10], 2);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 10,
            attribution: "&copy; OpenStreetMap contributors"
        }).addTo(map);

        const markerMap = {};
        const bounds = [];

        groups.forEach(function (group) {
            const marker = L.marker([group.lat, group.lng]).addTo(map);
            marker.bindPopup(buildPopupHtml(group), {
                maxWidth: 340
            });
            markerMap[group.key] = marker;
            bounds.push([group.lat, group.lng]);
        });

        const focusedKey = window.focusedOriginKey || "";
        const focusedMarker = focusedKey ? markerMap[focusedKey] : null;

        if (focusedMarker) {
            map.setView(focusedMarker.getLatLng(), 6);
            focusedMarker.openPopup();
        } else if (bounds.length === 1) {
            map.setView(bounds[0], 5);
        } else if (bounds.length > 1) {
            map.fitBounds(bounds, {
                padding: [24, 24],
                maxZoom: 5
            });
        }

        document.querySelectorAll(".origin-map-focus-button").forEach(function (button) {
            button.addEventListener("click", function () {
                const key = button.getAttribute("data-origin-key");
                const marker = key ? markerMap[key] : null;

                if (!marker) {
                    return;
                }

                map.setView(marker.getLatLng(), 6);
                marker.openPopup();
                mapElement.scrollIntoView({ behavior: "smooth", block: "center" });
            });
        });
    });
})();
</script>
`; %>
