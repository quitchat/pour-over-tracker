<div class="mb-4">
    <h1 class="h3 mb-1">
        <i class="bi bi-cup-hot me-2"></i>
        Pour-Over Coffee Tracker
    </h1>
    <p class="text-muted mb-0">
        Track beans, grinders, brewers, recipes, tasting scores, and brew results.
    </p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">
                    <i class="bi bi-bean me-1"></i>
                    Coffee Beans
                </div>
                <div class="display-6"><%= stats.coffeeBeanCount %></div>
                <a href="/coffee-beans" class="stretched-link text-decoration-none">View beans</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">
                    <i class="bi bi-gear me-1"></i>
                    Grinders
                </div>
                <div class="display-6"><%= stats.grinderCount %></div>
                <a href="/grinders" class="stretched-link text-decoration-none">View grinders</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">
                    <i class="bi bi-funnel me-1"></i>
                    Brewers
                </div>
                <div class="display-6"><%= stats.brewerCount %></div>
                <a href="/brewers" class="stretched-link text-decoration-none">View brewers</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">
                    <i class="bi bi-journal-text me-1"></i>
                    Brew Sessions
                </div>
                <div class="display-6"><%= stats.brewSessionCount %></div>
                <a href="/brew-sessions" class="stretched-link text-decoration-none">View sessions</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-clock-history me-1"></i>
                    Recent Brew Sessions
                </span>

                <a href="/brew-sessions/new" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>
                    Add Brew
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Bean</th>
                            <th>Brewer</th>
                            <th>Dose</th>
                            <th>Yield</th>
                            <th>Ratio</th>
                            <th>Rating</th>
                            <th style="width: 90px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (recentSessions.length === 0) { %>
                            <tr>
                                <td colspan="8" class="text-muted text-center py-4">
                                    No brew sessions yet.
                                </td>
                            </tr>
                        <% } %>

                        <% recentSessions.forEach(function (session) { %>
                            <tr>
                                <td><%= session.brewDate %></td>
                                <td><%= session.beanName %></td>
                                <td><%= session.brewerName %></td>
                                <td><%= session.coffeeDoseGrams %>g</td>
                                <td><%= session.totalYieldGrams %></td>
                                <td>1:<%= session.brewRatio %></td>
                                <td>
                                    <% if (session.overallRating) { %>
                                        <i class="bi bi-star-fill me-1"></i>
                                        <%= session.overallRating %>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/brew-sessions/<%= session.id %>" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>
                                        View
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-speedometer2 me-1"></i>
                Summary
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <div class="text-muted small">
                        <i class="bi bi-star me-1"></i>
                        Average Rating
                    </div>
                    <div class="display-6">
                        <%= stats.averageRating || "-" %>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">
                        <i class="bi bi-journal-check me-1"></i>
                        Total Brew Sessions
                    </div>
                    <div class="h4 mb-0"><%= stats.brewSessionCount %></div>
                </div>

                <p class="text-muted mb-0">
                    As you add more brews, this dashboard will help you compare beans,
                    recipes, and tasting results.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <i class="bi bi-trophy me-1"></i>
        Top Rated Brew Sessions
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Bean</th>
                    <th>Grinder</th>
                    <th>Brewer</th>
                    <th>Yield</th>
                    <th>Ratio</th>
                    <th>Time</th>
                    <th>Rating</th>
                    <th>Repeat?</th>
                    <th style="width: 90px;">Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (topRatedSessions.length === 0) { %>
                    <tr>
                        <td colspan="10" class="text-muted text-center py-4">
                            No rated brew sessions yet.
                        </td>
                    </tr>
                <% } %>

                <% topRatedSessions.forEach(function (session) { %>
                    <tr>
                        <td><%= session.brewDate %></td>
                        <td><%= session.beanName %></td>
                        <td><%= session.grinderName %></td>
                        <td><%= session.brewerName %></td>
                        <td><%= session.totalYieldGrams %></td>
                        <td>1:<%= session.brewRatio %></td>
                        <td><%= session.totalBrewTime %></td>
                        <td>
                            <i class="bi bi-star-fill me-1"></i>
                            <%= session.overallRating %>
                        </td>
                        <td>
                            <% if (session.wouldRepeat) { %>
                                <i class="bi bi-check-circle me-1"></i>
                                Yes
                            <% } else { %>
                                <i class="bi bi-x-circle me-1"></i>
                                No
                            <% } %>
                        </td>
                        <td>
                            <a href="/brew-sessions/<%= session.id %>" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>
                                View
                            </a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>