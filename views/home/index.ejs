<%
    const dashboardValue = typeof dashboard !== "undefined" ? dashboard : {
        totalBeans: 0,
        activeBeans: 0,
        inactiveBeans: 0,
        totalGrinders: 0,
        totalBrewers: 0,
        totalBrews: 0,
        recentBrews: [],
        topBeans: []
    };

    const recentBrewList = dashboardValue.recentBrews || [];
    const topBeanList = dashboardValue.topBeans || [];

    function renderRatingStars(value, emptyText = "Not rated") {
        if (value === null || value === undefined || value === "") {
            return `<span class="text-muted">${emptyText}</span>`;
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return `<span class="text-muted">${emptyText}</span>`;
        }

        const clampedValue = Math.max(0, Math.min(5, numericValue));
        const displayValue = Number.isInteger(clampedValue) ? clampedValue.toFixed(0) : clampedValue.toFixed(1);
        let html = `<span class="readonly-rating-display"><span class="readonly-rating-stars rating-stars-gold" aria-label="${displayValue} out of 5 stars">`;

        for (let index = 1; index <= 5; index++) {
            if (clampedValue >= index) {
                html += `<i class="bi bi-star-fill"></i>`;
            } else if (clampedValue >= index - 0.5) {
                html += `<i class="bi bi-star-half"></i>`;
            } else {
                html += `<i class="bi bi-star"></i>`;
            }
        }

        html += `</span>`;
        html += `<span class="text-muted small readonly-rating-value">${displayValue}</span></span>`;
        return html;
    }
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-speedometer2 me-2"></i>
            Dashboard
        </h1>
        <p class="text-muted mb-0">
            Quick overview of your coffee beans, equipment, and recent brews.
        </p>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a href="/brew-sessions/new" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            Add Brew
        </a>

        <a href="/coffee-beans/new" class="btn btn-outline-primary">
            <i class="bi bi-cup-hot me-1"></i>
            Add Bean
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <a href="/brew-sessions" class="card h-100 text-decoration-none text-reset dashboard-summary-card">
            <div class="card-body">
                <div class="text-muted small">Total Brews</div>
                <div class="display-6 fw-semibold"><%= dashboardValue.totalBrews %></div>
                <div class="small text-primary">View brews</div>
            </div>
        </a>
    </div>

    <div class="col-6 col-lg-3">
        <a href="/coffee-beans" class="card h-100 text-decoration-none text-reset dashboard-summary-card">
            <div class="card-body">
                <div class="text-muted small">Coffee Beans</div>
                <div class="display-6 fw-semibold"><%= dashboardValue.totalBeans %></div>
                <div class="text-muted small">
                    <%= dashboardValue.activeBeans %> active / <%= dashboardValue.inactiveBeans %> inactive
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-lg-3">
        <a href="/grinders" class="card h-100 text-decoration-none text-reset dashboard-summary-card">
            <div class="card-body">
                <div class="text-muted small">Grinders</div>
                <div class="display-6 fw-semibold"><%= dashboardValue.totalGrinders %></div>
                <div class="small text-primary">Manage grinders</div>
            </div>
        </a>
    </div>

    <div class="col-6 col-lg-3">
        <a href="/brewers" class="card h-100 text-decoration-none text-reset dashboard-summary-card">
            <div class="card-body">
                <div class="text-muted small">Brewers</div>
                <div class="display-6 fw-semibold"><%= dashboardValue.totalBrewers %></div>
                <div class="small text-primary">Manage brewers</div>
            </div>
        </a>
    </div>
</div>

<style>
    .recent-brew-clickable-row {
        cursor: pointer;
    }

    .recent-brew-clickable-row:focus {
        outline: 2px solid var(--bs-primary);
        outline-offset: -2px;
    }
</style>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-clock-history me-1"></i>
                    Recent Brews
                </span>

                <a href="/brew-sessions" class="btn btn-sm btn-outline-primary">
                    View All
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Coffee</th>
                            <th>Setup</th>
                            <th>Rating</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% if (recentBrewList.length === 0) { %>
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No brew sessions yet.
                                </td>
                            </tr>
                        <% } %>

                        <% recentBrewList.forEach(function (brew) { %>
                            <tr
                                class="recent-brew-clickable-row"
                                data-href="/brew-sessions/<%= brew.id %>"
                                tabindex="0"
                                role="link"
                                aria-label="View brew session details for <%= brew.beanName %> on <%= brew.brewDate %>">
                                <td><%= brew.brewDate %></td>

                                <td>
                                    <div class="fw-semibold"><%= brew.beanName %></div>

                                    <% if (brew.roasterName) { %>
                                        <div class="text-muted small"><%= brew.roasterName %></div>
                                    <% } %>
                                </td>

                                <td>
                                    <% if (brew.brewerName || brew.grinderName) { %>
                                        <div><%= brew.brewerName || "No brewer" %></div>
                                        <div class="text-muted small"><%= brew.grinderName || "No grinder" %></div>
                                    <% } else { %>
                                        <span class="text-muted">Not set</span>
                                    <% } %>
                                </td>

                                <td>
                                    <%- renderRatingStars(brew.overallRating) %>
                                </td>

                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-cup-hot me-1"></i>
                Most Brewed Beans
            </div>

            <div class="list-group list-group-flush">
                <% if (topBeanList.length === 0) { %>
                    <div class="list-group-item text-muted">
                        No bean data yet.
                    </div>
                <% } %>

                <% topBeanList.forEach(function (bean) { %>
                    <a href="/coffee-beans/<%= bean.id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">
                                <%= bean.beanName %>

                                <% if (!bean.isActive) { %>
                                    <span class="badge text-bg-secondary ms-1">Inactive</span>
                                <% } %>
                            </div>

                            <% if (bean.roasterName) { %>
                                <div class="text-muted small"><%= bean.roasterName %></div>
                            <% } %>
                        </div>

                        <span class="badge text-bg-light border">
                            <%= bean.brewCount %>
                        </span>
                    </a>
                <% }); %>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".recent-brew-clickable-row[data-href]").forEach(function (row) {
            row.addEventListener("click", function (event) {
                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                window.location.href = row.getAttribute("data-href");
            });

            row.addEventListener("keydown", function (event) {
                if (event.key !== "Enter" && event.key !== " ") {
                    return;
                }

                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                event.preventDefault();
                window.location.href = row.getAttribute("data-href");
            });
        });
    });
</script>
