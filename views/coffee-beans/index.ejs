<%
    const beans = typeof coffeeBeans !== "undefined" ? coffeeBeans : [];
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-cup-hot me-2"></i>
            Coffee Beans
        </h1>
        <p class="text-muted mb-0">
            Manage beans and start brew sessions from active beans.
        </p>
    </div>

    <a href="/coffee-beans/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Add Coffee Bean
    </a>
</div>

<style>
    .bean-list-card {
        overflow: visible;
    }

    .bean-table-responsive {
        overflow: visible !important;
    }

    .bean-list-table td {
        vertical-align: middle;
    }

    .bean-list-table .dropdown {
        position: static;
    }

    .bean-name-link {
        font-weight: 600;
        text-decoration: none;
    }

    .bean-name-link:hover {
        text-decoration: underline;
    }

    .bean-secondary-line {
        font-size: 0.875rem;
        color: var(--bs-secondary-color);
    }

    /*
        Do not use opacity on the whole inactive row.
        It also makes the dropdown menu transparent.
    */
    .bean-muted-row {
        background-color: rgba(108, 117, 125, 0.04);
    }

    .bean-muted-row .bean-name-link,
    .bean-muted-row .bean-secondary-line,
    .bean-muted-row td:not(.bean-actions-cell) {
        color: var(--bs-secondary-color);
    }

    .bean-muted-row .dropdown-menu {
        color: var(--bs-body-color);
        opacity: 1;
    }

    .bean-muted-row .dropdown-item {
        color: var(--bs-dropdown-link-color);
        opacity: 1;
    }

    .bean-muted-row .dropdown-item.text-success {
        color: var(--bs-success) !important;
    }

    .bean-muted-row .dropdown-item.text-danger {
        color: var(--bs-danger) !important;
    }

    .bean-actions-cell {
        width: 190px;
        white-space: nowrap;
    }

    .bean-status-badge {
        font-size: 0.72rem;
        vertical-align: middle;
    }

    .bean-mobile-label {
        display: none;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.15rem;
    }

    @media (max-width: 767.98px) {
        .bean-table-responsive {
            overflow-x: auto !important;
        }

        .bean-list-table thead {
            display: none;
        }

        .bean-list-table,
        .bean-list-table tbody,
        .bean-list-table tr,
        .bean-list-table td {
            display: block;
            width: 100%;
        }

        .bean-list-table tr {
            border-bottom: 1px solid var(--bs-border-color);
            padding: 0.75rem 0;
        }

        .bean-list-table td {
            border: 0;
            padding: 0.35rem 1rem;
        }

        .bean-mobile-label {
            display: block;
        }

        .bean-actions-cell {
            white-space: normal;
        }
    }
</style>

<div class="card bean-list-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-list-ul me-1"></i>
            Beans
        </span>

        <span class="text-muted small"><%= beans.length %> bean(s)</span>
    </div>

    <div class="table-responsive bean-table-responsive">
        <table class="table table-hover mb-0 align-middle bean-list-table">
            <thead>
                <tr>
                    <th>Coffee</th>
                    <th>Origin / Process</th>
                    <th>Roast</th>
                    <th class="text-center">Brews</th>
                    <th class="text-end bean-actions-cell">Actions</th>
                </tr>
            </thead>

            <tbody>
                <% if (beans.length === 0) { %>
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No coffee beans yet.
                        </td>
                    </tr>
                <% } %>

                <% beans.forEach(function (bean) { %>
                    <tr class="<%= bean.isActive ? "" : "bean-muted-row" %>">
                        <td>
                            <div class="bean-mobile-label">Coffee</div>

                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <a href="/coffee-beans/<%= bean.id %>" class="bean-name-link">
                                    <%= bean.beanName %>
                                </a>

                                <% if (bean.isActive) { %>
                                    <span class="badge text-bg-success bean-status-badge">
                                        Active
                                    </span>
                                <% } else { %>
                                    <span class="badge text-bg-secondary bean-status-badge">
                                        Inactive
                                    </span>
                                <% } %>
                            </div>

                            <div class="bean-secondary-line">
                                <% if (bean.roasterName) { %>
                                    <i class="bi bi-shop me-1"></i>
                                    <%= bean.roasterName %>
                                <% } else { %>
                                    <span>No roaster</span>
                                <% } %>

                                <% if (!bean.isActive && bean.deactivatedAt) { %>
                                    <span class="ms-2">
                                        Deactivated <%= bean.deactivatedAt %>
                                    </span>
                                <% } %>
                            </div>
                        </td>

                        <td>
                            <div class="bean-mobile-label">Origin / Process</div>

                            <% if (bean.origin || bean.process) { %>
                                <div>
                                    <%= bean.origin || "-" %>
                                </div>

                                <div class="bean-secondary-line">
                                    <%= bean.process || "Process not set" %>
                                </div>
                            <% } else { %>
                                <span class="text-muted">Not set</span>
                            <% } %>
                        </td>

                        <td>
                            <div class="bean-mobile-label">Roast</div>

                            <% if (bean.roastLevel || bean.roastDate) { %>
                                <div>
                                    <%= bean.roastLevel || "-" %>
                                </div>

                                <div class="bean-secondary-line">
                                    <%= bean.roastDate || "No roast date" %>
                                </div>
                            <% } else { %>
                                <span class="text-muted">Not set</span>
                            <% } %>
                        </td>

                        <td class="text-md-center">
                            <div class="bean-mobile-label">Brews</div>

                            <a href="/coffee-beans/<%= bean.id %>" class="text-decoration-none">
                                <span class="badge text-bg-light border">
                                    <%= bean.brewSessionCount %>
                                </span>
                            </a>
                        </td>

                        <td class="text-md-end bean-actions-cell">
                            <div class="bean-mobile-label">Actions</div>

                            <div class="d-inline-flex gap-2 align-items-center">
                                <% if (bean.isActive) { %>
                                    <a href="/brew-sessions/new?coffeeBeanId=<%= bean.id %>" class="btn btn-sm btn-success">
                                        <i class="bi bi-plus-circle me-1"></i>
                                        Brew
                                    </a>
                                <% } %>

                                <div class="dropdown">
                                    <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false">
                                        More
                                    </button>

                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" href="/coffee-beans/<%= bean.id %>">
                                                <i class="bi bi-eye me-2"></i>
                                                View Details
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item" href="/coffee-beans/<%= bean.id %>/edit">
                                                <i class="bi bi-pencil-square me-2"></i>
                                                Edit
                                            </a>
                                        </li>

                                        <li>
                                            <hr class="dropdown-divider">
                                        </li>

                                        <% if (bean.isActive) { %>
                                            <li>
                                                <form method="post" action="/coffee-beans/<%= bean.id %>/deactivate" onsubmit="return confirm('Deactivate this coffee bean? Historical brew sessions will stay available.');">
                                                    <button type="submit" class="dropdown-item text-danger">
                                                        <i class="bi bi-archive me-2"></i>
                                                        Deactivate
                                                    </button>
                                                </form>
                                            </li>
                                        <% } else { %>
                                            <li>
                                                <form method="post" action="/coffee-beans/<%= bean.id %>/reactivate">
                                                    <button type="submit" class="dropdown-item text-success">
                                                        <i class="bi bi-arrow-counterclockwise me-2"></i>
                                                        Reactivate
                                                    </button>
                                                </form>
                                            </li>
                                        <% } %>
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>