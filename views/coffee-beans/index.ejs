<%
    const beans = typeof coffeeBeans !== "undefined" ? coffeeBeans : [];
    const pageInfo = typeof pagination !== "undefined" ? pagination : { currentPage: 1, totalPages: 1, totalItems: beans.length, hasPreviousPage: false, hasNextPage: false, previousPage: 1, nextPage: 1 };
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <span class="coffee-bean-icon me-2" aria-hidden="true"></span>
            Coffee Beans
        </h1>
        <p class="text-muted mb-0">
            Manage beans and start brew sessions from active beans.
        </p>
    </div>

    <a href="/coffee-beans/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Add Bean
    </a>
</div>

<style>
    .bean-list-card {
        overflow: visible;
    }

    .bean-table-responsive {
        overflow: visible !important;
    }

    .bean-list-table td {
        vertical-align: middle;
    }

    .bean-list-table .dropdown {
        position: static;
    }

    .bean-name-link {
        font-weight: 600;
        text-decoration: none;
    }

    .bean-name-link:hover {
        text-decoration: underline;
    }

    .bean-secondary-line {
        font-size: 0.875rem;
        color: var(--bs-secondary-color);
    }

    /*
        Do not use opacity on the whole inactive row.
        It also makes the dropdown menu transparent.
    */
    .bean-muted-row {
        background-color: rgba(108, 117, 125, 0.04);
    }

    .bean-muted-row .bean-name-link,
    .bean-muted-row .bean-secondary-line,
    .bean-muted-row td:not(.bean-actions-cell) {
        color: var(--bs-secondary-color);
    }

    .bean-muted-row .dropdown-menu {
        color: var(--bs-body-color);
        opacity: 1;
    }

    .bean-muted-row .dropdown-item {
        color: var(--bs-dropdown-link-color);
        opacity: 1;
    }

    .bean-muted-row .dropdown-item.text-success {
        color: var(--bs-success) !important;
    }

    .bean-muted-row .dropdown-item.text-danger {
        color: var(--bs-danger) !important;
    }

    .bean-actions-cell {
        width: 120px;
        white-space: nowrap;
    }

    .bean-brew-action {
        min-width: 5rem;
    }

    .bean-status-badge {
        font-size: 0.72rem;
        vertical-align: middle;
    }

    .bean-clickable-row {
        cursor: pointer;
    }

    .bean-clickable-row:focus {
        outline: 2px solid var(--bs-primary);
        outline-offset: -2px;
    }

    .bean-thumbnail {
        width: 56px;
        height: 56px;
        object-fit: cover;
        border-radius: 0.5rem;
        border: 1px solid var(--bs-border-color);
        flex: 0 0 auto;
    }

    .bean-photo-button {
        border: 0;
        padding: 0;
        background: transparent;
        line-height: 0;
        border-radius: 0.5rem;
        flex: 0 0 auto;
    }

    .bean-photo-button:hover .bean-thumbnail,
    .bean-photo-button:focus .bean-thumbnail {
        border-color: var(--bs-primary);
        box-shadow: 0 0 0 0.15rem rgba(var(--bs-primary-rgb), 0.2);
    }

    .bean-photo-modal-image {
        max-height: 82vh;
        object-fit: contain;
    }

    .bean-thumbnail-placeholder {
        width: 56px;
        height: 56px;
        border-radius: 0.5rem;
        border: 1px solid var(--bs-border-color);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--bs-secondary-color);
        background-color: var(--bs-tertiary-bg);
        flex: 0 0 auto;
    }

    .bean-mobile-label {
        display: none;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.15rem;
    }

    @media (max-width: 767.98px) {
        .bean-table-responsive {
            overflow-x: visible !important;
        }

        .bean-list-table thead {
            display: none;
        }

        .bean-list-table {
            min-width: 0 !important;
        }

        .bean-list-table,
        .bean-list-table tbody,
        .bean-list-table tr,
        .bean-list-table td {
            display: block;
            width: 100%;
        }

        .bean-list-table tr {
            border-bottom: 1px solid var(--bs-border-color);
            padding: 0.75rem 0;
        }

        .bean-list-table td {
            border: 0;
            padding: 0.35rem 1rem;
        }

        .bean-mobile-label {
            display: block;
        }

        .bean-actions-cell {
            white-space: normal;
        }

        .bean-brew-action {
            width: 100%;
            padding: 0.65rem 1rem;
            font-size: 1rem;
        }
    }
</style>

<div class="card bean-list-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-list-ul me-1"></i>
            Beans
        </span>

        <span class="text-muted small"><%= pageInfo.totalItems %> bean(s)</span>
    </div>

    <div class="table-responsive bean-table-responsive">
        <table class="table table-hover mb-0 align-middle bean-list-table">
            <thead>
                <tr>
                    <th>Coffee</th>
                    <th>Origin / Process</th>
                    <th>Roast</th>
                    <th>Bean Rating</th>
                    <th class="text-center">Brews</th>
                    <th class="text-end bean-actions-cell" aria-label="Bean actions"></th>
                </tr>
            </thead>

            <tbody>
                <% if (beans.length === 0) { %>
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No coffee beans yet.
                        </td>
                    </tr>
                <% } %>

                <% beans.forEach(function (bean) { %>
                    <tr
                        class="bean-clickable-row <%= bean.isActive ? "" : "bean-muted-row" %>"
                        data-href="/coffee-beans/<%= bean.id %>"
                        tabindex="0"
                        role="link"
                        aria-label="View details for <%= bean.beanName %>">
                        <td>
                            <div class="bean-mobile-label">Coffee</div>

                            <div class="d-flex align-items-center gap-3">
                                <% if (bean.bagImageUrl) { %>
                                    <button
                                        type="button"
                                        class="bean-photo-button"
                                        data-bean-photo-src="<%= bean.bagImageUrl %>"
                                        data-bean-photo-title="<%= bean.roasterName ? bean.roasterName + ' - ' : '' %><%= bean.beanName %>"
                                        aria-label="Enlarge picture for <%= bean.beanName %>">
                                        <img
                                            src="<%= bean.bagImageUrl %>"
                                            alt="<%= bean.beanName %> picture"
                                            class="bean-thumbnail">
                                    </button>
                                <% } else { %>
                                    <div class="bean-thumbnail-placeholder" aria-hidden="true">
                                        <i class="bi bi-image"></i>
                                    </div>
                                <% } %>

                                <div class="min-width-0">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <a href="/coffee-beans/<%= bean.id %>" class="bean-name-link">
                                            <%= bean.beanName %>
                                        </a>

                                        <% if (bean.isActive) { %>
                                            <span class="badge text-bg-success bean-status-badge">
                                                Active
                                            </span>
                                        <% } else { %>
                                            <span class="badge text-bg-secondary bean-status-badge">
                                                Inactive
                                            </span>
                                        <% } %>
                                    </div>

                                    <div class="bean-secondary-line">
                                        <% if (bean.roasterName) { %>
                                            <i class="bi bi-shop me-1"></i>
                                            <%= bean.roasterName %>
                                        <% } else { %>
                                            <span>No roaster</span>
                                        <% } %>

                                        <% if (!bean.isActive && bean.deactivatedAt) { %>
                                            <span class="ms-2">
                                                Deactivated <%= bean.deactivatedAt %>
                                            </span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <div class="bean-mobile-label">Origin / Process</div>

                            <% if (bean.origin || bean.process) { %>
                                <div>
                                    <%- getOriginCountryFlagHtml(bean.origin) %><%= bean.origin || "-" %>
                                </div>

                                <div class="bean-secondary-line">
                                    <%= bean.process || "Process not set" %>
                                </div>
                            <% } else { %>
                                <span class="text-muted">Not set</span>
                            <% } %>
                        </td>

                        <td>
                            <div class="bean-mobile-label">Roast</div>

                            <% if (bean.roastLevel) { %>
                                <div>
                                    <%= bean.roastLevel %>
                                </div>
                            <% } else { %>
                                <span class="text-muted">Not set</span>
                            <% } %>
                        </td>

                        <td>
                            <div class="bean-mobile-label">Bean Rating</div>

                            <% if (bean.rating) { %>
                                <% const beanRatingValue = Number(bean.rating); %>
                                <span class="bean-rating-stars" style="white-space: nowrap;" aria-label="<%= bean.rating %> out of 5 stars">
                                    <% for (let i = 1; i <= 5; i++) { %><% if (beanRatingValue >= i) { %><i class="bi bi-star-fill" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i><% } else if (beanRatingValue >= i - 0.5) { %><i class="bi bi-star-half" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i><% } else { %><i class="bi bi-star" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i><% } %><% } %>
                                </span>
                            <% } else { %>
                                <span class="text-muted">Not rated</span>
                            <% } %>
                        </td>

                        <td class="text-md-center">
                            <div class="bean-mobile-label">Brews</div>

                            <% const brewCount = Number(bean.brewSessionCount || 0); %>
                            <% const totalGramsBrewed = bean.totalGramsBrewed || "0.0"; %>
                            <% if (brewCount > 0) { %>
                                <a href="/coffee-beans/<%= bean.id %>" class="text-decoration-none text-body">
                                    <span class="fw-semibold"><%= brewCount %> <%= brewCount === 1 ? "brew" : "brews" %></span>
                                    <span class="text-muted mx-1">·</span>
                                    <span><%= totalGramsBrewed %>g</span>
                                </a>
                            <% } else { %>
                                <span class="text-muted">No brews yet</span>
                            <% } %>
                        </td>

                        <td class="text-md-end bean-actions-cell">

                            <div class="d-inline-flex gap-2 align-items-center w-100 w-md-auto">
                                <% if (bean.isActive) { %>
                                    <a href="/brew-sessions/new?coffeeBeanId=<%= bean.id %>" class="btn btn-sm btn-success bean-brew-action">
                                        <i class="bi bi-plus-circle me-1"></i>
                                        Brew
                                    </a>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<% if (pageInfo.totalPages > 1) { %>
    <nav class="mt-3" aria-label="Coffee bean pagination">
        <ul class="pagination justify-content-center mb-0">
            <li class="page-item <%= pageInfo.hasPreviousPage ? "" : "disabled" %>">
                <a class="page-link" href="/coffee-beans?page=<%= pageInfo.previousPage %>">Previous</a>
            </li>

            <% for (let pageNumber = 1; pageNumber <= pageInfo.totalPages; pageNumber++) { %>
                <li class="page-item <%= pageNumber === pageInfo.currentPage ? "active" : "" %>">
                    <a class="page-link" href="/coffee-beans?page=<%= pageNumber %>"><%= pageNumber %></a>
                </li>
            <% } %>

            <li class="page-item <%= pageInfo.hasNextPage ? "" : "disabled" %>">
                <a class="page-link" href="/coffee-beans?page=<%= pageInfo.nextPage %>">Next</a>
            </li>
        </ul>
    </nav>
<% } %>

<div class="modal fade" id="beanPhotoModal" tabindex="-1" aria-labelledby="beanPhotoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="beanPhotoModalLabel">Bean Picture</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center bg-body-tertiary">
                <img src="" alt="Bean picture enlarged" class="img-fluid rounded bean-photo-modal-image" id="beanPhotoModalImage">
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const beanPhotoModalElement = document.getElementById("beanPhotoModal");
        const beanPhotoModalImage = document.getElementById("beanPhotoModalImage");
        const beanPhotoModalLabel = document.getElementById("beanPhotoModalLabel");
        const beanPhotoModal = beanPhotoModalElement ? new bootstrap.Modal(beanPhotoModalElement) : null;

        document.querySelectorAll("[data-bean-photo-src]").forEach(function (button) {
            button.addEventListener("click", function (event) {
                event.preventDefault();
                event.stopPropagation();

                if (!beanPhotoModal || !beanPhotoModalImage) {
                    return;
                }

                const imageUrl = button.getAttribute("data-bean-photo-src") || "";
                const title = button.getAttribute("data-bean-photo-title") || "Bean Picture";

                beanPhotoModalImage.src = imageUrl;
                beanPhotoModalImage.alt = title + " picture";

                if (beanPhotoModalLabel) {
                    beanPhotoModalLabel.textContent = title;
                }

                beanPhotoModal.show();
            });
        });

        document.querySelectorAll(".bean-clickable-row[data-href]").forEach(function (row) {
            row.addEventListener("click", function (event) {
                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                window.location.href = row.getAttribute("data-href");
            });

            row.addEventListener("keydown", function (event) {
                if (event.key !== "Enter" && event.key !== " ") {
                    return;
                }

                if (event.target.closest("a, button, input, select, textarea, label, form, .dropdown, .dropdown-menu")) {
                    return;
                }

                event.preventDefault();
                window.location.href = row.getAttribute("data-href");
            });
        });
    });
</script>
