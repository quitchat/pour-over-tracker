<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-cup-hot me-2"></i>
            Coffee Beans
        </h1>
        <p class="text-muted mb-0">
            Manage beans and start brew sessions from a specific active bean.
        </p>
    </div>

    <a href="/coffee-beans/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Add Coffee Bean
    </a>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-list-ul me-1"></i>
            Bean List
        </span>

        <span class="text-muted small"><%= coffeeBeans.length %> bean(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Roaster</th>
                    <th>Coffee Name</th>
                    <th>Origin</th>
                    <th>Process</th>
                    <th>Roast</th>
                    <th>Roast Date</th>
                    <th>Brews</th>
                    <th style="width: 330px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                <% if (coffeeBeans.length === 0) { %>
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            No coffee beans yet.
                        </td>
                    </tr>
                <% } %>

                <% coffeeBeans.forEach(function (bean) { %>
                    <tr>
                        <td>
                            <% if (bean.isActive) { %>
                                <span class="badge text-bg-success">Active</span>
                            <% } else { %>
                                <span class="badge text-bg-secondary">Inactive</span>
                                <% if (bean.deactivatedAt) { %>
                                    <div class="small text-muted mt-1"><%= bean.deactivatedAt %></div>
                                <% } %>
                            <% } %>
                        </td>

                        <td><%= bean.roasterName || "-" %></td>

                        <td>
                            <a href="/coffee-beans/<%= bean.id %>">
                                <%= bean.beanName %>
                            </a>
                        </td>

                        <td><%= bean.origin || "-" %></td>
                        <td><%= bean.process || "-" %></td>
                        <td><%= bean.roastLevel || "-" %></td>
                        <td><%= bean.roastDate || "-" %></td>
                        <td><%= bean.brewSessionCount %></td>

                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <% if (bean.isActive) { %>
                                    <a href="/brew-sessions/new?coffeeBeanId=<%= bean.id %>" class="btn btn-sm btn-success">
                                        <i class="bi bi-plus-circle me-1"></i>
                                        Create Brew
                                    </a>
                                <% } %>

                                <a href="/coffee-beans/<%= bean.id %>" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye me-1"></i>
                                    View
                                </a>

                                <a href="/coffee-beans/<%= bean.id %>/edit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil-square me-1"></i>
                                    Edit
                                </a>

                                <% if (bean.isActive) { %>
                                    <form method="post" action="/coffee-beans/<%= bean.id %>/deactivate">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Deactivate
                                        </button>
                                    </form>
                                <% } else { %>
                                    <form method="post" action="/coffee-beans/<%= bean.id %>/reactivate">
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            Reactivate
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
