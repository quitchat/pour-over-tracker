<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3 mb-1"><%= pageHeading %></h1><p class="text-muted mb-0">Remaining now: <%= remainingGrams %>g</p></div><a href="/coffee-beans/<%= coffeeBean.id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Bean</a></div>
<% if (errors && errors.length > 0) { %><div class="alert alert-danger"><strong>Please fix the following:</strong><ul class="mb-0"><% errors.forEach(function (error) { %><li><%= error %></li><% }); %></ul></div><% } %>
<form method="post" action="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= inventory.id %>/adjust">
    <div class="card mb-3"><div class="card-header"><i class="bi bi-plus-slash-minus me-1"></i>Adjustment</div><div class="card-body"><div class="row g-3"><div class="col-md-6"><label for="adjustmentGrams" class="form-label">Adjustment Grams</label><input type="number" step="0.01" class="form-control" id="adjustmentGrams" name="adjustmentGrams" value="<%= formData.adjustmentGrams || "" %>"><div class="form-text">Use positive or negative grams, for example +20 or -8.</div></div><div class="col-md-6"><label for="reason" class="form-label">Reason</label><select class="form-select" id="reason" name="reason"><option value="CORRECTION" <%= formData.reason === "CORRECTION" ? "selected" : "" %>>Measurement correction</option><option value="DISCARDED" <%= formData.reason === "DISCARDED" ? "selected" : "" %>>Discarded</option><option value="FINISHED_LEFTOVER" <%= formData.reason === "FINISHED_LEFTOVER" ? "selected" : "" %>>Finished / mixed with another bean</option><option value="OTHER" <%= formData.reason === "OTHER" ? "selected" : "" %>>Other</option></select></div><div class="col-12"><label for="notes" class="form-label">Notes</label><textarea class="form-control" id="notes" name="notes" rows="3"><%= formData.notes || "" %></textarea></div></div></div></div>
    <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Adjustment</button><a href="/coffee-beans/<%= coffeeBean.id %>" class="btn btn-outline-secondary">Cancel</a></div>
</form>
