<div class="inventory-page-header d-flex justify-content-between align-items-start align-items-lg-center mb-4 gap-3 flex-column flex-lg-row">
    <div class="inventory-page-title min-width-0">
        <h1 class="h3 mb-1">
            <i class="bi bi-box-seam me-2"></i>
            Inventory
        </h1>
        <p class="text-muted mb-0 text-truncate">
            <a href="/coffee-beans/<%= coffeeBean.id %>" class="text-decoration-none">
                <%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %>
            </a>
        </p>
    </div>

    <div class="inventory-header-actions">
        <a href="/coffee-beans/<%= coffeeBean.id %>/replenishments/new" class="btn btn-primary">
            <i class="bi bi-bag-plus me-1"></i>
            Add Replenishment
        </a>
        <a href="/coffee-beans/<%= coffeeBean.id %>/opening-balance/new" class="btn btn-outline-primary">
            <i class="bi bi-speedometer me-1"></i>
            Set Current Inventory
        </a>
        <a href="/coffee-beans/<%= coffeeBean.id %>" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Back to Bean
        </a>
    </div>
</div>

<% if (message) { %>
    <div class="alert alert-success">
        <%= message %>
    </div>
<% } %>

<% if (errorMessage) { %>
    <div class="alert alert-danger">
        <%= errorMessage %>
    </div>
<% } %>

<div class="card mb-4 inventory-section-card">
    <div class="card-header inventory-summary-card-header">
        <div class="inventory-summary-card-title">
            <span class="fw-semibold">
                <i class="bi bi-box-seam me-1"></i>
                Inventory Summary
            </span>
        </div>

        <div class="inventory-summary-header-metrics">
            <span class="inventory-summary-header-pill">
                <span class="inventory-summary-header-value"><%= formatInventoryGrams(inventorySummary.totalAvailableGrams) %>g</span>
                <span class="inventory-summary-header-label">available</span>
            </span>
            <span class="inventory-summary-header-pill">
                <span class="inventory-summary-header-value"><%= inventorySummary.items.length %></span>
                <span class="inventory-summary-header-label">record<%= inventorySummary.items.length === 1 ? "" : "s" %></span>
            </span>
        </div>
    </div>

    <div class="card-body">
        <div class="inventory-summary-strip">
            <div class="inventory-summary-tile inventory-summary-tile-primary">
                <div class="text-muted small">Available</div>
                <div class="inventory-summary-value"><%= formatInventoryGrams(inventorySummary.totalAvailableGrams) %>g</div>
            </div>
            <div class="inventory-summary-tile">
                <div class="text-muted small">Current Bag</div>
                <div class="fw-semibold"><%= inventorySummary.currentItem ? formatInventoryGrams(inventorySummary.currentItem.remainingGrams) + "g remaining" : "None" %></div>
            </div>
            <div class="inventory-summary-tile">
                <div class="text-muted small">Inventory Records</div>
                <div class="fw-semibold"><%= inventorySummary.items.length %></div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="fw-semibold">
            <i class="bi bi-list-check me-1"></i>
            Inventory Bags and Balances
        </span>
        <span class="text-muted small">Manage replenishments, opening balances, and adjustments.</span>
    </div>

    <% if (inventorySummary.items.length === 0) { %>
        <div class="card-body">
            <div class="text-muted border rounded p-3 bg-body-tertiary">
                No inventory records yet. Add a replenishment or set a current opening balance when you want inventory estimates.
            </div>
        </div>
    <% } else { %>
        <% const inventoryRows = inventorySummary.availableItems.concat(inventorySummary.finishedItems); %>

        <div class="table-responsive inventory-collapsed-table-wrap inventory-mobile-table-wrap border-0 rounded-0">
            <table class="table table-hover align-middle mb-0 inventory-table inventory-mobile-table">
                <thead>
                    <tr>
                        <th>Bag</th>
                        <th>Status</th>
                        <th class="text-end">Remaining</th>
                        <th class="text-end">Brewed</th>
                        <th class="text-end">Adjust.</th>
                        <th>Roasted</th>
                        <th>Purchased</th>
                        <th>Cost</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% inventoryRows.forEach(function (bag, bagIndex) { %>
                        <% const bagRemainingPercent = bag.startingGrams && Number(bag.startingGrams) > 0 ? Math.max(0, Math.min(100, Math.round((Number(bag.remainingGrams || 0) / Number(bag.startingGrams)) * 100))) : 0; %>
                        <% const bagMobileRowEdgeClass = (bagIndex === 0 ? "inventory-mobile-first-row inventory-mobile-has-header" : "") + (bagIndex === inventoryRows.length - 1 ? " inventory-mobile-last-row" : ""); %>
                        <tr class="<%= bagMobileRowEdgeClass %> <%= bag.isFinished ? "inventory-row-finished" : "" %>">
                            <td class="inventory-mobile-primary" data-label="Bag">
                                <div class="fw-semibold">
                                    <% if (bag.inventoryType === "OPENING_BALANCE") { %>
                                        Opening balance
                                    <% } else { %>
                                        <%= bag.bagSizeLabel %>
                                    <% } %>
                                </div>
                                <div class="small text-muted">
                                    <% if (bag.inventoryType === "OPENING_BALANCE") { %>
                                        Est. start: <%= formatInventoryGrams(bag.startingGrams) %>g
                                    <% } else { %>
                                        Start: <%= formatInventoryGrams(bag.startingGrams) %>g
                                    <% } %>
                                </div>
                                <div class="d-md-none mt-2">
                                    <% if (bag.adjustments && bag.adjustments.length > 0) { %>
                                        <details class="inventory-adjustment-details inventory-mobile-adjustment-details">
                                            <summary>Adjustment history (<%= bag.adjustments.length %>)</summary>
                                            <div class="inventory-adjustment-list mt-2">
                                                <% bag.adjustments.forEach(function (adjustment) { %>
                                                    <div class="inventory-adjustment-item inventory-adjustment-item-compact inventory-adjustment-item-mobile">
                                                        <div class="inventory-adjustment-icon <%= Number(adjustment.adjustmentGrams) < 0 ? "inventory-adjustment-negative" : "inventory-adjustment-positive" %>">
                                                            <i class="bi <%= Number(adjustment.adjustmentGrams) < 0 ? "bi-dash" : "bi-plus" %>"></i>
                                                        </div>
                                                        <div class="inventory-adjustment-content">
                                                            <div class="d-flex justify-content-between gap-2 flex-wrap">
                                                                <div class="fw-semibold"><%= Number(adjustment.adjustmentGrams) >= 0 ? "+" : "" %><%= formatInventoryGrams(adjustment.adjustmentGrams) %>g</div>
                                                                <div class="small text-muted"><%= formatDateUs(adjustment.createdAt) %></div>
                                                            </div>
                                                            <div class="small text-muted"><%= adjustment.reason === "BREWED_NOT_LOGGED" ? "Brewed but not logged" : adjustment.reason.replace(/_/g, " ") %></div>
                                                            <% if (adjustment.notes) { %>
                                                                <div class="small"><%= adjustment.notes %></div>
                                                            <% } %>
                                                            <div class="inventory-adjustment-actions d-flex gap-2 flex-wrap mt-2">
                                                                <a class="btn btn-sm btn-outline-secondary" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/adjustments/<%= adjustment.id %>/edit"><i class="bi bi-pencil me-1"></i>Edit</a>
                                                                <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/adjustments/<%= adjustment.id %>/delete" onsubmit="return confirm('Delete this adjustment? This will recalculate the bag remaining amount.');">
                                                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                <% }); %>
                                            </div>
                                        </details>
                                    <% } %>
                                </div>
                            </td>
                            <td data-label="Status">
                                <%
                                    const bagStatusLabel = bag.isFinished
                                        ? "Finished"
                                        : (inventorySummary.currentItem && inventorySummary.currentItem.id === bag.id ? "Current" : "Next");
                                    const bagStatusTextClass = bag.isFinished
                                        ? "text-muted"
                                        : (bagStatusLabel === "Current" ? "text-success" : "text-primary");
                                    const bagProgressClass = bag.isFinished
                                        ? "bg-secondary"
                                        : (bagStatusLabel === "Current" ? "bg-success" : "bg-primary");
                                %>
                                <div class="inventory-status-progress" title="<%= bagStatusLabel %>: <%= bagRemainingPercent %>% remaining">
                                    <div class="d-flex justify-content-between align-items-center small mb-1">
                                        <span class="fw-semibold <%= bagStatusTextClass %>"><%= bagStatusLabel %></span>
                                        <span class="text-muted"><%= bagRemainingPercent %>%</span>
                                    </div>
                                    <div class="progress inventory-bag-progress" role="progressbar" aria-label="<%= bagStatusLabel %> bag remaining" aria-valuenow="<%= bagRemainingPercent %>" aria-valuemin="0" aria-valuemax="100">
                                        <div class="progress-bar <%= bagProgressClass %>" style="width: <%= bagRemainingPercent %>%"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-end fw-semibold" data-label="Remaining"><%= formatInventoryGrams(bag.remainingGrams) %>g</td>
                            <td class="text-end" data-label="Brewed"><%= formatInventoryGrams(bag.brewedGrams) %>g</td>
                            <td class="text-end" data-label="Adjustments"><%= bag.adjustmentGrams >= 0 ? "+" : "" %><%= formatInventoryGrams(bag.adjustmentGrams) %>g</td>
                            <td data-label="Roasted"><%= bag.roastDate ? formatDateUs(bag.roastDate) : "-" %></td>
                            <td data-label="Purchased"><%= bag.purchaseDate ? formatDateUs(bag.purchaseDate) : "-" %></td>
                            <td data-label="Cost">
                                <% if (bag.purchase && bag.purchase.effectiveCostPerBag !== null) { %>
                                    <div><%= formatInventoryMoney(bag.purchase.effectiveCostPerBag, bag.purchase.currencyCode) %> / bag</div>
                                    <div class="small text-muted"><%= formatInventoryMoney(bag.purchase.effectiveCostPerGram, bag.purchase.currencyCode) %> / g</div>
                                    <a class="small" href="/coffee-beans/<%= coffeeBean.id %>/inventory/purchases/<%= bag.purchase.id %>/edit"><i class="bi bi-receipt me-1"></i>Edit cost</a>
                                <% } else if (bag.purchase) { %>
                                    <div class="text-muted">No cost</div>
                                    <a class="small" href="/coffee-beans/<%= coffeeBean.id %>/inventory/purchases/<%= bag.purchase.id %>/edit"><i class="bi bi-receipt me-1"></i>Add cost</a>
                                <% } else { %>
                                    <span class="text-muted">No cost</span>
                                <% } %>
                            </td>
                            <td class="text-end" data-label="Actions">
                                <div class="inventory-action-buttons" aria-label="Inventory actions">
                                    <a class="btn btn-sm btn-outline-secondary" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/edit" title="Edit Bag"><i class="bi bi-pencil me-1"></i>Edit</a>
                                    <a class="btn btn-sm btn-outline-primary" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/adjust" title="Adjust Inventory"><i class="bi bi-plus-slash-minus me-1"></i>Adjust</a>
                                    <% if (!bag.isFinished) { %>
                                        <a class="btn btn-sm btn-outline-success" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/finish" title="Finish Bag"><i class="bi bi-check2-circle me-1"></i>Finish</a>
                                    <% } %>
                                    <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/delete" onsubmit="return confirm('Delete this inventory bag? Linked brews will be kept but unlinked from this bag, and this bag adjustment history will be deleted.');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Bag"><i class="bi bi-trash me-1"></i>Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <tr class="inventory-row-detail d-none d-md-table-row <%= bag.isFinished ? "inventory-row-finished" : "" %>">
                            <td colspan="9">
                                <% if (bag.adjustments && bag.adjustments.length > 0) { %>
                                    <details class="inventory-adjustment-details">
                                        <summary>Adjustment history (<%= bag.adjustments.length %>)</summary>
                                        <div class="inventory-adjustment-list inventory-adjustment-list-desktop mt-2">
                                            <% bag.adjustments.forEach(function (adjustment) { %>
                                                <div class="inventory-adjustment-item inventory-adjustment-item-compact">
                                                    <div class="inventory-adjustment-icon <%= Number(adjustment.adjustmentGrams) < 0 ? "inventory-adjustment-negative" : "inventory-adjustment-positive" %>">
                                                        <i class="bi <%= Number(adjustment.adjustmentGrams) < 0 ? "bi-dash" : "bi-plus" %>"></i>
                                                    </div>
                                                    <div class="inventory-adjustment-content">
                                                        <div class="d-flex justify-content-between gap-2 flex-wrap">
                                                            <div class="fw-semibold"><%= Number(adjustment.adjustmentGrams) >= 0 ? "+" : "" %><%= formatInventoryGrams(adjustment.adjustmentGrams) %>g</div>
                                                            <div class="small text-muted"><%= formatDateUs(adjustment.createdAt) %></div>
                                                        </div>
                                                        <div class="small text-muted"><%= adjustment.reason === "BREWED_NOT_LOGGED" ? "Brewed but not logged" : adjustment.reason.replace(/_/g, " ") %></div>
                                                        <% if (adjustment.notes) { %>
                                                            <div class="small"><%= adjustment.notes %></div>
                                                        <% } %>
                                                    </div>
                                                    <div class="inventory-adjustment-actions d-flex gap-2 flex-wrap">
                                                        <a class="btn btn-sm btn-outline-secondary" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/adjustments/<%= adjustment.id %>/edit"><i class="bi bi-pencil me-1"></i>Edit</a>
                                                        <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/adjustments/<%= adjustment.id %>/delete" onsubmit="return confirm('Delete this adjustment? This will recalculate the bag remaining amount.');">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        </div>
                                    </details>
                                <% } else { %>
                                    <span class="text-muted small">No adjustments for this bag.</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
