<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3 mb-1"><%= pageHeading %></h1><p class="text-muted mb-0">Zero out <strong><%= remainingGrams %>g</strong> remaining.</p></div><a href="/coffee-beans/<%= coffeeBean.id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Bean</a></div>
<% if (errors && errors.length > 0) { %><div class="alert alert-danger"><strong>Please fix the following:</strong><ul class="mb-0"><% errors.forEach(function (error) { %><li><%= error %></li><% }); %></ul></div><% } %>
<form method="post" action="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= inventory.id %>/finish">
    <div class="card mb-3"><div class="card-header"><i class="bi bi-check-circle me-1"></i>Confirm Finish Bag</div><div class="card-body"><p>Zero out <strong><%= remainingGrams %>g</strong> remaining?</p><div class="mb-3"><label for="reason" class="form-label">Reason</label><select class="form-select" id="reason" name="reason"><option value="BREWED_NOT_LOGGED" <%= formData.reason === "BREWED_NOT_LOGGED" ? "selected" : "" %>>Brewed but not logged</option><option value="FINISHED_LEFTOVER" <%= formData.reason === "FINISHED_LEFTOVER" ? "selected" : "" %>>Finished / mixed with another bean</option><option value="DISCARDED" <%= formData.reason === "DISCARDED" ? "selected" : "" %>>Discarded</option><option value="CORRECTION" <%= formData.reason === "CORRECTION" ? "selected" : "" %>>Measurement correction</option><option value="OTHER" <%= formData.reason === "OTHER" ? "selected" : "" %>>Other</option></select></div><div><label for="notes" class="form-label">Optional Notes</label><textarea class="form-control" id="notes" name="notes" rows="3"><%= formData.notes || "" %></textarea></div></div></div>
    <div class="d-flex gap-2"><button type="submit" class="btn btn-danger"><i class="bi bi-check-circle me-1"></i>Confirm</button><a href="/coffee-beans/<%= coffeeBean.id %>" class="btn btn-outline-secondary">Cancel</a></div>
</form>
