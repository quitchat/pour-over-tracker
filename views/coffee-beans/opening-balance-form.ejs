<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1"><%= pageHeading %></h1>
        <p class="text-muted mb-0"><%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %></p>
    </div>
    <a href="/coffee-beans/<%= coffeeBean.id %>/inventory" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Inventory</a>
</div>

<% if (errors && errors.length > 0) { %><div class="alert alert-danger"><strong>Please fix the following:</strong><ul class="mb-0"><% errors.forEach(function (error) { %><li><%= error %></li><% }); %></ul></div><% } %>

<form method="post" action="/coffee-beans/<%= coffeeBean.id %>/opening-balance">
    <div class="card mb-3">
        <div class="card-header"><i class="bi bi-speedometer me-1"></i>Opening Balance</div>
        <div class="card-body">
            <p class="text-muted">Use this for a partially used bean when you only know the current remaining amount.</p>
            <div class="row g-3">
                <div class="col-md-6"><label for="currentAmount" class="form-label">Current Remaining Amount</label><input type="number" min="0" step="0.01" class="form-control" id="currentAmount" name="currentAmount" value="<%= formData.currentAmount || "" %>"></div>
                <div class="col-md-6"><label for="unit" class="form-label">Unit</label><select class="form-select" id="unit" name="unit"><option value="G" <%= formData.unit === "G" ? "selected" : "" %>>g</option><option value="OZ" <%= formData.unit === "OZ" ? "selected" : "" %>>oz</option></select></div>
                <div class="col-md-6"><label for="roastDate" class="form-label">Roast Date</label><input type="date" class="form-control" id="roastDate" name="roastDate" value="<%= formData.roastDate || "" %>"></div>
                <div class="col-md-6"><label for="purchaseDate" class="form-label">Purchase Date</label><input type="date" class="form-control" id="purchaseDate" name="purchaseDate" value="<%= formData.purchaseDate || "" %>"></div>
                <div class="col-12"><label for="notes" class="form-label">Notes</label><textarea class="form-control" id="notes" name="notes" rows="3"><%= formData.notes || "" %></textarea></div>
            </div>
        </div>
    </div>
    <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Set Current Inventory</button><a href="/coffee-beans/<%= coffeeBean.id %>/inventory" class="btn btn-outline-secondary">Cancel</a></div>
</form>
