<div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1"><%= pageHeading %></h1>
        <p class="text-muted mb-0"><%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %></p>
        <div class="small text-muted">
            <%= purchase.inventories.length %> bag<%= purchase.inventories.length === 1 ? "" : "s" %> in this purchase
        </div>
    </div>
    <a href="/coffee-beans/<%= coffeeBean.id %>/inventory" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Inventory</a>
</div>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger"><strong>Please fix the following:</strong><ul class="mb-0"><% errors.forEach(function (error) { %><li><%= error %></li><% }); %></ul></div>
<% } %>

<form method="post" action="/coffee-beans/<%= coffeeBean.id %>/inventory/purchases/<%= purchase.id %>/edit" data-purchase-cost-form>
    <div class="card mb-3">
        <div class="card-header"><i class="bi bi-receipt me-1"></i>Purchase Cost</div>
        <div class="card-body">
            <div class="alert alert-info small mb-3">
                These cost fields belong to the shared purchase/order. Updating them updates cost-per-bag and cost-per-gram for all bags in this replenishment.
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label for="purchaseDate" class="form-label">Purchase Date</label>
                    <input type="date" class="form-control" id="purchaseDate" name="purchaseDate" value="<%= formData.purchaseDate || "" %>">
                </div>
                <div class="col-md-6">
                    <label for="currencyCode" class="form-label">Currency</label>
                    <input type="text" maxlength="3" class="form-control text-uppercase" id="currencyCode" name="currencyCode" value="<%= formData.currencyCode || "USD" %>">
                </div>
                <div class="col-md-3">
                    <label for="itemSubtotal" class="form-label">Subtotal</label>
                    <input type="number" step="0.01" class="form-control" id="itemSubtotal" name="itemSubtotal" value="<%= formData.itemSubtotal || "" %>" data-purchase-cost-input>
                </div>
                <div class="col-md-3">
                    <label for="discount" class="form-label">Discount</label>
                    <input type="number" step="0.01" class="form-control" id="discount" name="discount" value="<%= formData.discount || "" %>" data-purchase-cost-input>
                </div>
                <div class="col-md-3">
                    <label for="shipping" class="form-label">Shipping</label>
                    <input type="number" step="0.01" class="form-control" id="shipping" name="shipping" value="<%= formData.shipping || "" %>" data-purchase-cost-input>
                </div>
                <div class="col-md-3">
                    <label for="tax" class="form-label">Tax</label>
                    <input type="number" step="0.01" class="form-control" id="tax" name="tax" value="<%= formData.tax || "" %>" data-purchase-cost-input>
                </div>
                <div class="col-md-4">
                    <label for="totalPaid" class="form-label">Total Paid</label>
                    <input type="number" step="0.01" class="form-control bg-body-secondary" id="totalPaid" name="totalPaid" value="<%= formData.totalPaid || "" %>" readonly data-purchase-total-output>
                    <div class="form-text">Auto-calculated as subtotal - discount + shipping + tax.</div>
                </div>
                <div class="col-12">
                    <label for="notes" class="form-label">Notes</label>
                    <textarea class="form-control" id="notes" name="notes" rows="3"><%= formData.notes || "" %></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap inventory-form-actions">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Purchase Cost</button>
        <a href="/coffee-beans/<%= coffeeBean.id %>/inventory" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

<script>
(function () {
    function toNumber(value) {
        var parsed = Number(value || "0");
        return Number.isNaN(parsed) ? 0 : parsed;
    }

    function updatePurchaseTotal(form) {
        var subtotalInput = form.querySelector("#itemSubtotal");
        var discountInput = form.querySelector("#discount");
        var shippingInput = form.querySelector("#shipping");
        var taxInput = form.querySelector("#tax");
        var subtotal = toNumber(subtotalInput ? subtotalInput.value : "");
        var discount = toNumber(discountInput ? discountInput.value : "");
        var shipping = toNumber(shippingInput ? shippingInput.value : "");
        var tax = toNumber(taxInput ? taxInput.value : "");
        var totalOutput = form.querySelector("[data-purchase-total-output]");
        var hasCost = Boolean((subtotalInput && subtotalInput.value) || (discountInput && discountInput.value) || (shippingInput && shippingInput.value) || (taxInput && taxInput.value));

        if (!totalOutput) {
            return;
        }

        totalOutput.value = hasCost ? (subtotal - discount + shipping + tax).toFixed(2) : "";
    }

    document.querySelectorAll("[data-purchase-cost-form]").forEach(function (form) {
        form.querySelectorAll("[data-purchase-cost-input]").forEach(function (input) {
            input.addEventListener("input", function () {
                updatePurchaseTotal(form);
            });
        });
        updatePurchaseTotal(form);
    });
})();
</script>
