<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-cup-hot me-2"></i>
            <%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %>
        </h1>
        <p class="text-muted mb-0">
            Coffee bean detail and brew history.
        </p>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <% if (coffeeBean.isActive) { %>
            <a href="/brew-sessions/new?coffeeBeanId=<%= coffeeBean.id %>" class="btn btn-outline-success">
                <i class="bi bi-plus-circle me-1"></i>
                Create Brew
            </a>

            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/deactivate">
                <button type="submit" class="btn btn-outline-danger">
                    Deactivate
                </button>
            </form>
        <% } else { %>
            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/reactivate">
                <button type="submit" class="btn btn-outline-success">
                    Reactivate
                </button>
            </form>
        <% } %>

        <a href="/coffee-beans/<%= coffeeBean.id %>/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil-square me-1"></i>
            Edit
        </a>

        <a href="/coffee-beans" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Back to Beans
        </a>
    </div>
</div>

<% if (message) { %>
    <div class="alert alert-success">
        <%= message %>
    </div>
<% } %>

<% if (errorMessage) { %>
    <div class="alert alert-danger">
        <%= errorMessage %>
    </div>
<% } %>

<% if (!coffeeBean.isActive) { %>
    <div class="alert alert-secondary">
        This coffee bean is inactive.
        <% if (coffeeBean.deactivatedAt) { %>
            It was deactivated on <%= coffeeBean.deactivatedAt %>.
        <% } %>
        Historical brew sessions are preserved, but you cannot create new brews from this bean until it is reactivated.
    </div>
<% } %>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-card-checklist me-1"></i>
                Bean Information
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.isActive) { %>
                            <span class="badge text-bg-success">Active</span>
                        <% } else { %>
                            <span class="badge text-bg-secondary">Inactive</span>
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Roaster</dt>
                    <dd class="col-sm-8"><%= coffeeBean.roasterName %></dd>

                    <dt class="col-sm-4">Coffee Name</dt>
                    <dd class="col-sm-8"><%= coffeeBean.beanName %></dd>

                    <dt class="col-sm-4">Origin</dt>
                    <dd class="col-sm-8"><%= coffeeBean.origin %></dd>

                    <dt class="col-sm-4">Process</dt>
                    <dd class="col-sm-8"><%= coffeeBean.process %></dd>

                    <dt class="col-sm-4">Roast Level</dt>
                    <dd class="col-sm-8"><%= coffeeBean.roastLevel %></dd>

                    <dt class="col-sm-4">Roast Date</dt>
                    <dd class="col-sm-8"><%= coffeeBean.roastDate %></dd>

                    <dt class="col-sm-4">Price US$</dt>
                    <dd class="col-sm-8"><%= coffeeBean.price %></dd>

                    <dt class="col-sm-4">Flavor Notes</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.flavorNotes) { %>
                            <%= coffeeBean.flavorNotes %>
                        <% } else { %>
                            <span class="text-muted">No flavor notes entered.</span>
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Source</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.sourceUrl) { %>
                            <a href="<%= coffeeBean.sourceUrl %>" target="_blank" rel="noopener noreferrer">
                                <%= coffeeBean.sourceUrl %>
                            </a>
                        <% } else { %>
                            <span class="text-muted">No source URL.</span>
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.notes) { %>
                            <%= coffeeBean.notes %>
                        <% } else { %>
                            <span class="text-muted">No notes entered.</span>
                        <% } %>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-speedometer2 me-1"></i>
                Bean Summary
            </div>

            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-muted small">Brews</div>
                        <div class="h3 mb-0"><%= stats.brewSessionCount %></div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Average Rating</div>
                        <div class="h3 mb-0"><%= stats.averageRating || "-" %></div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Best Rating</div>
                        <div class="h3 mb-0"><%= stats.bestRating || "-" %></div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Average Ratio</div>
                        <div class="h3 mb-0">
                            <%= stats.averageRatio ? "1:" + stats.averageRatio : "-" %>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Would Repeat</div>
                        <div class="h3 mb-0"><%= stats.repeatCount %></div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Rated Brews</div>
                        <div class="h3 mb-0"><%= stats.ratedSessionCount %></div>
                    </div>
                </div>

                <% if (stats.bestBrewSessionId) { %>
                    <div class="mt-3">
                        <a href="/brew-sessions/<%= stats.bestBrewSessionId %>" class="btn btn-outline-primary w-100">
                            <i class="bi bi-trophy me-1"></i>
                            View Best Brew
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-journal-text me-1"></i>
            Brew Sessions for This Bean
        </span>

        <span class="text-muted small"><%= brewSessions.length %> brew(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Brew Date</th>
                    <th>Grinder</th>
                    <th>Brewer</th>
                    <th>Grind</th>
                    <th>Dose</th>
                    <th>Total Yield</th>
                    <th>Ratio</th>
                    <th>Temp</th>
                    <th>Time</th>
                    <th>Rating</th>
                    <th>Repeat?</th>
                    <th style="width: 90px;">Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (brewSessions.length === 0) { %>
                    <tr>
                        <td colspan="12" class="text-muted text-center py-4">
                            No brew sessions yet for this bean.
                        </td>
                    </tr>
                <% } %>

                <% brewSessions.forEach(function (session) { %>
                    <tr>
                        <td><%= session.brewDate %></td>
                        <td><%= session.grinderName %></td>
                        <td><%= session.brewerName %></td>
                        <td><%= session.grindSize %></td>
                        <td><%= session.coffeeDoseGrams %></td>
                        <td><%= session.totalYieldGrams %></td>
                        <td>1:<%= session.brewRatio %></td>
                        <td><%= session.waterTemperatureC %></td>
                        <td><%= session.totalBrewTime %></td>
                        <td><%= session.overallRating || "-" %></td>
                        <td>
                            <% if (session.wouldRepeat) { %>
                                <i class="bi bi-check-circle me-1"></i>
                                Yes
                            <% } else { %>
                                <i class="bi bi-x-circle me-1"></i>
                                No
                            <% } %>
                        </td>
                        <td>
                            <a href="/brew-sessions/<%= session.id %>" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>
                                View
                            </a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
