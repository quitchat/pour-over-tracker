<style>
    .bean-notes-display {
        white-space: pre-line;
    }

    .bean-rating-stars {
        color: #f5b301;
        letter-spacing: 0.05rem;
        white-space: nowrap;
    }
</style>

<style>
    .bean-history-mobile-label {
        display: none;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.1rem;
    }

    .bean-best-setup-card {
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        padding: 0.75rem;
        background: var(--bs-body-bg);
    }

    .bean-photo-detail-button {
        display: block;
        width: 100%;
        border: 0;
        padding: 0;
        background: transparent;
        border-radius: 0.5rem;
    }

    .bean-photo-detail-button:hover img,
    .bean-photo-detail-button:focus img {
        border-color: var(--bs-primary) !important;
        box-shadow: 0 0 0 0.2rem rgba(var(--bs-primary-rgb), 0.2);
    }

    .bean-photo-modal-image {
        max-height: 82vh;
        object-fit: contain;
    }

    @media (max-width: 991.98px) {
        .bean-detail-header {
            align-items: stretch !important;
        }

        .bean-detail-actions .btn,
        .bean-detail-actions form,
        .bean-detail-actions button {
            width: 100%;
        }

        .bean-history-table thead {
            display: none;
        }

        .bean-history-table,
        .bean-history-table tbody,
        .bean-history-table tr,
        .bean-history-table td {
            display: block;
            width: 100%;
        }

        .bean-history-table tr {
            border-bottom: 1px solid var(--bs-border-color);
            padding: 0.75rem 0;
        }

        .bean-history-table td {
            border: 0;
            padding: 0.35rem 1rem;
        }

        .bean-history-mobile-label {
            display: block;
        }

        .bean-history-action-cell .btn {
            width: 100%;
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-column flex-lg-row bean-detail-header">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-cup-hot me-2"></i>
            <%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %>
        </h1>
        <p class="text-muted mb-0">
            Coffee bean detail and brew history.
        </p>
    </div>

    <div class="d-flex gap-2 flex-wrap bean-detail-actions">
        <% if (coffeeBean.isActive) { %>
            <a href="/brew-sessions/new?coffeeBeanId=<%= coffeeBean.id %>" class="btn btn-outline-success">
                <i class="bi bi-plus-circle me-1"></i>
                Create Brew
            </a>
        <% } %>

        <a href="/coffee-beans/<%= coffeeBean.id %>/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil-square me-1"></i>
            Edit
        </a>

        <% if (coffeeBean.isActive) { %>
            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/deactivate">
                <button type="submit" class="btn btn-outline-danger">
                    Deactivate
                </button>
            </form>
        <% } else { %>
            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/reactivate">
                <button type="submit" class="btn btn-outline-success">
                    Reactivate
                </button>
            </form>
        <% } %>

        <% if (stats.brewSessionCount === 0) { %>
            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/delete" onsubmit="return confirm('Delete this coffee bean permanently? This is only allowed because it has no brew sessions.');">
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>
                    Delete
                </button>
            </form>
        <% } %>

        <a href="/coffee-beans" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Back to Beans
        </a>
    </div>
</div>

<% if (message) { %>
    <div class="alert alert-success">
        <%= message %>
    </div>
<% } %>

<% if (errorMessage) { %>
    <div class="alert alert-danger">
        <%= errorMessage %>
    </div>
<% } %>

<% if (!coffeeBean.isActive) { %>
    <div class="alert alert-secondary">
        This coffee bean is inactive.
        <% if (coffeeBean.deactivatedAt) { %>
            It was deactivated on <%= coffeeBean.deactivatedAt %>.
        <% } %>
        Historical brew sessions are preserved, but you cannot create new brews from this bean until it is reactivated.
    </div>
<% } %>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-card-checklist me-1"></i>
                Bean Information
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.isActive) { %>
                            <span class="badge text-bg-success">Active</span>
                        <% } else { %>
                            <span class="badge text-bg-secondary">Inactive</span>
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Roaster</dt>
                    <dd class="col-sm-8"><%= coffeeBean.roasterName %></dd>

                    <dt class="col-sm-4">Coffee Name</dt>
                    <dd class="col-sm-8"><%= coffeeBean.beanName %></dd>

                    <dt class="col-sm-4">Origin</dt>
                    <dd class="col-sm-8"><%= coffeeBean.origin %></dd>

                    <dt class="col-sm-4">Process</dt>
                    <dd class="col-sm-8"><%= coffeeBean.process %></dd>

                    <dt class="col-sm-4">Roast Level</dt>
                    <dd class="col-sm-8"><%= coffeeBean.roastLevel %></dd>

                    <dt class="col-sm-4">Roast Date</dt>
                    <dd class="col-sm-8"><%= coffeeBean.roastDate %></dd>

                    <dt class="col-sm-4">Price US$</dt>
                    <dd class="col-sm-8"><%= coffeeBean.price %></dd>

                    <dt class="col-sm-4">Bean Rating</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.rating) { %>
                            <span class="bean-rating-stars" aria-label="<%= coffeeBean.rating %> out of 5 stars">
                                <% for (let i = 1; i <= 5; i++) { %><%= Number(coffeeBean.rating) >= i ? "★" : "☆" %><% } %>
                            </span>
                            <span class="ms-1 text-muted"><%= coffeeBean.rating %> / 5</span>
                        <% } else { %>
                            <span class="text-muted">No bean rating.</span>
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Flavor Notes</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.flavorNotes) { %>
                            <%= coffeeBean.flavorNotes %>
                        <% } else { %>
                            <span class="text-muted">No flavor notes entered.</span>
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Source</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.sourceUrl) { %>
                            <a href="<%= coffeeBean.sourceUrl %>" target="_blank" rel="noopener noreferrer">
                                <%= coffeeBean.sourceUrl %>
                            </a>
                        <% } else { %>
                            <span class="text-muted">No source URL.</span>
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Bean Info</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.beanInfo) { %>
                            <div class="bean-notes-display"><%= coffeeBean.beanInfo %></div>
                        <% } else { %>
                            <span class="text-muted">No bean info entered.</span>
                        <% } %>
                    </dd>

                    <dt class="col-sm-4">Bean Notes</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.beanNotes) { %>
                            <div class="bean-notes-display"><%= coffeeBean.beanNotes %></div>
                        <% } else { %>
                            <span class="text-muted">No bean notes entered.</span>
                        <% } %>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-image me-1"></i>
                Bean Picture
            </div>

            <div class="card-body">
                <% if (coffeeBean.bagImageUrl) { %>
                    <button
                        type="button"
                        class="bean-photo-detail-button"
                        data-bs-toggle="modal"
                        data-bs-target="#beanPhotoModal"
                        aria-label="Enlarge picture for <%= coffeeBean.beanName %>">
                        <img
                            src="<%= coffeeBean.bagImageUrl %>"
                            alt="<%= coffeeBean.beanName %> picture"
                            class="img-fluid rounded border w-100"
                            style="max-height: 360px; object-fit: cover;">
                    </button>
                    <div class="form-text text-center mt-2">Click photo to enlarge.</div>
                <% } else { %>
                    <div class="text-muted text-center py-4 border rounded bg-body-tertiary">
                        <i class="bi bi-image d-block fs-1 mb-2"></i>
                        No picture uploaded.
                    </div>
                <% } %>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-speedometer2 me-1"></i>
                Bean Summary
            </div>

            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-muted small">Brews</div>
                        <div class="h3 mb-0"><%= stats.brewSessionCount %></div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Total Grams Brewed</div>
                        <div class="h3 mb-0"><%= stats.totalGramsBrewed || "0.0" %> g</div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Average Rating</div>
                        <div class="h3 mb-0"><%= stats.averageRating || "-" %></div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Best Rating</div>
                        <div class="h3 mb-0"><%= stats.bestRating || "-" %></div>
                    </div>

                </div>

                <% if (stats.bestBrewSessionId) { %>
                    <hr>

                    <div class="bean-best-setup-card">
                        <div class="fw-semibold mb-2">
                            <i class="bi bi-trophy me-1"></i>
                            Best Brew Setup
                        </div>

                        <div class="row g-2 small">
                            <div class="col-6 text-muted">Date</div>
                            <div class="col-6 text-end"><%= stats.bestBrewDate || "-" %></div>

                            <div class="col-6 text-muted">Grinder</div>
                            <div class="col-6 text-end"><%= stats.bestGrinderName || "-" %></div>

                            <div class="col-6 text-muted">Brewer</div>
                            <div class="col-6 text-end"><%= stats.bestBrewerName || "-" %></div>

                            <div class="col-6 text-muted">Grind</div>
                            <div class="col-6 text-end"><%= stats.bestGrindSize || "-" %></div>

                            <div class="col-6 text-muted">Dose → Yield</div>
                            <div class="col-6 text-end"><%= stats.bestDoseGrams || "-" %> → <%= stats.bestYieldGrams || "-" %></div>

                            <div class="col-6 text-muted">Ratio</div>
                            <div class="col-6 text-end"><%= stats.bestBrewRatio ? "1:" + stats.bestBrewRatio : "-" %></div>

                            <div class="col-6 text-muted">Water Temp</div>
                            <div class="col-6 text-end"><%= stats.bestWaterTemperatureC ? stats.bestWaterTemperatureC + " " + (stats.bestWaterTemperatureUnit || "°C") : "-" %></div>

                            <div class="col-6 text-muted">Time</div>
                            <div class="col-6 text-end"><%= stats.bestBrewTime || "-" %></div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <a href="/brew-sessions/<%= stats.bestBrewSessionId %>" class="btn btn-outline-primary w-100">
                            <i class="bi bi-trophy me-1"></i>
                            View Best Brew
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4 inventory-section-card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <span class="fw-semibold">
                <i class="bi bi-box-seam me-1"></i>
                Inventory
            </span>
            <div class="small text-muted">
                <%= formatInventoryGrams(inventorySummary.totalAvailableGrams) %>g available · <%= inventorySummary.items.length %> record<%= inventorySummary.items.length === 1 ? "" : "s" %>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap inventory-header-actions">
            <% if (inventorySummary.items.length > 0) { %>
                <button class="btn btn-sm btn-outline-dark" type="button" data-bs-toggle="collapse" data-bs-target="#beanInventoryTableCollapse" aria-expanded="false" aria-controls="beanInventoryTableCollapse">
                    <i class="bi bi-chevron-down me-1"></i>Show Inventory Table
                </button>
            <% } %>
            <a href="/coffee-beans/<%= coffeeBean.id %>/replenishments/new" class="btn btn-sm btn-outline-primary"><i class="bi bi-bag-plus me-1"></i>Add Replenishment</a>
            <a href="/coffee-beans/<%= coffeeBean.id %>/opening-balance/new" class="btn btn-sm btn-outline-secondary"><i class="bi bi-speedometer me-1"></i>Set Current Inventory</a>
        </div>
    </div>
    <div class="card-body">
        <div class="inventory-summary-strip mb-3">
            <div class="inventory-summary-tile inventory-summary-tile-primary">
                <div class="text-muted small">Available</div>
                <div class="inventory-summary-value"><%= formatInventoryGrams(inventorySummary.totalAvailableGrams) %>g</div>
            </div>
            <div class="inventory-summary-tile">
                <div class="text-muted small">Current Bag</div>
                <div class="fw-semibold"><%= inventorySummary.currentItem ? formatInventoryGrams(inventorySummary.currentItem.remainingGrams) + "g remaining" : "None" %></div>
            </div>
            <div class="inventory-summary-tile">
                <div class="text-muted small">Inventory Records</div>
                <div class="fw-semibold"><%= inventorySummary.items.length %></div>
            </div>
        </div>

        <% if (inventorySummary.items.length === 0) { %>
            <div class="text-muted border rounded p-3 bg-body-tertiary">No inventory records yet. Add a replenishment or set a current opening balance when you want inventory estimates.</div>
        <% } else { %>
            <% const inventoryRows = inventorySummary.availableItems.concat(inventorySummary.finishedItems); %>

            <div class="collapse" id="beanInventoryTableCollapse">
                <div class="table-responsive inventory-collapsed-table-wrap">
                    <table class="table table-hover align-middle mb-0 inventory-table">
                        <thead>
                            <tr>
                                <th>Bag</th>
                                <th>Status</th>
                                <th class="text-end">Remaining</th>
                                <th class="text-end">Brewed</th>
                                <th class="text-end">Adjust.</th>
                                <th>Roasted</th>
                                <th>Purchased</th>
                                <th>Cost</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% inventoryRows.forEach(function (bag) { %>
                                <tr class="<%= bag.isFinished ? "inventory-row-finished" : "" %>">
                                    <td>
                                        <div class="fw-semibold">
                                            <% if (bag.inventoryType === "OPENING_BALANCE") { %>
                                                Opening balance
                                            <% } else { %>
                                                <%= bag.bagSizeLabel %>
                                            <% } %>
                                        </div>
                                        <div class="small text-muted">
                                            <% if (bag.inventoryType === "OPENING_BALANCE") { %>
                                                Est. start: <%= formatInventoryGrams(bag.startingGrams) %>g
                                            <% } else { %>
                                                Start: <%= formatInventoryGrams(bag.startingGrams) %>g
                                            <% } %>
                                        </div>
                                        <% if (bag.notes) { %>
                                            <div class="small text-muted mt-1"><i class="bi bi-sticky me-1"></i><%= bag.notes %></div>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (bag.isFinished) { %>
                                            <span class="badge text-bg-secondary">Finished</span>
                                        <% } else if (inventorySummary.currentItem && inventorySummary.currentItem.id === bag.id) { %>
                                            <span class="badge text-bg-success">Current</span>
                                        <% } else { %>
                                            <span class="badge text-bg-light border">Next</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end fw-semibold"><%= formatInventoryGrams(bag.remainingGrams) %>g</td>
                                    <td class="text-end"><%= formatInventoryGrams(bag.brewedGrams) %>g</td>
                                    <td class="text-end"><%= bag.adjustmentGrams >= 0 ? "+" : "" %><%= formatInventoryGrams(bag.adjustmentGrams) %>g</td>
                                    <td><%= bag.roastDate ? formatDateUs(bag.roastDate) : "-" %></td>
                                    <td><%= bag.purchaseDate ? formatDateUs(bag.purchaseDate) : "-" %></td>
                                    <td>
                                        <% if (bag.purchase && bag.purchase.effectiveCostPerBag !== null) { %>
                                            <div><%= formatInventoryMoney(bag.purchase.effectiveCostPerBag, bag.purchase.currencyCode) %> / bag</div>
                                            <div class="small text-muted"><%= formatInventoryMoney(bag.purchase.effectiveCostPerGram, bag.purchase.currencyCode) %> / g</div>
                                        <% } else { %>
                                            <span class="text-muted">No cost</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm inventory-action-group" role="group" aria-label="Inventory actions">
                                            <% if (!bag.isFinished) { %>
                                                <a class="btn btn-outline-success" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/finish" title="Finish Bag"><i class="bi bi-check2-circle"></i></a>
                                            <% } %>
                                            <a class="btn btn-outline-primary" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/adjust" title="Adjust Inventory"><i class="bi bi-plus-slash-minus"></i></a>
                                            <a class="btn btn-outline-secondary" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/edit" title="Edit Bag"><i class="bi bi-pencil"></i></a>
                                            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/delete" onsubmit="return confirm('Delete this inventory bag? Linked brews will be kept but unlinked from this bag, and this bag adjustment history will be deleted.');">
                                                <button type="submit" class="btn btn-outline-danger" title="Delete Bag"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <% if (bag.adjustments && bag.adjustments.length > 0) { %>
                                    <tr class="inventory-row-detail <%= bag.isFinished ? "inventory-row-finished" : "" %>">
                                        <td colspan="9">
                                            <details class="inventory-adjustment-details">
                                                <summary>Adjustment history (<%= bag.adjustments.length %>)</summary>
                                                <div class="inventory-adjustment-list inventory-adjustment-list-desktop mt-2">
                                                    <% bag.adjustments.forEach(function (adjustment) { %>
                                                        <div class="inventory-adjustment-item inventory-adjustment-item-compact">
                                                            <div class="inventory-adjustment-icon <%= Number(adjustment.adjustmentGrams) < 0 ? "inventory-adjustment-negative" : "inventory-adjustment-positive" %>">
                                                                <i class="bi <%= Number(adjustment.adjustmentGrams) < 0 ? "bi-dash" : "bi-plus" %>"></i>
                                                            </div>
                                                            <div class="inventory-adjustment-content">
                                                                <div class="d-flex justify-content-between gap-2 flex-wrap">
                                                                    <div class="fw-semibold"><%= Number(adjustment.adjustmentGrams) >= 0 ? "+" : "" %><%= formatInventoryGrams(adjustment.adjustmentGrams) %>g</div>
                                                                    <div class="small text-muted"><%= formatDateUs(adjustment.createdAt) %></div>
                                                                </div>
                                                                <div class="small text-muted"><%= adjustment.reason.replace(/_/g, " ") %></div>
                                                                <% if (adjustment.notes) { %>
                                                                    <div class="small"><%= adjustment.notes %></div>
                                                                <% } %>
                                                            </div>
                                                            <div class="inventory-adjustment-actions d-flex gap-2 flex-wrap">
                                                                <a class="btn btn-sm btn-outline-secondary" href="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/adjustments/<%= adjustment.id %>/edit"><i class="bi bi-pencil me-1"></i>Edit</a>
                                                                <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/inventory/<%= bag.id %>/adjustments/<%= adjustment.id %>/delete" onsubmit="return confirm('Delete this adjustment? This will recalculate the bag remaining amount.');">
                                                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    <% }); %>
                                                </div>
                                            </details>
                                        </td>
                                    </tr>
                                <% } %>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>
</div>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-journal-text me-1"></i>
            Brew History for This Bean
        </span>

        <span class="text-muted small"><%= brewSessions.length %> brew(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle bean-history-table">
            <thead>
                <tr>
                    <th>Brew Date</th>
                    <th>Grinder</th>
                    <th>Brewer</th>
                    <th>Grind</th>
                    <th>Dose</th>
                    <th>Total Yield</th>
                    <th>Ratio</th>
                    <th>Temp</th>
                    <th>Time</th>
                    <th>Rating</th>
                    <th style="width: 90px;">Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (brewSessions.length === 0) { %>
                    <tr>
                        <td colspan="11" class="text-muted text-center py-4">
                            No brew sessions yet for this bean.
                        </td>
                    </tr>
                <% } %>

                <% brewSessions.forEach(function (session) { %>
                    <tr>
                        <td>
                            <span class="bean-history-mobile-label">Brew Date</span>
                            <%= session.brewDate %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Grinder</span>
                            <%= session.grinderName || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Brewer</span>
                            <%= session.brewerName || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Grind</span>
                            <%= session.grindSize || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Dose</span>
                            <%= session.coffeeDoseGrams || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Total Yield</span>
                            <%= session.totalYieldGrams || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Ratio</span>
                            <%= session.brewRatio ? "1:" + session.brewRatio : "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Temp</span>
                            <%= session.waterTemperatureC ? session.waterTemperatureC + " " + (session.waterTemperatureUnit || "°C") : "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Time</span>
                            <%= session.totalBrewTime || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Rating</span>
                            <%= session.overallRating || "-" %>
                        </td>
                        <td class="bean-history-action-cell">
                            <a href="/brew-sessions/<%= session.id %>" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>
                                View
                            </a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<% if (coffeeBean.bagImageUrl) { %>
    <div class="modal fade" id="beanPhotoModal" tabindex="-1" aria-labelledby="beanPhotoModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="beanPhotoModalLabel">
                        <%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %>
                    </h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body text-center bg-body-tertiary">
                    <img
                        src="<%= coffeeBean.bagImageUrl %>"
                        alt="<%= coffeeBean.beanName %> picture enlarged"
                        class="img-fluid rounded bean-photo-modal-image">
                </div>
            </div>
        </div>
    </div>
<% } %>
