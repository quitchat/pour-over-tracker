<style>
    .bean-notes-display {
        white-space: pre-line;
    }

    .bean-rating-stars {
        color: #f5b301 !important;
        letter-spacing: 0.05rem;
        white-space: nowrap;
    }

    .bean-rating-stars .bi,
    .bean-rating-stars i {
        color: #f5b301 !important;
    }
</style>

<%

    function getBeanHistoryBrewSummaryText(session) {
        const dose = session.coffeeDoseGrams ? `${session.coffeeDoseGrams}g` : "-";
        const totalYield = session.totalYieldGrams ? `${session.totalYieldGrams}g` : "-";
        const waterTemperature = session.waterTemperatureC ? ` @ ${session.waterTemperatureC}${session.waterTemperatureUnit || "°C"}` : "";
        const totalBrewTime = session.totalBrewTime ? ` over ${session.totalBrewTime}` : "";

        if (dose === "-" && totalYield === "-" && !waterTemperature && !totalBrewTime) {
            return "-";
        }

        return `${dose} → ${totalYield}${waterTemperature}${totalBrewTime}`;
    }

    function getBeanHistoryBrewSummarySubtext(session) {
        if (!session.brewRatio) {
            return "";
        }

        return `Ratio 1:${session.brewRatio}`;
    }

    function renderRatingStars(value, emptyText = "-") {
        if (value === null || value === undefined || value === "") {
            return `<span class="text-muted">${emptyText}</span>`;
        }

        const numericValue = Number(value);

        if (Number.isNaN(numericValue)) {
            return `<span class="text-muted">${emptyText}</span>`;
        }

        const clampedValue = Math.max(0, Math.min(5, numericValue));
        const displayValue = Number.isInteger(clampedValue) ? clampedValue.toFixed(0) : clampedValue.toFixed(1);
        let html = `<span class="readonly-rating-display" style="white-space: nowrap;"><span class="readonly-rating-stars" style="white-space: nowrap;" aria-label="${displayValue} out of 5 stars">`;

        for (let index = 1; index <= 5; index++) {
            if (clampedValue >= index) {
                html += `<i class="bi bi-star-fill" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            } else if (clampedValue >= index - 0.5) {
                html += `<i class="bi bi-star-half" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            } else {
                html += `<i class="bi bi-star" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i>`;
            }
        }

        html += `</span>`;
        return html;
    }
%>

<style>
    .bean-history-mobile-label {
        display: none;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.1rem;
    }

    .bean-best-setup-card {
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        padding: 0.75rem;
        background: var(--bs-body-bg);
    }

    .bean-photo-detail-button {
        display: block;
        width: 100%;
        border: 0;
        padding: 0;
        background: transparent;
        border-radius: 0.5rem;
    }

    .bean-photo-detail-button:hover img,
    .bean-photo-detail-button:focus img {
        border-color: var(--bs-primary) !important;
        box-shadow: 0 0 0 0.2rem rgba(var(--bs-primary-rgb), 0.2);
    }

    .bean-photo-modal-image {
        max-height: 82vh;
        object-fit: contain;
    }

    .bean-history-brew-summary {
        white-space: nowrap;
    }

    .bean-history-muted {
        color: var(--bs-secondary-color);
        font-size: 0.875rem;
    }

    .bean-detail-actions .btn,
    .bean-detail-actions button {
        white-space: nowrap;
    }

    @media (min-width: 992px) {
        .bean-detail-actions {
            align-items: center;
            flex-wrap: nowrap !important;
            justify-content: flex-end;
            margin-left: auto;
        }

        .bean-detail-actions form {
            display: inline-flex;
            flex: 0 0 auto;
            margin: 0;
        }
    }

    @media (max-width: 991.98px) {
        .bean-detail-header {
            align-items: stretch !important;
        }

        .bean-detail-actions .btn,
        .bean-detail-actions form,
        .bean-detail-actions button {
            width: 100%;
        }

        .bean-history-table thead {
            display: none;
        }

        .bean-history-table,
        .bean-history-table tbody,
        .bean-history-table tr,
        .bean-history-table td {
            display: block;
            width: 100%;
        }

        .bean-history-table tr {
            border-bottom: 1px solid var(--bs-border-color);
            padding: 0.75rem 0;
        }

        .bean-history-table td {
            border: 0;
            padding: 0.35rem 1rem;
        }

        .bean-history-mobile-label {
            display: block;
        }

        .bean-history-action-cell .btn {
            width: 100%;
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 gap-3 flex-column flex-lg-row bean-detail-header">
    <div>
        <h1 class="h3 mb-1">
            <span class="coffee-bean-icon me-2" aria-hidden="true"></span>
            <%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %>
        </h1>
        <p class="text-muted mb-0">
            Coffee bean detail and brew history.
        </p>
    </div>

    <div class="d-flex gap-2 flex-wrap flex-lg-nowrap justify-content-lg-end bean-detail-actions">
        <% if (coffeeBean.isActive) { %>
            <a href="/brew-sessions/new?coffeeBeanId=<%= coffeeBean.id %>" class="btn btn-outline-success">
                <i class="bi bi-plus-circle me-1"></i>
                Create Brew
            </a>
        <% } %>

        <a href="/coffee-beans/<%= coffeeBean.id %>/edit" class="btn btn-outline-primary">
            <i class="bi bi-pencil-square me-1"></i>
            Edit
        </a>

        <% if (coffeeBean.isActive) { %>
            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/deactivate">
                <button type="submit" class="btn btn-outline-danger">
                    Deactivate
                </button>
            </form>
        <% } else { %>
            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/reactivate">
                <button type="submit" class="btn btn-outline-success">
                    Reactivate
                </button>
            </form>
        <% } %>

        <% if (stats.brewSessionCount === 0) { %>
            <form method="post" action="/coffee-beans/<%= coffeeBean.id %>/delete" onsubmit="return confirm('Delete this coffee bean permanently? This is only allowed because it has no brew sessions.');">
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>
                    Delete
                </button>
            </form>
        <% } %>

        <a href="/coffee-beans" class="btn btn-outline-secondary">
            <i class="bi bi-list-ul me-1"></i>
            Back to Beans
        </a>
    </div>
</div>

<% if (message) { %>
    <div class="alert alert-success">
        <%= message %>
    </div>
<% } %>

<% if (errorMessage) { %>
    <div class="alert alert-danger">
        <%= errorMessage %>
    </div>
<% } %>

<% if (!coffeeBean.isActive) { %>
    <div class="alert alert-secondary">
        This coffee bean is inactive.
        <% if (coffeeBean.deactivatedAt) { %>
            It was deactivated on <%= coffeeBean.deactivatedAt %>.
        <% } %>
        Historical brew sessions are preserved, but you cannot create new brews from this bean until it is reactivated.
    </div>
<% } %>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-card-checklist me-1"></i>
                Bean Information
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <% if (coffeeBean.isActive) { %>
                            <span class="badge text-bg-success">Active</span>
                        <% } else { %>
                            <span class="badge text-bg-secondary">Inactive</span>
                        <% } %>
                    </dd>

                    <% if (coffeeBean.roasterName) { %>
                        <dt class="col-sm-4">Roaster</dt>
                        <dd class="col-sm-8"><%= coffeeBean.roasterName %></dd>
                    <% } %>

                    <% if (coffeeBean.beanName) { %>
                        <dt class="col-sm-4">Coffee Name</dt>
                        <dd class="col-sm-8"><%= coffeeBean.beanName %></dd>
                    <% } %>

                    <% if (coffeeBean.country) { %>
                        <dt class="col-sm-4">Country / Countries</dt>
                        <dd class="col-sm-8">
                            <%- getCountryFlagHtml(coffeeBean.country) %><%= coffeeBean.country %>
                            <a href="/analytics/origin-map?beanId=<%= coffeeBean.id %>" class="ms-2 text-decoration-none align-baseline" title="Show this origin on the map" aria-label="Show this origin on the map">
                                <i class="bi bi-geo"></i>
                            </a>
                        </dd>
                    <% } %>

                    <% if (coffeeBean.origin) { %>
                        <dt class="col-sm-4">Origin / Region</dt>
                        <dd class="col-sm-8"><% if (!coffeeBean.country) { %><%- getOriginCountryFlagHtml(coffeeBean.origin) %><% } %><%= coffeeBean.origin %></dd>
                    <% } %>

                    <% if (coffeeBean.process) { %>
                        <dt class="col-sm-4">Process</dt>
                        <dd class="col-sm-8"><%= coffeeBean.process %></dd>
                    <% } %>

                    <% if (coffeeBean.roastLevel) { %>
                        <dt class="col-sm-4">Roast Level</dt>
                        <dd class="col-sm-8"><%= coffeeBean.roastLevel %></dd>
                    <% } %>

                    <% if (coffeeBean.rating !== null && coffeeBean.rating !== undefined && coffeeBean.rating !== "") { %>
                        <dt class="col-sm-4">Bean Rating</dt>
                        <dd class="col-sm-8">
                            <% const beanRatingValue = Number(coffeeBean.rating); %>
                            <span class="bean-rating-stars" style="white-space: nowrap;" aria-label="<%= coffeeBean.rating %> out of 5 stars">
                                <% for (let i = 1; i <= 5; i++) { %><% if (beanRatingValue >= i) { %><i class="bi bi-star-fill" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i><% } else if (beanRatingValue >= i - 0.5) { %><i class="bi bi-star-half" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i><% } else { %><i class="bi bi-star" style="color: #f5b301; -webkit-text-fill-color: #f5b301; line-height: 1;"></i><% } %><% } %>
                            </span>
                        </dd>
                    <% } %>

                    <dt class="col-sm-4">Remaining Inventory</dt>
                    <dd class="col-sm-8">
                        <a href="/coffee-beans/<%= coffeeBean.id %>/inventory" class="text-decoration-none fw-semibold">
                            <i class="bi bi-box-seam me-1"></i>
                            <%= formatInventoryGrams(inventorySummary.totalAvailableGrams) %> g
                        </a>
                        <div class="form-text">Click to manage bags, replenishments, and adjustments.</div>
                    </dd>

                    <% if (coffeeBean.flavorNotes) { %>
                        <dt class="col-sm-4">Flavor Notes</dt>
                        <dd class="col-sm-8"><%= coffeeBean.flavorNotes %></dd>
                    <% } %>

                    <% if (coffeeBean.sourceUrl) { %>
                        <dt class="col-sm-4">Source</dt>
                        <dd class="col-sm-8">
                            <a href="<%= coffeeBean.sourceUrl %>" target="_blank" rel="noopener noreferrer">
                                <%= coffeeBean.sourceUrl %>
                            </a>
                        </dd>
                    <% } %>

                    <% if (coffeeBean.beanInfo) { %>
                        <dt class="col-sm-4">Bean Info</dt>
                        <dd class="col-sm-8"><div class="bean-notes-display"><%= coffeeBean.beanInfo %></div></dd>
                    <% } %>

                    <% if (coffeeBean.beanNotes) { %>
                        <dt class="col-sm-4">Bean Notes</dt>
                        <dd class="col-sm-8"><div class="bean-notes-display"><%= coffeeBean.beanNotes %></div></dd>
                    <% } %>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <% if (coffeeBean.bagImageUrl) { %>
            <div class="card mb-3">
                <div class="card-header">
                    <i class="bi bi-image me-1"></i>
                    Bean Picture
                </div>

                <div class="card-body">
                    <button
                        type="button"
                        class="bean-photo-detail-button"
                        data-bs-toggle="modal"
                        data-bs-target="#beanPhotoModal"
                        aria-label="Enlarge picture for <%= coffeeBean.beanName %>">
                        <img
                            src="<%= coffeeBean.bagImageUrl %>"
                            alt="<%= coffeeBean.beanName %> picture"
                            class="img-fluid rounded border w-100"
                            style="max-height: 360px; object-fit: cover;">
                    </button>
                    <div class="form-text text-center mt-2">Click photo to enlarge.</div>
                </div>
            </div>
        <% } %>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-speedometer2 me-1"></i>
                Bean Summary
            </div>

            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-muted small">Brews</div>
                        <div class="h3 mb-0"><%= stats.brewSessionCount %></div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Total Grams Brewed</div>
                        <div class="h3 mb-0"><%= stats.totalGramsBrewed || "0.0" %> g</div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Average Rating</div>
                        <div class="h3 mb-0"><%= stats.averageRating || "-" %></div>
                    </div>

                    <div class="col-6">
                        <div class="text-muted small">Best Rating</div>
                        <div class="h3 mb-0"><%= stats.bestRating || "-" %></div>
                    </div>

                </div>

                <% if (stats.bestBrewSessionId) { %>
                    <hr>

                    <div class="bean-best-setup-card">
                        <div class="fw-semibold mb-2">
                            <i class="bi bi-trophy me-1"></i>
                            Best Brew Setup
                        </div>

                        <div class="row g-2 small">
                            <div class="col-6 text-muted">Date</div>
                            <div class="col-6 text-end"><%= stats.bestBrewDate || "-" %></div>

                            <div class="col-6 text-muted">Grinder</div>
                            <div class="col-6 text-end"><%= stats.bestGrinderName || "-" %></div>

                            <div class="col-6 text-muted">Brewer</div>
                            <div class="col-6 text-end"><%= stats.bestBrewerName || "-" %></div>

                            <div class="col-6 text-muted">Grind</div>
                            <div class="col-6 text-end"><%= stats.bestGrindSize || "-" %></div>

                            <div class="col-6 text-muted">Dose → Yield</div>
                            <div class="col-6 text-end"><%= stats.bestDoseGrams || "-" %> → <%= stats.bestYieldGrams || "-" %></div>

                            <div class="col-6 text-muted">Ratio</div>
                            <div class="col-6 text-end"><%= stats.bestBrewRatio ? "1:" + stats.bestBrewRatio : "-" %></div>

                            <div class="col-6 text-muted">Water Temp</div>
                            <div class="col-6 text-end"><%= stats.bestWaterTemperatureC ? stats.bestWaterTemperatureC + " " + (stats.bestWaterTemperatureUnit || "°C") : "-" %></div>

                            <div class="col-6 text-muted">Time</div>
                            <div class="col-6 text-end"><%= stats.bestBrewTime || "-" %></div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <a href="/brew-sessions/<%= stats.bestBrewSessionId %>" class="btn btn-outline-primary w-100">
                            <i class="bi bi-trophy me-1"></i>
                            View Best Brew
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>


<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-journal-text me-1"></i>
            Brew History for This Bean
        </span>

        <span class="text-muted small"><%= brewSessions.length %> brew(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle bean-history-table">
            <thead>
                <tr>
                    <th>Brew Date</th>
                    <th>Grinder</th>
                    <th>Brewer</th>
                    <th>Grind</th>
                    <th>Brew</th>
                    <th>Rating</th>
                    <th style="width: 90px;">Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (brewSessions.length === 0) { %>
                    <tr>
                        <td colspan="7" class="text-muted text-center py-4">
                            No brew sessions yet for this bean.
                        </td>
                    </tr>
                <% } %>

                <% brewSessions.forEach(function (session) { %>
                    <tr>
                        <td>
                            <span class="bean-history-mobile-label">Brew Date</span>
                            <%= session.brewDate %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Grinder</span>
                            <%= session.grinderName || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Brewer</span>
                            <%= session.brewerName || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Grind</span>
                            <%= session.grindSize || "-" %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Brew</span>
                            <div class="bean-history-brew-summary"><%= getBeanHistoryBrewSummaryText(session) %></div>
                            <% if (getBeanHistoryBrewSummarySubtext(session)) { %>
                                <div class="bean-history-muted"><%= getBeanHistoryBrewSummarySubtext(session) %></div>
                            <% } %>
                        </td>
                        <td>
                            <span class="bean-history-mobile-label">Rating</span>
                            <%- renderRatingStars(session.overallRating, "-") %>
                        </td>
                        <td class="bean-history-action-cell">
                            <a href="/brew-sessions/<%= session.id %>" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>
                                View
                            </a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<% if (coffeeBean.bagImageUrl) { %>
    <div class="modal fade" id="beanPhotoModal" tabindex="-1" aria-labelledby="beanPhotoModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="beanPhotoModalLabel">
                        <%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %>
                    </h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body text-center bg-body-tertiary">
                    <img
                        src="<%= coffeeBean.bagImageUrl %>"
                        alt="<%= coffeeBean.beanName %> picture enlarged"
                        class="img-fluid rounded bean-photo-modal-image">
                </div>
            </div>
        </div>
    </div>
<% } %>
