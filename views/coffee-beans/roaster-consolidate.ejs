<%
    const roasters = typeof roasterOptions !== "undefined" ? roasterOptions : [];
    const aliases = typeof roasterAliases !== "undefined" ? roasterAliases : [];
    const data = typeof formData !== "undefined" ? formData : { canonicalRoasterName: "", sourceRoasterNames: [] };
    const selectedNames = Array.isArray(data.sourceRoasterNames) ? data.sourceRoasterNames : [];
    const pageErrors = typeof errors !== "undefined" ? errors : [];
    const pageMessage = typeof message !== "undefined" ? message : "";

    const groupedRoasters = roasters.reduce(function (groups, roaster) {
        const key = roaster.normalizedName || roaster.roasterName.toLowerCase();

        if (!groups[key]) {
            groups[key] = [];
        }

        groups[key].push(roaster);
        return groups;
    }, {});

    const suggestedGroups = Object.keys(groupedRoasters)
        .map(function (key) {
            return groupedRoasters[key];
        })
        .filter(function (group) {
            return group.length > 1;
        });
%>

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-3 gap-3 flex-column flex-md-row">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-intersect me-2"></i>
            Consolidate Roasters
        </h1>
        <p class="text-muted mb-0">
            Merge roaster name variants for your beans only. Alias links are saved for future bean info lookups.
        </p>
    </div>

    <a href="/coffee-beans" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>
        Back to Beans
    </a>
</div>

<% if (pageMessage) { %>
    <div class="alert alert-success" role="alert">
        <i class="bi bi-check-circle me-1"></i>
        <%= pageMessage %>
    </div>
<% } %>

<% if (pageErrors.length > 0) { %>
    <div class="alert alert-danger" role="alert">
        <div class="fw-semibold mb-1">Please fix the following:</div>
        <ul class="mb-0">
            <% pageErrors.forEach(function (error) { %>
                <li><%= error %></li>
            <% }); %>
        </ul>
    </div>
<% } %>

<% if (roasters.length === 0) { %>
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-shop fs-3 d-block mb-2"></i>
            No roaster names found yet.
        </div>
    </div>
<% } else { %>
    <form method="post" action="/coffee-beans/roasters/consolidate" id="roasterConsolidateForm">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <span>
                    <i class="bi bi-list-check me-1"></i>
                    Roaster Names
                </span>

                <span class="text-muted small"><%= roasters.length %> name(s)</span>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 3rem;">Use</th>
                            <th>Roaster Name</th>
                            <th class="text-end">Beans</th>
                            <th class="text-end" style="width: 9rem;">Target</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% roasters.forEach(function (roaster) { %>
                            <tr>
                                <td>
                                    <input
                                        class="form-check-input roaster-source-checkbox"
                                        type="checkbox"
                                        name="sourceRoasterNames"
                                        value="<%= roaster.roasterName %>"
                                        id="roaster-<%= roaster.roasterName.replace(/[^a-zA-Z0-9]/g, "-") %>"
                                        <%= selectedNames.includes(roaster.roasterName) ? "checked" : "" %>>
                                </td>
                                <td>
                                    <label class="form-check-label fw-semibold" for="roaster-<%= roaster.roasterName.replace(/[^a-zA-Z0-9]/g, "-") %>">
                                        <%= roaster.roasterName %>
                                    </label>
                                </td>
                                <td class="text-end"><%= roaster.beanCount %></td>
                                <td class="text-end">
                                    <button
                                        type="button"
                                        class="btn btn-sm btn-outline-secondary roaster-target-button"
                                        data-roaster="<%= roaster.roasterName %>">
                                        Use as Target
                                    </button>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-arrow-down-up me-1"></i>
                Consolidation Target
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-lg-7">
                        <label for="canonicalRoasterName" class="form-label">Preferred Roaster Name</label>
                        <input
                            type="text"
                            class="form-control"
                            id="canonicalRoasterName"
                            name="canonicalRoasterName"
                            list="roasterNameOptions"
                            value="<%= data.canonicalRoasterName || "" %>"
                            placeholder="Final roaster name, for example Sey Coffee">
                        <datalist id="roasterNameOptions">
                            <% roasters.forEach(function (roaster) { %>
                                <option value="<%= roaster.roasterName %>"></option>
                            <% }); %>
                        </datalist>
                        <div class="form-text">
                            Selected roaster names will be updated to this exact value. Their old names will be saved as aliases.
                        </div>
                    </div>

                    <div class="col-12 col-lg-5 text-lg-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle me-1"></i>
                            Consolidate Selected Roasters
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <% if (suggestedGroups.length > 0) { %>
            <div class="card mb-3">
                <div class="card-header">
                    <i class="bi bi-lightbulb me-1"></i>
                    Possible Matches
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        These groups have similar normalized names. Review before selecting; nothing is changed until you submit.
                    </p>

                    <div class="d-flex flex-column gap-2">
                        <% suggestedGroups.forEach(function (group, groupIndex) { %>
                            <div class="border rounded p-2">
                                <div class="d-flex justify-content-between align-items-start gap-2 flex-column flex-md-row">
                                    <div>
                                        <% group.forEach(function (roaster, index) { %>
                                            <span class="badge text-bg-light border me-1 mb-1">
                                                <%= roaster.roasterName %> · <%= roaster.beanCount %>
                                            </span>
                                        <% }); %>
                                    </div>

                                    <button
                                        type="button"
                                        class="btn btn-sm btn-outline-primary roaster-group-select"
                                        data-roasters="<%= group.map(function (roaster) { return roaster.roasterName; }).join("||") %>"
                                        data-target="<%= group.slice().sort(function (left, right) { return right.beanCount - left.beanCount; })[0].roasterName %>">
                                        Select Group
                                    </button>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            </div>
        <% } %>

        <% if (aliases.length > 0) { %>
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
                    <span>
                        <i class="bi bi-link-45deg me-1"></i>
                        Roaster Alias Crosswalk
                    </span>
                    <span class="text-muted small"><%= aliases.length %> alias(es)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Old / Alternate Name</th>
                                <th>Preferred Name</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% aliases.forEach(function (alias) { %>
                                <tr>
                                    <td><%= alias.aliasName %></td>
                                    <td class="fw-semibold"><%= alias.preferredName %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer text-muted small">
                    When bean info lookup or bag label reading sees an alternate roaster name, it uses the preferred name from this list.
                </div>
            </div>
        <% } %>
    </form>
<% } %>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const targetInput = document.getElementById("canonicalRoasterName");
        const checkboxes = Array.from(document.querySelectorAll(".roaster-source-checkbox"));

        document.querySelectorAll(".roaster-target-button").forEach(function (button) {
            button.addEventListener("click", function () {
                if (!targetInput) {
                    return;
                }

                targetInput.value = button.getAttribute("data-roaster") || "";
                targetInput.focus();
            });
        });

        document.querySelectorAll(".roaster-group-select").forEach(function (button) {
            button.addEventListener("click", function () {
                const roasterNames = (button.getAttribute("data-roasters") || "").split("||");
                const targetName = button.getAttribute("data-target") || "";

                if (targetInput) {
                    targetInput.value = targetName;
                }

                checkboxes.forEach(function (checkbox) {
                    checkbox.checked = roasterNames.includes(checkbox.value);
                });
            });
        });
    });
</script>
