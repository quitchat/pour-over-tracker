<% const userCanUseAi = !!(currentUser && currentUser.allowAi); %>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1"><%= pageHeading %></h1>
        <p class="text-muted mb-0">
            <% if (userCanUseAi) { %>
                Enter bean details manually or use AI to fill supported bean information.
            <% } else { %>
                Enter bean details manually.
            <% } %>
        </p>
    </div>

    <a href="/coffee-beans" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>
        Back to Beans
    </a>
</div>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <strong>Please fix the following:</strong>
        <ul class="mb-0">
            <% errors.forEach(function (error) { %>
                <li><%= error %></li>
            <% }); %>
        </ul>
    </div>
<% } %>

<div id="coffeeInfoAjaxMessage"></div>

<style>
    .bean-star-rating-control {
        display: inline-flex;
        align-items: center;
        gap: 0.15rem;
    }

    .bean-star-rating-button {
        position: relative;
        width: 2.1rem;
        height: 2.1rem;
        border: 0;
        background: transparent;
        padding: 0;
        line-height: 1;
        cursor: pointer;
    }

    .bean-star-rating-button:focus-visible {
        outline: 2px solid var(--bs-primary);
        outline-offset: 2px;
        border-radius: 0.35rem;
    }

    .bean-star-rating-empty,
    .bean-star-rating-filled {
        position: absolute;
        left: 0;
        top: 0;
        font-size: 2rem;
    }

    .bean-star-rating-empty {
        color: #dee2e6;
    }

    .bean-star-rating-filled {
        color: #ffc107;
        width: var(--bean-star-fill-width, 0%);
        overflow: hidden;
        white-space: nowrap;
    }

    .bean-star-rating-button:hover .bean-star-rating-empty {
        color: #ced4da;
    }

    @media (max-width: 767.98px) {
        .bean-star-rating-button {
            width: 2.4rem;
            height: 2.4rem;
        }

        .bean-star-rating-empty,
        .bean-star-rating-filled {
            font-size: 2.3rem;
        }
    }
</style>

<form method="post" action="<%= formAction %>" id="coffeeBeanForm" enctype="multipart/form-data">
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-cup-hot me-1"></i>
                Bean Info
            </span>

            <% if (userCanUseAi) { %>
                <button type="button" class="btn btn-sm btn-outline-success" id="getCoffeeInfoButton">
                    <i class="bi bi-stars me-1"></i>
                    Get Coffee Information
                </button>
            <% } %>
        </div>

        <div class="card-body">
            <p class="text-muted">
                <% if (userCanUseAi) { %>
                    Upload a bean bag picture first to let AI read the roaster and coffee name, or enter them manually.
                <% } else { %>
                    Upload a bean bag picture or enter bean details manually.
                <% } %>
            </p>

            <div class="row g-3">
                <div class="col-12">
                    <label for="bagImageFile" class="form-label">Bean Bag Picture</label>

                    <input
                        type="hidden"
                        id="bagImageUrl"
                        name="bagImageUrl"
                        value="<%= formData.bagImageUrl || "" %>">

                    <div id="bagImagePreviewContainer" class="mb-2 <%= formData.bagImageUrl ? "" : "d-none" %>">
                        <img
                            src="<%= formData.bagImageUrl || "" %>"
                            alt="Current bean picture"
                            id="bagImagePreview"
                            class="img-thumbnail"
                            style="max-width: 220px; max-height: 220px; object-fit: cover;">
                    </div>

                    <% if (formData.bagImageUrl) { %>
                        <div class="form-check mb-2" id="removeBagImageContainer">
                            <input
                                class="form-check-input"
                                type="checkbox"
                                value="1"
                                id="removeBagImage"
                                name="removeBagImage">
                            <label class="form-check-label" for="removeBagImage">
                                Remove current picture
                            </label>
                        </div>
                    <% } %>

                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <input
                            type="file"
                            class="visually-hidden"
                            id="bagImageFile"
                            name="bagImageFile"
                            accept="image/*">

                        <label class="btn btn-outline-secondary mb-0" for="bagImageFile" title="Choose bean bag picture">
                            <i class="bi bi-image me-1"></i>
                            <span class="d-none d-sm-inline">Choose Photo</span>
                        </label>

                        <span class="text-muted small" id="bagImageFileName">No photo selected</span>

                        <% if (isEdit || userCanUseAi) { %>
                            <button
                                type="button"
                                class="btn btn-outline-primary"
                                id="uploadBagImageButton">
                                <i class="bi bi-upload me-1"></i>
                                <% if (isEdit) { %>
                                    <span>Upload</span>
                                <% } else { %>
                                    <span class="d-none d-sm-inline">Upload + Read Label + Get Info</span>
                                    <span class="d-inline d-sm-none">Read Bag + Get Info</span>
                                <% } %>
                            </button>
                        <% } %>
                    </div>

                    <div class="form-text">
                        Upload JPG, PNG, WEBP, or GIF. Maximum upload size: 12 MB. The server will resize and compress it automatically.
                        On a phone, you can choose from the photo library or take a new picture with the rear camera.
                        <% if (isEdit) { %>
                            The Upload button saves the selected image only.
                        <% } else if (userCanUseAi) { %>
                            The upload button saves the image, reads Roaster and Coffee Name, then automatically gets bean information when both values are found.
                        <% } else { %>
                            The selected image will be saved when you save the coffee bean.
                        <% } %>
                    </div>
                </div>
                <div class="col-md-6">
                    <label for="roasterName" class="form-label">Roaster</label>
                    <input
                        type="text"
                        class="form-control"
                        id="roasterName"
                        name="roasterName"
                        list="roasterSuggestions"
                        value="<%= formData.roasterName || "" %>">

                    <datalist id="roasterSuggestions">
                        <% roasterSuggestions.forEach(function (roasterName) { %>
                            <option value="<%= roasterName %>"></option>
                        <% }); %>
                    </datalist>
                </div>

                <div class="col-md-6">
                    <label for="beanName" class="form-label">Coffee Name</label>
                    <input
                        type="text"
                        class="form-control"
                        id="beanName"
                        name="beanName"
                        value="<%= formData.beanName || "" %>">
                </div>

                <div class="col-md-6">
                    <label for="origin" class="form-label">Origin</label>
                    <input
                        type="text"
                        class="form-control"
                        id="origin"
                        name="origin"
                        value="<%= formData.origin || "" %>">
                </div>

                <div class="col-md-6">
                    <label for="process" class="form-label">Process</label>
                    <input
                        type="text"
                        class="form-control"
                        id="process"
                        name="process"
                        value="<%= formData.process || "" %>">
                </div>

                <div class="col-md-6">
                    <label for="roastLevel" class="form-label">Roast Level</label>
                    <select class="form-select" id="roastLevel" name="roastLevel">
                        <option value="">Select roast level</option>
                        <option value="Light" <%= formData.roastLevel === "Light" ? "selected" : "" %>>Light</option>
                        <option value="Medium" <%= formData.roastLevel === "Medium" ? "selected" : "" %>>Medium</option>
                        <option value="Dark" <%= formData.roastLevel === "Dark" ? "selected" : "" %>>Dark</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label for="roastDate" class="form-label">Roast Date</label>
                    <input
                        type="date"
                        class="form-control"
                        id="roastDate"
                        name="roastDate"
                        value="<%= formData.roastDate || "" %>">
                </div>

                <div class="col-md-6">
                    <label for="price" class="form-label">Price US$</label>
                    <input
                        type="number"
                        step="0.01"
                        min="0"
                        class="form-control"
                        id="price"
                        name="price"
                        value="<%= formData.price || "" %>">
                </div>

                <div class="col-md-6">
                    <label class="form-label d-flex justify-content-between align-items-center" for="rating">
                        <span>Bean Rating</span>
                        <span class="text-muted small" id="beanRatingDisplay">No rating</span>
                    </label>

                    <input
                        type="hidden"
                        id="rating"
                        name="rating"
                        value="<%= formData.rating || "" %>">

                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="bean-star-rating-control" id="beanRatingStars" role="radiogroup" aria-label="Bean rating">
                            <% [1, 2, 3, 4, 5].forEach(function (starNumber) { %>
                                <button
                                    type="button"
                                    class="bean-star-rating-button"
                                    data-star-number="<%= starNumber %>"
                                    aria-label="Rate <%= starNumber %> star">
                                    <i class="bi bi-star-fill bean-star-rating-empty"></i>
                                    <i class="bi bi-star-fill bean-star-rating-filled"></i>
                                </button>
                            <% }); %>
                        </div>

                        <button type="button" class="btn btn-sm btn-outline-secondary" id="clearBeanRatingButton">
                            Clear
                        </button>
                    </div>

                </div>

                <div class="col-md-6">
                    <label for="sourceUrl" class="form-label">Source URL</label>
                    <input
                        type="url"
                        class="form-control"
                        id="sourceUrl"
                        name="sourceUrl"
                        value="<%= formData.sourceUrl || "" %>">
                </div>


                <div class="col-12">
                    <label for="flavorNotes" class="form-label">Flavor Notes</label>
                    <textarea
                        class="form-control"
                        id="flavorNotes"
                        name="flavorNotes"
                        rows="3"><%= formData.flavorNotes || "" %></textarea>
                </div>

                <div class="col-12">
                    <label for="beanInfo" class="form-label">Bean Info</label>
                    <textarea
                        class="form-control"
                        id="beanInfo"
                        name="beanInfo"
                        rows="4"
                        placeholder="Factual bean information confirmed by the roaster or AI lookup."><%= formData.beanInfo || "" %></textarea>
                </div>

                <div class="col-12">
                    <label for="beanNotes" class="form-label">Bean Notes</label>
                    <textarea
                        class="form-control"
                        id="beanNotes"
                        name="beanNotes"
                        rows="4"
                        placeholder="Your own notes about this bean."><%= formData.beanNotes || "" %></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3 d-none" id="confirmedAiNotesCard">
        <div class="card-header">
            <i class="bi bi-info-circle me-1"></i>
            Confirmed AI Notes
        </div>

        <div class="card-body">
            <ul class="mb-0" id="confirmedAiNotesList"></ul>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save me-1"></i>
            <%= submitButtonText %>
        </button>

        <a href="/coffee-beans" class="btn btn-outline-secondary">
            Cancel
        </a>
    </div>
</form>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const beanRatingInput = document.getElementById("rating");
        const beanRatingDisplay = document.getElementById("beanRatingDisplay");
        const beanRatingButtons = document.querySelectorAll(".bean-star-rating-button");
        const clearBeanRatingButton = document.getElementById("clearBeanRatingButton");

        function normalizeBeanRatingValue(value) {
            if (value === null || typeof value === "undefined" || value === "") {
                return "";
            }

            const parsed = Number(value);

            if (Number.isNaN(parsed) || parsed <= 0) {
                return "";
            }

            const clamped = Math.min(5, Math.max(0.5, parsed));
            const roundedToHalf = Math.round(clamped * 2) / 2;

            if (Number.isInteger(roundedToHalf)) {
                return String(roundedToHalf);
            }

            return roundedToHalf.toFixed(1);
        }

        function getBeanRatingDisplayText(value) {
            const normalized = normalizeBeanRatingValue(value);

            if (!normalized) {
                return "No rating";
            }

            return normalized + " / 5";
        }

        function setBeanStarVisual(value) {
            const normalized = normalizeBeanRatingValue(value);
            const rating = normalized ? Number(normalized) : 0;

            beanRatingButtons.forEach(function (button) {
                const starNumber = Number(button.getAttribute("data-star-number") || "0");
                let fillWidth = 0;

                if (rating >= starNumber) {
                    fillWidth = 100;
                } else if (rating >= starNumber - 0.5) {
                    fillWidth = 50;
                }

                button.style.setProperty("--bean-star-fill-width", fillWidth + "%");
            });
        }

        function setBeanRating(value) {
            const normalized = normalizeBeanRatingValue(value);

            if (beanRatingInput) {
                beanRatingInput.value = normalized;
            }

            if (beanRatingDisplay) {
                beanRatingDisplay.textContent = getBeanRatingDisplayText(normalized);
            }

            setBeanStarVisual(normalized);
        }

        function getBeanRatingFromPointerEvent(button, event) {
            const starNumber = Number(button.getAttribute("data-star-number") || "0");
            const buttonRect = button.getBoundingClientRect();
            const offsetX = event.clientX - buttonRect.left;
            const isLeftHalf = offsetX <= buttonRect.width / 2;

            if (isLeftHalf) {
                return starNumber - 0.5;
            }

            return starNumber;
        }

        beanRatingButtons.forEach(function (button) {
            button.addEventListener("mousemove", function (event) {
                const previewRating = getBeanRatingFromPointerEvent(button, event);

                setBeanStarVisual(previewRating);

                if (beanRatingDisplay) {
                    beanRatingDisplay.textContent = getBeanRatingDisplayText(previewRating);
                }
            });

            button.addEventListener("mouseleave", function () {
                const currentValue = beanRatingInput ? beanRatingInput.value : "";

                setBeanStarVisual(currentValue);

                if (beanRatingDisplay) {
                    beanRatingDisplay.textContent = getBeanRatingDisplayText(currentValue);
                }
            });

            button.addEventListener("click", function (event) {
                const selectedRating = getBeanRatingFromPointerEvent(button, event);

                setBeanRating(selectedRating);
            });
        });

        if (clearBeanRatingButton) {
            clearBeanRatingButton.addEventListener("click", function () {
                setBeanRating("");
            });
        }

        if (beanRatingInput) {
            setBeanRating(beanRatingInput.value);
        }

        const isEditMode = <%= isEdit ? "true" : "false" %>;
        const coffeeBeanForm = document.getElementById("coffeeBeanForm");
        const getCoffeeInfoButton = document.getElementById("getCoffeeInfoButton");
        const uploadBagImageButton = document.getElementById("uploadBagImageButton");
        const bagImageFileInput = document.getElementById("bagImageFile");
        const bagImageFileName = document.getElementById("bagImageFileName");
        const bagImageUrlInput = document.getElementById("bagImageUrl");
        const bagImagePreviewContainer = document.getElementById("bagImagePreviewContainer");
        const bagImagePreview = document.getElementById("bagImagePreview");
        const removeBagImageCheckbox = document.getElementById("removeBagImage");
        const messageContainer = document.getElementById("coffeeInfoAjaxMessage");
        const confirmedAiNotesCard = document.getElementById("confirmedAiNotesCard");
        const confirmedAiNotesList = document.getElementById("confirmedAiNotesList");

        function getElementValue(id) {
            const element = document.getElementById(id);

            if (!element) {
                return "";
            }

            return element.value || "";
        }

        function setElementValue(id, value) {
            const element = document.getElementById(id);

            if (element) {
                element.value = value || "";
            }
        }

        function escapeHtml(value) {
            return String(value || "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function showMessage(type, message) {
            if (!messageContainer) {
                return;
            }

            messageContainer.innerHTML =
                '<div class="alert alert-' + type + '">' +
                escapeHtml(message) +
                '</div>';
        }

        function clearMessage() {
            if (messageContainer) {
                messageContainer.innerHTML = "";
            }
        }

        function setButtonLoading(isLoading) {
            if (!getCoffeeInfoButton) {
                return;
            }

            if (isLoading) {
                getCoffeeInfoButton.disabled = true;
                getCoffeeInfoButton.innerHTML =
                    '<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>' +
                    'Getting Coffee Info...';
            } else {
                getCoffeeInfoButton.disabled = false;
                getCoffeeInfoButton.innerHTML =
                    '<i class="bi bi-stars me-1"></i>' +
                    'Get Coffee Information';
            }
        }

        function setUploadBagImageButtonLoading(isLoading) {
            if (!uploadBagImageButton) {
                return;
            }

            if (isLoading) {
                uploadBagImageButton.disabled = true;
                uploadBagImageButton.innerHTML =
                    '<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>' +
                    (isEditMode ? 'Uploading...' : 'Reading bag...');
            } else {
                uploadBagImageButton.disabled = false;

                if (isEditMode) {
                    uploadBagImageButton.innerHTML =
                        '<i class="bi bi-upload me-1"></i>' +
                        '<span>Upload</span>';
                } else {
                    uploadBagImageButton.innerHTML =
                        '<i class="bi bi-upload me-1"></i>' +
                        '<span class="d-none d-sm-inline">Upload + Read Label + Get Info</span>' +
                        '<span class="d-inline d-sm-none">Read Bag + Get Info</span>';
                }
            }
        }

        function setBagImagePreview(imageUrl) {
            if (bagImageUrlInput) {
                bagImageUrlInput.value = imageUrl || "";
            }

            if (bagImagePreview && bagImagePreviewContainer && imageUrl) {
                bagImagePreview.src = imageUrl;
                bagImagePreviewContainer.classList.remove("d-none");
            }

            if (removeBagImageCheckbox && imageUrl) {
                removeBagImageCheckbox.checked = false;
            }
        }

        function populateConfirmedNotes(confirmedNotes) {
            if (!confirmedAiNotesCard || !confirmedAiNotesList) {
                return;
            }

            confirmedAiNotesList.innerHTML = "";

            if (!confirmedNotes || confirmedNotes.length === 0) {
                confirmedAiNotesCard.classList.add("d-none");
                return;
            }

            confirmedNotes.forEach(function (note) {
                const item = document.createElement("li");
                item.textContent = note;
                confirmedAiNotesList.appendChild(item);
            });

            confirmedAiNotesCard.classList.remove("d-none");
        }

        function populateForm(formData) {
            if (formData.roasterName) {
                setElementValue("roasterName", formData.roasterName);
            }

            if (formData.beanName) {
                setElementValue("beanName", formData.beanName);
            }

            setElementValue("origin", formData.origin);
            setElementValue("process", formData.process);
            setElementValue("roastLevel", formData.roastLevel);
            setElementValue("flavorNotes", formData.flavorNotes);
            setElementValue("sourceUrl", formData.sourceUrl);
            setElementValue("beanInfo", formData.beanInfo);
        }


        if (bagImageFileInput && bagImageFileName) {
            bagImageFileInput.addEventListener("change", function () {
                if (!bagImageFileInput.files || bagImageFileInput.files.length === 0) {
                    bagImageFileName.textContent = "No photo selected";
                    return;
                }

                bagImageFileName.textContent = bagImageFileInput.files[0].name;
            });
        }

        function uploadBagImageOnly() {
            clearMessage();

            if (!bagImageFileInput || !bagImageFileInput.files || bagImageFileInput.files.length === 0) {
                showMessage("warning", "Choose a bean bag picture first.");
                return;
            }

            if (!coffeeBeanForm) {
                showMessage("danger", "Could not find the coffee bean form.");
                return;
            }

            setUploadBagImageButtonLoading(true);

            if (typeof coffeeBeanForm.requestSubmit === "function") {
                coffeeBeanForm.requestSubmit();
            } else {
                coffeeBeanForm.submit();
            }
        }

        async function uploadBagImageAndIdentify() {
            clearMessage();

            if (!bagImageFileInput || !bagImageFileInput.files || bagImageFileInput.files.length === 0) {
                showMessage("warning", "Choose a bean bag picture first.");
                return;
            }

            const formData = new FormData();
            formData.append("bagImageFile", bagImageFileInput.files[0]);

            setUploadBagImageButtonLoading(true);

            const controller = new AbortController();
            const timeoutId = window.setTimeout(function () {
                controller.abort();
            }, 90000);

            try {
                const response = await fetch("/coffee-beans/upload-bag-image-identify", {
                    method: "POST",
                    headers: {
                        "Accept": "application/json",
                        "X-Requested-With": "fetch"
                    },
                    body: formData,
                    credentials: "same-origin",
                    signal: controller.signal
                });

                let data = null;

                try {
                    data = await response.json();
                } catch {
                    data = null;
                }

                if (data && data.bagImageUrl) {
                    setBagImagePreview(data.bagImageUrl);

                    if (bagImageFileInput) {
                        bagImageFileInput.value = "";
                    }
                }

                if (!response.ok || !data || !data.ok) {
                    const errorMessage = data && data.errorMessage
                        ? data.errorMessage
                        : "Could not upload and read the bean bag picture.";

                    showMessage("danger", errorMessage);
                    return;
                }

                if (data.formData) {
                    populateForm(data.formData);
                }

                populateConfirmedNotes([]);

                const confidenceText = data.confidence ? " Confidence: " + data.confidence + "." : "";
                const roasterName = getElementValue("roasterName").trim();
                const beanName = getElementValue("beanName").trim();

                if (roasterName && beanName) {
                    showMessage("info", "Bean bag picture uploaded and label fields were read." + confidenceText + " Getting coffee information...");

                    await getCoffeeInformation({
                        clearExistingMessage: false,
                        manageButtonLoading: false,
                        successMessage: "Bean bag picture uploaded, label fields read, and coffee information filled. Review everything before saving.",
                        failureMessagePrefix: "Bean bag picture uploaded and label fields were read, but coffee information lookup failed."
                    });

                    return;
                }

                showMessage("success", "Bean bag picture uploaded and any readable label fields were filled. Enter Roaster and Coffee Name, then use Get Coffee Information." + confidenceText);
            } catch (error) {
                if (error && error.name === "AbortError") {
                    showMessage("danger", "Uploading and reading the bean bag picture took too long. Please try again.");
                } else {
                    showMessage("danger", "Could not upload and read the bean bag picture.");
                }
            } finally {
                window.clearTimeout(timeoutId);
                setUploadBagImageButtonLoading(false);
            }
        }

        async function getCoffeeInformation(options) {
            const settings = Object.assign({
                clearExistingMessage: true,
                manageButtonLoading: true,
                successMessage: "Coffee information filled. Review it before saving.",
                failureMessagePrefix: ""
            }, options || {});

            if (settings.clearExistingMessage) {
                clearMessage();
            }

            const roasterName = getElementValue("roasterName").trim();
            const beanName = getElementValue("beanName").trim();

            if (!roasterName || !beanName) {
                showMessage("warning", "Enter Roaster and Coffee Name before getting coffee information.");
                return false;
            }

            if (settings.manageButtonLoading) {
                setButtonLoading(true);
            }

            const controller = new AbortController();
            const timeoutId = window.setTimeout(function () {
                controller.abort();
            }, 90000);

            const body = new URLSearchParams();
            body.set("roasterName", roasterName);
            body.set("beanName", beanName);
            body.set("origin", getElementValue("origin"));
            body.set("process", getElementValue("process"));
            body.set("roastLevel", getElementValue("roastLevel"));
            body.set("flavorNotes", getElementValue("flavorNotes"));
            body.set("sourceUrl", getElementValue("sourceUrl"));
            body.set("beanInfo", getElementValue("beanInfo"));

            try {
                const response = await fetch("/coffee-beans/get-info", {
                    method: "POST",
                    headers: {
                        "Accept": "application/json",
                        "Content-Type": "application/x-www-form-urlencoded",
                        "X-Requested-With": "fetch"
                    },
                    body: body.toString(),
                    credentials: "same-origin",
                    signal: controller.signal
                });

                let data = null;

                try {
                    data = await response.json();
                } catch {
                    data = null;
                }

                if (!response.ok || !data || !data.ok) {
                    const baseErrorMessage = data && data.errorMessage
                        ? data.errorMessage
                        : "Could not get coffee information.";
                    const errorMessage = settings.failureMessagePrefix
                        ? settings.failureMessagePrefix + " " + baseErrorMessage
                        : baseErrorMessage;

                    showMessage("danger", errorMessage);
                    return false;
                }

                populateForm(data.formData || {});
                populateConfirmedNotes(data.confirmedNotes || []);
                showMessage("success", settings.successMessage);
                return true;
            } catch (error) {
                let errorMessage = "Could not get coffee information.";

                if (error && error.name === "AbortError") {
                    errorMessage = "Getting coffee information took too long. Please try again.";
                }

                if (settings.failureMessagePrefix) {
                    errorMessage = settings.failureMessagePrefix + " " + errorMessage;
                }

                showMessage("danger", errorMessage);
                return false;
            } finally {
                window.clearTimeout(timeoutId);

                if (settings.manageButtonLoading) {
                    setButtonLoading(false);
                }
            }
        }

        if (uploadBagImageButton) {
            uploadBagImageButton.addEventListener("click", function () {
                if (isEditMode) {
                    uploadBagImageOnly();
                    return;
                }

                uploadBagImageAndIdentify();
            });
        }

        if (getCoffeeInfoButton) {
            getCoffeeInfoButton.addEventListener("click", getCoffeeInformation);
        }
    });
</script>
