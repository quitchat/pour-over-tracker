<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1"><%= pageHeading %></h1>
        <p class="text-muted mb-0"><%= coffeeBean.roasterName ? coffeeBean.roasterName + " - " : "" %><%= coffeeBean.beanName %></p>
    </div>
    <a href="/coffee-beans/<%= coffeeBean.id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Bean</a>
</div>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger"><strong>Please fix the following:</strong><ul class="mb-0"><% errors.forEach(function (error) { %><li><%= error %></li><% }); %></ul></div>
<% } %>

<form method="post" action="/coffee-beans/<%= coffeeBean.id %>/replenishments">
    <div class="card mb-3">
        <div class="card-header"><i class="bi bi-bag-plus me-1"></i>Bag / Purchase</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="quantity" class="form-label">Quantity</label>
                    <input type="number" min="1" step="1" class="form-control" id="quantity" name="quantity" value="<%= formData.quantity || "1" %>">
                </div>
                <div class="col-md-4">
                    <label for="bagSize" class="form-label">Bag Size</label>
                    <input type="number" min="0" step="0.01" class="form-control" id="bagSize" name="bagSize" value="<%= formData.bagSize || "" %>">
                </div>
                <div class="col-md-4">
                    <label for="bagSizeUnit" class="form-label">Unit</label>
                    <select class="form-select" id="bagSizeUnit" name="bagSizeUnit">
                        <option value="G" <%= formData.bagSizeUnit === "G" ? "selected" : "" %>>g</option>
                        <option value="OZ" <%= formData.bagSizeUnit === "OZ" ? "selected" : "" %>>oz</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label for="roastDate" class="form-label">Roast Date</label>
                    <input type="date" class="form-control" id="roastDate" name="roastDate" value="<%= formData.roastDate || "" %>">
                </div>
                <div class="col-md-6">
                    <label for="purchaseDate" class="form-label">Purchase Date</label>
                    <input type="date" class="form-control" id="purchaseDate" name="purchaseDate" value="<%= formData.purchaseDate || "" %>">
                </div>
                <div class="col-md-4">
                    <label for="currencyCode" class="form-label">Currency</label>
                    <input type="text" maxlength="3" class="form-control text-uppercase" id="currencyCode" name="currencyCode" value="<%= formData.currencyCode || "USD" %>">
                </div>
                <div class="col-md-4">
                    <label for="itemSubtotal" class="form-label">Subtotal</label>
                    <input type="number" step="0.01" class="form-control" id="itemSubtotal" name="itemSubtotal" value="<%= formData.itemSubtotal || "" %>">
                </div>
                <div class="col-md-4">
                    <label for="discount" class="form-label">Discount</label>
                    <input type="number" step="0.01" class="form-control" id="discount" name="discount" value="<%= formData.discount || "" %>">
                </div>
                <div class="col-md-4">
                    <label for="shipping" class="form-label">Shipping</label>
                    <input type="number" step="0.01" class="form-control" id="shipping" name="shipping" value="<%= formData.shipping || "" %>">
                </div>
                <div class="col-md-4">
                    <label for="tax" class="form-label">Tax</label>
                    <input type="number" step="0.01" class="form-control" id="tax" name="tax" value="<%= formData.tax || "" %>">
                </div>
                <div class="col-md-4">
                    <label for="totalPaid" class="form-label">Total Paid</label>
                    <input type="number" step="0.01" class="form-control" id="totalPaid" name="totalPaid" value="<%= formData.totalPaid || "" %>">
                    <div class="form-text">Optional override. Otherwise effective cost uses subtotal - discount + shipping + tax.</div>
                </div>
                <div class="col-12">
                    <label for="notes" class="form-label">Notes</label>
                    <textarea class="form-control" id="notes" name="notes" rows="3"><%= formData.notes || "" %></textarea>
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Replenishment</button>
        <a href="/coffee-beans/<%= coffeeBean.id %>" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
