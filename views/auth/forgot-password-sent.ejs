<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-envelope-check me-1"></i>
                Check Your Email
            </div>

            <div class="card-body">
                <div class="alert alert-success mb-3">
                    If an active account exists for that email address, a password reset link has been sent.
                </div>

                <p class="text-muted">
                    The reset link expires in 1 hour. If you do not receive an email, check your spam folder or contact an administrator.
                </p>

                <% if (devResetUrl) { %>
                    <div class="alert alert-warning">
                        <strong>Development only:</strong>
                        Email is not configured, so use this reset link while testing locally:
                        <div class="mt-2">
                            <a href="<%= devResetUrl %>"><%= devResetUrl %></a>
                        </div>
                    </div>
                <% } %>

                <a href="/auth/sign-in" class="btn btn-primary w-100">
                    <i class="bi bi-box-arrow-in-right me-1"></i>
                    Back to Sign In
                </a>
            </div>
        </div>
    </div>
</div>
