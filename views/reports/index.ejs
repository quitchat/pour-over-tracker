<div class="mb-4">
    <h1 class="h3 mb-1">Analytics</h1>
    <p class="text-muted mb-0">
        Compare your brew sessions by bean, grinder, brewer, rating, repeat count, and ratio.
    </p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Brew Sessions</div>
                <div class="display-6"><%= summary.brewSessionCount %></div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Rated Sessions</div>
                <div class="display-6"><%= summary.ratedSessionCount %></div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Average Rating</div>
                <div class="display-6"><%= summary.averageRating || "-" %></div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Would Repeat</div>
                <div class="display-6"><%= summary.repeatCount %></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                Average Rating by Bean
            </div>

            <div class="card-body">
                <% if (beanChart.labels.length === 0) { %>
                    <p class="text-muted mb-0">No rated bean data yet.</p>
                <% } else { %>
                    <canvas id="beanRatingChart"></canvas>
                <% } %>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                Average Rating by Grinder
            </div>

            <div class="card-body">
                <% if (grinderChart.labels.length === 0) { %>
                    <p class="text-muted mb-0">No rated grinder data yet.</p>
                <% } else { %>
                    <canvas id="grinderRatingChart"></canvas>
                <% } %>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                Average Rating by Brewer
            </div>

            <div class="card-body">
                <% if (brewerChart.labels.length === 0) { %>
                    <p class="text-muted mb-0">No rated brewer data yet.</p>
                <% } else { %>
                    <canvas id="brewerRatingChart"></canvas>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        Beans
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Bean</th>
                    <th>Brew Count</th>
                    <th>Average Rating</th>
                    <th>Average Ratio</th>
                    <th>Would Repeat Count</th>
                </tr>
            </thead>
            <tbody>
                <% if (beanRows.length === 0) { %>
                    <tr>
                        <td colspan="5" class="text-muted text-center py-4">
                            No brew session data yet.
                        </td>
                    </tr>
                <% } %>

                <% beanRows.forEach(function (row) { %>
                    <tr>
                        <td><%= row.name %></td>
                        <td><%= row.count %></td>
                        <td><%= row.averageRating || "-" %></td>
                        <td><%= row.averageRatio ? "1:" + row.averageRatio : "-" %></td>
                        <td><%= row.repeatCount %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        Grinders
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Grinder</th>
                    <th>Brew Count</th>
                    <th>Average Rating</th>
                    <th>Average Ratio</th>
                    <th>Would Repeat Count</th>
                </tr>
            </thead>
            <tbody>
                <% if (grinderRows.length === 0) { %>
                    <tr>
                        <td colspan="5" class="text-muted text-center py-4">
                            No brew session data yet.
                        </td>
                    </tr>
                <% } %>

                <% grinderRows.forEach(function (row) { %>
                    <tr>
                        <td><%= row.name %></td>
                        <td><%= row.count %></td>
                        <td><%= row.averageRating || "-" %></td>
                        <td><%= row.averageRatio ? "1:" + row.averageRatio : "-" %></td>
                        <td><%= row.repeatCount %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<div class="card">
    <div class="card-header">
        Brewers
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Brewer</th>
                    <th>Brew Count</th>
                    <th>Average Rating</th>
                    <th>Average Ratio</th>
                    <th>Would Repeat Count</th>
                </tr>
            </thead>
            <tbody>
                <% if (brewerRows.length === 0) { %>
                    <tr>
                        <td colspan="5" class="text-muted text-center py-4">
                            No brew session data yet.
                        </td>
                    </tr>
                <% } %>

                <% brewerRows.forEach(function (row) { %>
                    <tr>
                        <td><%= row.name %></td>
                        <td><%= row.count %></td>
                        <td><%= row.averageRating || "-" %></td>
                        <td><%= row.averageRatio ? "1:" + row.averageRatio : "-" %></td>
                        <td><%= row.repeatCount %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const beanChart = <%- JSON.stringify(beanChart) %>;
    const grinderChart = <%- JSON.stringify(grinderChart) %>;
    const brewerChart = <%- JSON.stringify(brewerChart) %>;

    function createBarChart(canvasId, label, chartData) {
        const canvas = document.getElementById(canvasId);

        if (!canvas) {
            return;
        }

        new Chart(canvas, {
            type: "bar",
            data: {
                labels: chartData.labels,
                datasets: [
                    {
                        label: label,
                        data: chartData.values
                    }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        suggestedMin: 0,
                        suggestedMax: 10
                    }
                }
            }
        });
    }

    createBarChart("beanRatingChart", "Average Rating", beanChart);
    createBarChart("grinderRatingChart", "Average Rating", grinderChart);
    createBarChart("brewerRatingChart", "Average Rating", brewerChart);
</script>