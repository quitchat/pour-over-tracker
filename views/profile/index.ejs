<%
    const brewDefaultsErrorsValue = typeof brewDefaultsErrors !== "undefined" ? brewDefaultsErrors : [];
    const brewDefaultsSuccessMessageValue = typeof brewDefaultsSuccessMessage !== "undefined" ? brewDefaultsSuccessMessage : "";
    const brewDefaultsFormDataValue = typeof brewDefaultsFormData !== "undefined" ? brewDefaultsFormData : {};
    const grindersValue = typeof grinders !== "undefined" ? grinders : [];
    const brewersValue = typeof brewers !== "undefined" ? brewers : [];
    const timeZoneOptionsValue = typeof timeZoneOptions !== "undefined" ? timeZoneOptions : [];
%>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-person-circle me-2"></i>
            Profile
        </h1>
        <p class="text-muted mb-0">
            Manage your account information, password, and brew defaults.
        </p>
    </div>

    <a href="/" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>
        Back to Dashboard
    </a>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-person-lines-fill me-1"></i>
                Account Information
            </div>

            <div class="card-body">
                <% if (profileSuccessMessage) { %>
                    <div class="alert alert-success">
                        <%= profileSuccessMessage %>
                    </div>
                <% } %>

                <% if (profileErrors && profileErrors.length > 0) { %>
                    <div class="alert alert-danger">
                        <strong>Please fix the following:</strong>
                        <ul class="mb-0">
                            <% profileErrors.forEach(function (error) { %>
                                <li><%= error %></li>
                            <% }); %>
                        </ul>
                    </div>
                <% } %>

                <form method="post" action="/profile">
                    <div class="mb-3">
                        <label for="displayName" class="form-label">Name</label>
                        <input
                            type="text"
                            class="form-control"
                            id="displayName"
                            name="displayName"
                            value="<%= formData.displayName || "" %>">
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input
                            type="email"
                            class="form-control"
                            id="email"
                            name="email"
                            value="<%= formData.email || "" %>">
                    </div>

                    <div class="mb-3">
                        <label for="timeZone" class="form-label">Timezone</label>
                        <div class="input-group">
                            <select class="form-select" id="timeZone" name="timeZone">
                                <% (timeZoneOptions || []).forEach(function (option) { %>
                                    <option value="<%= option.value %>" <%= (formData.timeZone || "America/Los_Angeles") === option.value ? "selected" : "" %>><%= option.label %></option>
                                <% }); %>
                            </select>
                            <button class="btn btn-outline-secondary" type="button" id="useBrowserTimeZoneButton">Use Mine</button>
                        </div>
                        <div class="form-text">Shown with the current UTC offset. Used for new brew dates. Changing this does not change existing brew dates.</div>
                    </div>

                    <div class="mb-3">
                        <label for="temperatureUnit" class="form-label">Temperature Unit</label>
                        <select class="form-select" id="temperatureUnit" name="temperatureUnit">
                            <option value="C" <%= (formData.temperatureUnit || "C") === "C" ? "selected" : "" %>>Celsius (°C)</option>
                            <option value="F" <%= formData.temperatureUnit === "F" ? "selected" : "" %>>Fahrenheit (°F)</option>
                        </select>
                        <div class="form-text">Brew temperatures are shown and entered with this unit. Existing structured brew temperatures are converted automatically.</div>
                    </div>

                    <div class="mb-3">
                        <label for="preferredCurrencyCode" class="form-label">Preferred Currency</label>
                        <input
                            type="text"
                            maxlength="3"
                            class="form-control text-uppercase"
                            id="preferredCurrencyCode"
                            name="preferredCurrencyCode"
                            value="<%= formData.preferredCurrencyCode || "USD" %>">
                        <div class="form-text">Used as the default currency for new bean purchases. No exchange conversion is performed.</div>
                    </div>

                    <div class="mb-3">
                        <label for="preferredWeightUnit" class="form-label">Preferred Bag Weight Unit</label>
                        <select class="form-select" id="preferredWeightUnit" name="preferredWeightUnit">
                            <option value="G" <%= (formData.preferredWeightUnit || "G") === "G" ? "selected" : "" %>>Grams (g)</option>
                            <option value="OZ" <%= formData.preferredWeightUnit === "OZ" ? "selected" : "" %>>Ounces (oz)</option>
                        </select>
                        <div class="form-text">Used as the default unit for new bean inventory entries.</div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>
                        Save Profile
                    </button>
                </form>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-cup-hot me-1"></i>
                Brew Defaults
            </div>

            <div class="card-body">
                <% if (brewDefaultsSuccessMessageValue) { %>
                    <div class="alert alert-success">
                        <%= brewDefaultsSuccessMessageValue %>
                    </div>
                <% } %>

                <% if (brewDefaultsErrorsValue && brewDefaultsErrorsValue.length > 0) { %>
                    <div class="alert alert-danger">
                        <strong>Please fix the following:</strong>
                        <ul class="mb-0">
                            <% brewDefaultsErrorsValue.forEach(function (error) { %>
                                <li><%= error %></li>
                            <% }); %>
                        </ul>
                    </div>
                <% } %>

                <p class="text-muted">
                    These values auto-fill when you add a new brew session. You can still change them on each brew.
                </p>

                <form method="post" action="/profile/brew-defaults">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="defaultBrewerId" class="form-label">Default Brewer</label>
                            <select class="form-select" id="defaultBrewerId" name="defaultBrewerId">
                                <option value="">No default brewer</option>
                                <% brewersValue.forEach(function (brewer) { %>
                                    <option value="<%= brewer.id %>" <%= String(brewDefaultsFormDataValue.defaultBrewerId || "") === String(brewer.id) ? "selected" : "" %>>
                                        <%= brewer.name %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label for="defaultGrinderId" class="form-label">Default Grinder</label>
                            <select class="form-select" id="defaultGrinderId" name="defaultGrinderId">
                                <option value="">No default grinder</option>
                                <% grindersValue.forEach(function (grinder) { %>
                                    <option value="<%= grinder.id %>" <%= String(brewDefaultsFormDataValue.defaultGrinderId || "") === String(grinder.id) ? "selected" : "" %>>
                                        <%= grinder.name %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label for="defaultCoffeeDoseGrams" class="form-label">Default Coffee Dose g</label>
                            <input
                                type="number"
                                step="0.1"
                                min="0"
                                class="form-control"
                                id="defaultCoffeeDoseGrams"
                                name="defaultCoffeeDoseGrams"
                                placeholder="15"
                                value="<%= brewDefaultsFormDataValue.defaultCoffeeDoseGrams || "" %>">
                        </div>

                        <div class="col-md-6">
                            <label for="defaultWaterTemperatureC" class="form-label">Default Water Temp <%= formData.temperatureUnit === "F" ? "°F" : "°C" %></label>
                            <input
                                type="number"
                                step="1"
                                min="0"
                                class="form-control"
                                id="defaultWaterTemperatureC"
                                name="defaultWaterTemperatureC"
                                placeholder="<%= formData.temperatureUnit === "F" ? "201" : "94" %>"
                                value="<%= brewDefaultsFormDataValue.defaultWaterTemperatureC || "" %>">
                        </div>
                    </div>

                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>
                            Save Brew Defaults
                        </button>

                        <a href="/profile" class="btn btn-outline-secondary">
                            Reset
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-key me-1"></i>
                Change Password
            </div>

            <div class="card-body">
                <% if (passwordSuccessMessage) { %>
                    <div class="alert alert-success">
                        <%= passwordSuccessMessage %>
                    </div>
                <% } %>

                <% if (passwordErrors && passwordErrors.length > 0) { %>
                    <div class="alert alert-danger">
                        <strong>Please fix the following:</strong>
                        <ul class="mb-0">
                            <% passwordErrors.forEach(function (error) { %>
                                <li><%= error %></li>
                            <% }); %>
                        </ul>
                    </div>
                <% } %>

                <form method="post" action="/profile/password">
                    <div class="mb-3">
                        <label for="currentPassword" class="form-label">Current Password</label>
                        <input
                            type="password"
                            class="form-control"
                            id="currentPassword"
                            name="currentPassword"
                            autocomplete="current-password">
                    </div>

                    <div class="mb-3">
                        <label for="newPassword" class="form-label">New Password</label>
                        <input
                            type="password"
                            class="form-control"
                            id="newPassword"
                            name="newPassword"
                            autocomplete="new-password">
                    </div>

                    <div class="mb-3">
                        <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                        <input
                            type="password"
                            class="form-control"
                            id="confirmNewPassword"
                            name="confirmNewPassword"
                            autocomplete="new-password">
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-key me-1"></i>
                        Update Password
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-info-circle me-1"></i>
                Account Summary
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8"><%= user.displayName || "" %></dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8"><%= user.email %></dd>

                    <dt class="col-sm-4">Temperature</dt>
                    <dd class="col-sm-8"><%= formData.temperatureUnit === "F" ? "Fahrenheit (°F)" : "Celsius (°C)" %></dd>

                    <dt class="col-sm-4">Timezone</dt>
                    <dd class="col-sm-8"><%= typeof timeZoneLabel !== "undefined" ? timeZoneLabel : (formData.timeZone || "America/Los_Angeles") %></dd>

                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8"><%= typeof formatDateUs !== "undefined" ? formatDateUs(user.createdAt) : "" %></dd>
                </dl>

                <hr>

                <h2 class="h6">Current Brew Defaults</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Brewer</dt>
                    <dd class="col-sm-7">
                        <%
                            const selectedBrewer = brewersValue.find(function (brewer) {
                                return String(brewer.id) === String(brewDefaultsFormDataValue.defaultBrewerId || "");
                            });
                        %>
                        <%= selectedBrewer ? selectedBrewer.name : "None" %>
                    </dd>

                    <dt class="col-sm-5">Grinder</dt>
                    <dd class="col-sm-7">
                        <%
                            const selectedGrinder = grindersValue.find(function (grinder) {
                                return String(grinder.id) === String(brewDefaultsFormDataValue.defaultGrinderId || "");
                            });
                        %>
                        <%= selectedGrinder ? selectedGrinder.name : "None" %>
                    </dd>

                    <dt class="col-sm-5">Dose</dt>
                    <dd class="col-sm-7"><%= brewDefaultsFormDataValue.defaultCoffeeDoseGrams ? brewDefaultsFormDataValue.defaultCoffeeDoseGrams + " g" : "None" %></dd>

                    <dt class="col-sm-5">Water Temp</dt>
                    <dd class="col-sm-7"><%= brewDefaultsFormDataValue.defaultWaterTemperatureC ? brewDefaultsFormDataValue.defaultWaterTemperatureC + " " + (formData.temperatureUnit === "F" ? "°F" : "°C") : "None" %></dd>
                </dl>

                <hr>

                <p class="text-muted mb-0">
                    Your coffee beans, grinders, brewers, brew sessions, and analytics are associated with this account.
                </p>
            </div>
        </div>
    </div>
</div>


<script>
(function () {
    var button = document.getElementById("useBrowserTimeZoneButton");
    var select = document.getElementById("timeZone");

    if (!button || !select || !window.Intl) {
        return;
    }

    button.addEventListener("click", function () {
        var resolvedOptions = Intl.DateTimeFormat().resolvedOptions();
        var browserTimeZone = resolvedOptions ? resolvedOptions.timeZone : "";

        if (!browserTimeZone) {
            return;
        }

        var existingOption = Array.prototype.find.call(select.options, function (option) {
            return option.value === browserTimeZone;
        });

        if (!existingOption) {
            existingOption = new Option(browserTimeZone, browserTimeZone, true, true);
            select.add(existingOption, 0);
        }

        select.value = browserTimeZone;
    });
})();
</script>
