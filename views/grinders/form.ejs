<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1"><%= pageHeading %></h1>
        <p class="text-muted mb-0">Enter information about your grinder.</p>
    </div>

    <a href="/grinders" class="btn btn-outline-secondary">Back to List</a>
</div>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
        <strong>Please fix the following:</strong>
        <ul class="mb-0">
            <% errors.forEach(function (error) { %>
                <li><%= error %></li>
            <% }); %>
        </ul>
    </div>
<% } %>

<form method="post" action="<%= formAction %>">
    <div class="card mb-3">
        <div class="card-header">
            Grinder Information
        </div>

        <div class="card-body">
            <div class="mb-3">
                <label for="name" class="form-label">Grinder Name</label>
                <input
                    type="text"
                    class="form-control"
                    id="name"
                    name="name"
                    value="<%= formData.name || "" %>">
            </div>

            <div class="mb-3">
                <label for="brand" class="form-label">Brand</label>
                <input
                    type="text"
                    class="form-control"
                    id="brand"
                    name="brand"
                    value="<%= formData.brand || "" %>">
            </div>

            <div class="mb-3">
                <label for="grinderType" class="form-label">Grinder Type</label>
                <select class="form-select" id="grinderType" name="grinderType">
                    <option value="">Select type</option>
                    <option value="Hand Grinder" <%= formData.grinderType === "Hand Grinder" ? "selected" : "" %>>Hand Grinder</option>
                    <option value="Electric Grinder" <%= formData.grinderType === "Electric Grinder" ? "selected" : "" %>>Electric Grinder</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="burrType" class="form-label">Burr Type</label>
                <input
                    type="text"
                    class="form-control"
                    id="burrType"
                    name="burrType"
                    placeholder="Example: conical, flat, stainless steel"
                    value="<%= formData.burrType || "" %>">
            </div>

            <div class="mb-3">
                <label for="defaultGrindSizeRange" class="form-label">Default Grind Size Range</label>
                <input
                    type="text"
                    class="form-control"
                    id="defaultGrindSizeRange"
                    name="defaultGrindSizeRange"
                    placeholder="Example: 80-100 clicks for V60"
                    value="<%= formData.defaultGrindSizeRange || "" %>">
            </div>

            <div class="mb-3">
                <label for="calibrationNotes" class="form-label">Calibration Notes</label>
                <textarea
                    class="form-control"
                    id="calibrationNotes"
                    name="calibrationNotes"
                    rows="4"><%= formData.calibrationNotes || "" %></textarea>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><%= submitButtonText %></button>
        <a href="/grinders" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>