<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Grinders</h1>
        <p class="text-muted mb-0">Track grinders, burr type, calibration notes, grind size range, and usage.</p>
    </div>

    <a href="/grinders/new" class="btn btn-primary align-self-start align-self-sm-center">
        <i class="bi bi-plus-lg me-1"></i>
        Add Grinder
    </a>
</div>

<div class="card equipment-list-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Grinder List</span>
        <span class="badge text-bg-light"><%= grinders.length %></span>
    </div>

    <div class="table-responsive d-none d-lg-block">
        <table class="table table-striped table-hover mb-0 align-middle equipment-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Brand</th>
                    <th>Type</th>
                    <th>Burr Type</th>
                    <th class="text-end">Brews</th>
                    <th class="text-end">Total Ground</th>
                    <th>Default Grind Range</th>
                    <th>Location</th>
                    <th>Calibration Notes</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (grinders.length === 0) { %>
                    <tr>
                        <td colspan="10" class="text-muted text-center py-4">
                            No grinders yet. Click Add Grinder to create one.
                        </td>
                    </tr>
                <% } %>

                <% grinders.forEach(function (grinder) { %>
                    <tr>
                        <td class="fw-semibold"><%= grinder.name %></td>
                        <td><%= grinder.brand || "" %></td>
                        <td><%= grinder.grinderType || "" %></td>
                        <td><%= grinder.burrType || "" %></td>
                        <td class="text-end">
                            <span class="badge text-bg-secondary"><%= grinder.brewCount || 0 %></span>
                        </td>
                        <td class="text-end">
                            <%= grinder.totalGramsGround || "0.0" %> g
                        </td>
                        <td><%= grinder.defaultGrindSizeRange || "" %></td>
                        <td>
                            <% if (grinder.locationName || (grinder.latitude !== null && grinder.longitude !== null)) { %>
                                <div><%= grinder.locationName || "Saved location" %></div>
                                <% if (grinder.latitude !== null && grinder.longitude !== null) { %>
                                    <% const grinderMapUrl = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(grinder.latitude) + "," + String(grinder.longitude)); %>
                                    <div class="small text-muted">
                                        <a href="<%= grinderMapUrl %>" target="_blank" rel="noopener noreferrer">
                                            <i class="bi bi-geo-alt me-1"></i>
                                            <%= Number(grinder.latitude).toFixed(5) %>, <%= Number(grinder.longitude).toFixed(5) %>
                                        </a>
                                    </div>
                                <% } %>
                            <% } %>
                        </td>
                        <td><%= grinder.calibrationNotes || "" %></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/grinders/<%= grinder.id %>/edit" class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <form
                                    method="post"
                                    action="/grinders/<%= grinder.id %>/delete"
                                    onsubmit="return confirm('Delete this grinder?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <div class="equipment-mobile-list d-lg-none">
        <% if (grinders.length === 0) { %>
            <div class="text-muted text-center py-4 px-3">
                No grinders yet. Click Add Grinder to create one.
            </div>
        <% } %>

        <% grinders.forEach(function (grinder) { %>
            <article class="equipment-mobile-card">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div class="min-w-0">
                        <h2 class="h6 mb-1 text-truncate"><%= grinder.name %></h2>
                        <div class="small text-muted">
                            <% const grinderSummary = [grinder.brand, grinder.grinderType, grinder.burrType].filter(Boolean).join(" · "); %>
                            <%= grinderSummary || "No grinder details" %>
                        </div>
                    </div>
                    <span class="badge text-bg-secondary flex-shrink-0"><%= grinder.brewCount || 0 %> brews</span>
                </div>

                <div class="equipment-mobile-metrics mt-3">
                    <div>
                        <div class="equipment-mobile-label">Total Ground</div>
                        <div class="fw-semibold"><%= grinder.totalGramsGround || "0.0" %> g</div>
                    </div>
                    <div>
                        <div class="equipment-mobile-label">Grind Range</div>
                        <div class="fw-semibold"><%= grinder.defaultGrindSizeRange || "—" %></div>
                    </div>
                </div>

                <% if (grinder.locationName || (grinder.latitude !== null && grinder.longitude !== null)) { %>
                    <div class="equipment-mobile-detail mt-3">
                        <div class="equipment-mobile-label">Location</div>
                        <div><%= grinder.locationName || "Saved location" %></div>
                        <% if (grinder.latitude !== null && grinder.longitude !== null) { %>
                            <% const grinderMobileMapUrl = "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(grinder.latitude) + "," + String(grinder.longitude)); %>
                            <a class="small" href="<%= grinderMobileMapUrl %>" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-geo-alt me-1"></i>
                                <%= Number(grinder.latitude).toFixed(5) %>, <%= Number(grinder.longitude).toFixed(5) %>
                            </a>
                        <% } %>
                    </div>
                <% } %>

                <% if (grinder.calibrationNotes) { %>
                    <div class="equipment-mobile-detail mt-3">
                        <div class="equipment-mobile-label">Calibration Notes</div>
                        <div><%= grinder.calibrationNotes %></div>
                    </div>
                <% } %>

                <div class="equipment-mobile-actions mt-3">
                    <a href="/grinders/<%= grinder.id %>/edit" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil-square me-1"></i>
                        Edit
                    </a>

                    <form
                        method="post"
                        action="/grinders/<%= grinder.id %>/delete"
                        onsubmit="return confirm('Delete this grinder?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash me-1"></i>
                            Delete
                        </button>
                    </form>
                </div>
            </article>
        <% }); %>
    </div>
</div>
