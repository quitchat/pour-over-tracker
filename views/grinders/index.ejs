<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Grinders</h1>
        <p class="text-muted mb-0">Track grinders, burr type, calibration notes, grind size range, and usage.</p>
    </div>

    <a href="/grinders/new" class="btn btn-primary align-self-start align-self-sm-center">
        <i class="bi bi-plus-lg me-1"></i>
        Add Grinder
    </a>
</div>

<div class="card equipment-list-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Grinder List</span>
        <span class="badge text-bg-light"><%= grinders.length %></span>
    </div>

    <div class="table-responsive equipment-responsive-table-wrap">
        <table class="table table-striped table-hover mb-0 align-middle equipment-table equipment-responsive-table">
            <thead>
                <tr>
                    <th class="equipment-primary-col">Name</th>
                    <th>Brand</th>
                    <th class="d-none d-md-table-cell">Type</th>
                    <th class="d-none d-xl-table-cell">Burr Type</th>
                    <th class="text-end">Brews</th>
                    <th class="text-end">Total Ground</th>
                    <th class="d-none d-lg-table-cell">Default Grind Range</th>
                    <th class="d-none d-md-table-cell">Location</th>
                    <th class="d-none d-xl-table-cell">Calibration Notes</th>
                    <th class="equipment-action-col">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (grinders.length === 0) { %>
                    <tr>
                        <td colspan="10" class="text-muted text-center py-4">
                            No grinders yet. Click Add Grinder to create one.
                        </td>
                    </tr>
                <% } %>

                <% grinders.forEach(function (grinder) { %>
                    <tr>
                        <td class="fw-semibold equipment-primary-col" data-label="Name">
                            <div><%= grinder.name %></div>
                            <div class="small text-muted d-md-none">
                                <% const grinderMobileSummary = [grinder.grinderType, grinder.burrType].filter(Boolean).join(" · "); %>
                                <%= grinderMobileSummary || "" %>
                            </div>
                            <% if (grinder.defaultGrindSizeRange) { %>
                                <div class="small text-muted d-lg-none">
                                    Grind: <%= grinder.defaultGrindSizeRange %>
                                </div>
                            <% } %>
                            <% if (grinder.locationName || (grinder.latitude !== null && grinder.longitude !== null)) { %>
                                <% const grinderMobileMapUrl = grinder.latitude !== null && grinder.longitude !== null ? "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(grinder.latitude) + "," + String(grinder.longitude)) : ""; %>
                                <div class="small text-muted d-md-none">
                                    <i class="bi bi-geo-alt me-1"></i>
                                    <% if (grinderMobileMapUrl) { %>
                                        <a href="<%= grinderMobileMapUrl %>" target="_blank" rel="noopener noreferrer"><%= grinder.locationName || "Open map" %></a>
                                    <% } else { %>
                                        <%= grinder.locationName %>
                                    <% } %>
                                </div>
                            <% } %>
                        </td>
                        <td data-label="Brand"><%= grinder.brand || "" %></td>
                        <td class="d-none d-md-table-cell" data-label="Type"><%= grinder.grinderType || "" %></td>
                        <td class="d-none d-xl-table-cell" data-label="Burr Type"><%= grinder.burrType || "" %></td>
                        <td class="text-end" data-label="Brews">
                            <span class="badge text-bg-secondary"><%= grinder.brewCount || 0 %></span>
                        </td>
                        <td class="text-end text-nowrap" data-label="Total Ground">
                            <%= grinder.totalGramsGround || "0.0" %> g
                        </td>
                        <td class="d-none d-lg-table-cell" data-label="Default Grind Range"><%= grinder.defaultGrindSizeRange || "" %></td>
                        <td class="d-none d-md-table-cell" data-label="Location">
                            <% if (grinder.locationName || (grinder.latitude !== null && grinder.longitude !== null)) { %>
                                <% const grinderMapUrl = grinder.latitude !== null && grinder.longitude !== null ? "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(String(grinder.latitude) + "," + String(grinder.longitude)) : ""; %>
                                <% if (grinderMapUrl) { %>
                                    <a href="<%= grinderMapUrl %>" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                        <i class="bi bi-geo-alt me-1"></i><%= grinder.locationName || "Open map" %>
                                    </a>
                                <% } else { %>
                                    <%= grinder.locationName %>
                                <% } %>
                            <% } %>
                        </td>
                        <td class="d-none d-xl-table-cell" data-label="Calibration Notes"><%= grinder.calibrationNotes || "" %></td>
                        <td class="equipment-action-col" data-label="Actions">
                            <div class="equipment-action-buttons">
                                <a href="/grinders/<%= grinder.id %>/edit" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square d-inline d-sm-none"></i>
                                    <span class="d-none d-sm-inline">Edit</span>
                                </a>

                                <form
                                    method="post"
                                    action="/grinders/<%= grinder.id %>/delete"
                                    onsubmit="return confirm('Delete this grinder?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash d-inline d-sm-none"></i>
                                        <span class="d-none d-sm-inline">Delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
